---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/public-system.css';
interface Props { title: string; description?: string; active?: string; footer?: boolean; image?: string; noindex?: boolean }
const { title, description = 'Чашка кофе — сеть ресторанов в Новосибирске.', active = '', footer = true, image = '/images/home-hero-v1.png', noindex = false } = Astro.props;
const siteOrigin = import.meta.env.PUBLIC_SITE_URL ?? Astro.url.origin
const canonical = new URL(Astro.url.pathname, siteOrigin)
const imageUrl = new URL(image, siteOrigin)
---
<html lang="ru" class="public-site"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/><meta name="theme-color" content="#fcfbf8"/><link rel="icon" type="image/svg+xml" href="/favicon.svg"/><meta name="description" content={description}/><link rel="canonical" href={canonical}/>{noindex && <meta name="robots" content="noindex,nofollow"/>}<meta property="og:type" content="website"/><meta property="og:locale" content="ru_RU"/><meta property="og:site_name" content="Чашка кофе"/><meta property="og:title" content={`${title} — Чашка кофе`}/><meta property="og:description" content={description}/><meta property="og:url" content={canonical}/><meta property="og:image" content={imageUrl}/><meta name="twitter:card" content="summary_large_image"/><title>{title} — Чашка кофе</title></head><body id="top" class="public-site"><div class="page-shell"><SiteHeader active={active}/><main class="public-main" data-path={Astro.url.pathname}><slot /></main>{footer && <SiteFooter/>}</div></body></html>
