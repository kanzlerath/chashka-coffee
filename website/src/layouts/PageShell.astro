---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
interface Props { title: string; description?: string; active?: string; footer?: boolean; image?: string; noindex?: boolean }
const { title, description = 'Чашка кофе — сеть кофеен в Новосибирске.', active = '', footer = true, image = '/images/home-hero-v1.png', noindex = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.url.origin)
const imageUrl = new URL(image, Astro.url.origin)
---
<html lang="ru"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/><meta name="theme-color" content="#f8f7f2"/><link rel="icon" type="image/svg+xml" href="/favicon.svg"/><meta name="description" content={description}/><link rel="canonical" href={canonical}/>{noindex && <meta name="robots" content="noindex,nofollow"/>}<meta property="og:type" content="website"/><meta property="og:locale" content="ru_RU"/><meta property="og:site_name" content="Чашка кофе"/><meta property="og:title" content={`${title} — Чашка кофе`}/><meta property="og:description" content={description}/><meta property="og:url" content={canonical}/><meta property="og:image" content={imageUrl}/><meta name="twitter:card" content="summary_large_image"/><title>{title} — Чашка кофе</title></head><body id="top"><div class="page-shell"><SiteHeader active={active}/><main><slot /></main>{footer && <SiteFooter/>}</div></body></html>
<style is:global>@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap');@font-face{font-family:'21Cent';src:url('/brand/21Cent-Italic.ttf') format('truetype');font-style:italic;font-display:swap}:root{font-family:Montserrat,Arial,sans-serif;background:#f8f7f2;color:#20251f}*{box-sizing:border-box}body{margin:0}.page-shell{min-height:100svh;overflow:hidden}main{min-width:0}@media(min-width:1100px){body{padding:12px;background:#eeede7}.page-shell{max-width:1920px;margin:auto;border-radius:30px;background:#f8f7f2;box-shadow:0 16px 55px rgba(48,55,45,.08)}.site-header{border-radius:30px 30px 0 0}.site-footer{border-radius:0 0 30px 30px}}</style>
