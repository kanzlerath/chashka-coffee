---
interface Props { title: string; eyebrow: string; intro: string; sections: Array<{heading: string; text: string}> }
const { title, eyebrow, intro, sections } = Astro.props;
---
<html lang="ru"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><title>{title} — Чашка кофе</title></head><body><main><a class="brand" href="/"><img src="/brand/logo.png" alt="Логотип Чашка кофе"/>Чашка кофе</a><section class="hero"><p>{eyebrow}</p><h1>{title}</h1><span>{intro}</span></section><article class="content">{sections.map((section, index)=><section><b>0{index+1}</b><div><h2>{section.heading}</h2><p>{section.text}</p></div></section>)}</article><a class="back" href="/">← На главную</a></main></body></html>
<style>@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap');:root{font-family:Montserrat,Arial,sans-serif;color:#20251f;background:#f8f7f2}*{box-sizing:border-box}body{margin:0}.brand{height:94px;padding:0 6vw;display:flex;align-items:center;gap:9px;color:inherit;text-decoration:none;font-size:20px;font-weight:800}.brand img{width:43px;height:43px;object-fit:contain}.hero{margin:0 2vw;padding:clamp(55px,8vw,125px);border-radius:30px;background:#dcebd1}.hero p{margin:0;color:#759b28;text-transform:uppercase;letter-spacing:.15em;font-size:11px;font-weight:800}.hero h1{max-width:900px;margin:20px 0;font-size:clamp(53px,7vw,112px);line-height:.85;letter-spacing:-.1em}.hero span{display:block;max-width:510px;font-size:15px;line-height:1.6}.content{max-width:980px;padding:clamp(85px,10vw,150px) 7vw;margin:auto}.content section{display:grid;grid-template-columns:90px 1fr;gap:25px;padding:29px 0;border-top:1px solid #c9d0c4}.content section:last-child{border-bottom:1px solid #c9d0c4}.content b{color:#719628;font-size:12px}.content h2{margin:0 0 12px;font-size:25px;letter-spacing:-.06em}.content p{max-width:650px;margin:0;font-size:13px;line-height:1.7}.back{display:inline-block;margin:0 7vw 80px;padding:16px 20px;border:1px solid #889486;border-radius:99px;color:inherit;text-decoration:none;font-size:12px;font-weight:700}@media(max-width:700px){.brand{height:72px;padding:0 20px}.hero{margin:0;padding:62px 20px;border-radius:0}.hero h1{font-size:55px}.content{padding:82px 20px}.content section{grid-template-columns:45px 1fr;gap:10px}.content h2{font-size:21px}.content p{font-size:12px}.back{margin:0 20px 60px}}</style>
