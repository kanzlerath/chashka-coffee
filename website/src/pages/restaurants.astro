---
import PageShell from '../layouts/PageShell.astro';
import type { RestaurantSummary } from '@chashka-coffee/contracts'

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
let restaurants: RestaurantSummary[] = []
let apiUnavailable = false
try { const response = await fetch(`${apiUrl}/api/restaurants`); if (!response.ok) throw new Error(); restaurants = (await response.json()).restaurants } catch { apiUnavailable = true }
const formatLabels = { CITY: 'В городе', PARK: 'В парке', AIRPORT: 'В аэропорту', APART_HOTEL: 'Апарт-отель' } as const
const coverFor = (index: number) => index % 3 === 0 ? '/images/restaurants-hero.png' : '/images/home-hero-v1.png'
---

<PageShell title="Рестораны" active="restaurants">
    <section class="hero"><img src="/images/restaurants-hero.png" alt="Светлый интерьер кофейни" /><div><p class="eyebrow">13 мест для вашего дня</p><h1>Рестораны<br />рядом с вами</h1><p>В центре города, в парках и перед вылетом — выбирайте свою «Чашку кофе».</p></div></section>
    <section class="directory" aria-labelledby="directory-title"><div class="directory-top"><div><p class="eyebrow">найти кофейню</p><h2 id="directory-title">Куда сегодня?</h2></div><p>{restaurants.length || 13} точек для встреч, работы и короткой паузы.</p></div>
      <div class="filters" aria-label="Фильтр ресторанов"><button class="is-active" data-filter="all">Все <span>{restaurants.length || 13}</span></button><button data-filter="CITY">В городе</button><button data-filter="PARK">В парках</button><button data-filter="AIRPORT">В аэропорту</button><button data-filter="APART_HOTEL">Апарт-отель</button></div>
      <div class="map-panel" aria-label="Карта ресторанов"><div><span>Новосибирск</span><i class="pin p1">☕</i><i class="pin p2">☕</i><i class="pin p3">☕</i><i class="pin p4">☕</i><b>13</b><small>кофеен на карте</small></div><a href="#restaurant-list">Смотреть списком <span>↓</span></a></div>
      {apiUnavailable ? <p class="api-note">Запустите API, чтобы увидеть актуальные точки: <code>bun run dev:backend</code>.</p> : <div class="restaurant-grid" id="restaurant-list">{restaurants.map((restaurant, index) => <article class="restaurant" data-area={restaurant.area} data-apart={restaurant.isAtApartHotel}><a class="restaurant-image" href={`/restaurants/${restaurant.slug}`}><img src={restaurant.coverImageUrl ?? coverFor(index)} alt="" /><span>{formatLabels[restaurant.format]}</span></a><div class="restaurant-body"><p>0{index + 1}</p><h3>{restaurant.name.replace('Чашка кофе — ', '')}</h3><span class="address">{restaurant.address}</span><span class="hours">◔ {restaurant.openingHoursLabel}</span><div class="card-actions"><a href={`/restaurants/${restaurant.slug}`}>Подробнее <span>→</span></a><a class="menu-link" href={`/restaurants/${restaurant.slug}/menu`}>Меню <span>↗</span></a></div></div></article>)}</div>}
    </section>
    <section class="menu-banner"><div><p class="eyebrow">меню каждой точки</p><h2>Вкус, который<br />всегда рядом</h2><p>У разных ресторанов — свои сезонные предложения и любимые блюда.</p><a class="button" href="/restaurants/krasny-prospekt/menu">Выбрать ресторан и меню <span>→</span></a></div><img src="/images/home-hero-v1.png" alt="Кофе и свежая выпечка" /></section>
  </PageShell><script>const filters=document.querySelectorAll('[data-filter]');const cards=document.querySelectorAll('.restaurant');filters.forEach((filter)=>filter.addEventListener('click',()=>{filters.forEach((item)=>item.classList.toggle('is-active',item===filter));const value=filter.dataset.filter;cards.forEach((card)=>{card.hidden=!(value==='all'||card.dataset.area===value||(value==='APART_HOTEL'&&card.dataset.apart==='true'))})}))</script>

<style>
@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap');:root{font-family:Montserrat,Arial,sans-serif;color:#1b201b;background:#eaebe5}*{box-sizing:border-box}body{margin:0;padding:14px;background:#eaebe5}a{color:inherit;text-decoration:none}.page-shell{max-width:1680px;margin:auto;background:#fdfcf8;border-radius:30px;overflow:hidden;box-shadow:0 14px 55px rgba(34,40,29,.08)}.header{height:104px;padding:0 clamp(34px,4.2vw,72px);display:flex;align-items:center;gap:34px}.brand,.footer-brand{display:flex;align-items:center;gap:10px;font-weight:800;line-height:.86;letter-spacing:-.075em;font-size:22px}.brand img{object-fit:contain}.header nav{display:flex;gap:34px;margin:auto}.header nav a{font-size:14px;font-weight:600}.header nav .active{border-bottom:2px solid #9bbe2b;padding-bottom:7px}.header-cta{background:#202d24;color:#fff;border-radius:999px;padding:15px 21px;font-size:14px;font-weight:700}.header-cta span{color:#b8d83e;margin-left:7px}.hero{height:min(43vw,690px);min-height:500px;position:relative;margin:0 14px;overflow:hidden;border-radius:25px}.hero img{width:100%;height:100%;object-fit:cover}.hero:after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,#fdfcf8 0%,rgba(253,252,248,.9) 29%,rgba(253,252,248,.1) 62%,transparent)}.hero>div{position:absolute;z-index:1;left:clamp(35px,6vw,105px);top:50%;transform:translateY(-50%);max-width:600px}.eyebrow{margin:0 0 14px;font-size:11px;text-transform:uppercase;letter-spacing:.14em;font-weight:700;color:#8baa27}.hero h1,.directory h2,.menu-banner h2{margin:0;font-size:clamp(58px,6vw,105px);letter-spacing:-.09em;line-height:.86}.hero>div>p:last-child{max-width:390px;margin:27px 0 0;font-size:17px;line-height:1.55;color:#566057}.directory{padding:clamp(95px,10vw,150px) clamp(34px,6.5vw,108px)}.directory-top{display:flex;align-items:end;justify-content:space-between;gap:45px}.directory h2{font-size:clamp(55px,5vw,88px)}.directory-top>p{max-width:280px;margin:0;font-size:16px;line-height:1.55;color:#5b6259}.filters{display:flex;gap:9px;flex-wrap:wrap;margin:46px 0 18px}.filters button{border:1px solid #d7dbd3;border-radius:999px;padding:14px 18px;background:#fffefa;font:600 14px Montserrat,Arial,sans-serif;cursor:pointer}.filters .is-active{background:#202d24;color:white;border-color:#202d24}.filters span{opacity:.7;margin-left:4px}.map-panel{height:310px;border-radius:25px;overflow:hidden;background:linear-gradient(25deg,#d4e2d3 0 18%,#ecf0e9 18% 37%,#d8e5ed 37% 44%,#e9eee8 44% 70%,#d7e3d2 70%);position:relative;isolation:isolate}.map-panel:before,.map-panel:after{content:'';position:absolute;inset:-20% -5%;border-top:15px solid rgba(255,255,255,.78);transform:rotate(-12deg);box-shadow:0 105px 0 rgba(255,255,255,.64),0 210px 0 rgba(255,255,255,.55)}.map-panel:after{inset:-15% -30%;transform:rotate(48deg);border-width:9px;box-shadow:0 125px 0 rgba(255,255,255,.64)}.map-panel>div{position:absolute;z-index:1;left:35px;top:28px;display:flex;align-items:center;gap:10px}.map-panel>div>span{font-size:13px;font-weight:700}.map-panel b{display:grid;place-items:center;width:43px;height:43px;border-radius:50%;background:#202d24;color:#fff;font-size:15px}.map-panel small{font-size:11px}.pin{position:absolute;z-index:1;width:42px;height:42px;display:grid;place-items:center;border-radius:50% 50% 50% 0;background:#202d24;color:#b8d83e;font-style:normal;transform:rotate(-45deg)}.pin::first-letter{transform:rotate(45deg)}.p1{left:36%;top:52%}.p2{left:60%;top:31%}.p3{left:74%;top:61%}.p4{left:49%;top:75%}.map-panel>a{position:absolute;z-index:1;right:23px;bottom:20px;background:#fdfcf8;padding:13px 17px;border-radius:999px;font-size:13px;font-weight:700}.map-panel>a span{margin-left:8px}.restaurant-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:22px}.restaurant{border:1px solid #e1e4dc;border-radius:23px;overflow:hidden;background:#fffefa}.restaurant-image{height:225px;display:block;position:relative;overflow:hidden}.restaurant-image img{width:100%;height:100%;object-fit:cover;transition:transform .35s}.restaurant:hover img{transform:scale(1.04)}.restaurant-image span{position:absolute;top:14px;left:14px;padding:8px 10px;border-radius:999px;background:rgba(253,252,248,.93);font-size:11px;font-weight:700}.restaurant-body{padding:19px}.restaurant-body>p{margin:0;color:#8cad25;font-size:12px;font-weight:700}.restaurant h3{margin:10px 0;font-size:23px;line-height:1;letter-spacing:-.06em}.address,.hours{display:block;font-size:12px;line-height:1.45;color:#626b61}.hours{margin-top:7px}.card-actions{display:flex;gap:8px;margin-top:19px}.card-actions a{flex:1;text-align:center;border:1px solid #d6dad1;border-radius:999px;padding:12px 8px;font-size:12px;font-weight:700}.card-actions .menu-link{background:#202d24;color:#fff;border-color:#202d24}.restaurant[hidden]{display:none}.api-note{padding:28px 0}.menu-banner{margin:0 14px 14px;border-radius:25px;overflow:hidden;min-height:450px;display:grid;grid-template-columns:.9fr 1.1fr;background:#d8e6cf}.menu-banner>div{padding:clamp(42px,6vw,94px)}.menu-banner h2{font-size:clamp(47px,5vw,83px)}.menu-banner p:not(.eyebrow){max-width:370px;font-size:16px;line-height:1.55;color:#4e5d4f;margin:27px 0}.menu-banner img{width:100%;height:100%;object-fit:cover}.button{display:inline-flex;align-items:center;gap:28px;padding:18px 21px;border-radius:999px;background:#202d24;color:#fff;font-size:14px;font-weight:700}footer{padding:75px clamp(34px,6.5vw,105px) 23px;background:#202d24;color:#f7f6ed;display:grid;grid-template-columns:1fr 1.2fr 1fr;gap:35px;align-items:start}.footer-brand{font-size:25px}.footer-brand img{object-fit:contain}.footer-brand+p{font-size:clamp(28px,3vw,43px);font-weight:700;line-height:.93;letter-spacing:-.07em;margin:0}.footer-links{display:flex;gap:14px;flex-wrap:wrap}.footer-links a,footer>span{font-size:12px;color:#d1d9d0}footer>span{grid-column:1/-1;border-top:1px solid rgba(255,255,255,.16);padding-top:20px}.mobile-nav{display:none}@media(max-width:840px){body{padding:0;background:#fdfcf8}.page-shell{border-radius:0;box-shadow:none}.header{height:72px;padding:0 20px}.brand{font-size:18px}.brand img{width:39px;height:39px}.header nav,.header-cta{display:none}.hero{height:620px;min-height:0;margin:0;border-radius:0}.hero:after{background:linear-gradient(180deg,#fdfcf8 0%,rgba(253,252,248,.87) 44%,rgba(253,252,248,.05) 85%,transparent)}.hero>div{top:72px;left:20px;right:20px;transform:none}.hero h1{font-size:54px}.hero>div>p:last-child{font-size:15px;margin-top:21px}.directory{padding:81px 20px}.directory-top{display:block}.directory h2{font-size:53px}.directory-top>p{margin-top:22px;font-size:15px}.filters{flex-wrap:nowrap;overflow:auto;margin:33px -20px 15px;padding:0 20px 8px}.filters button{white-space:nowrap;font-size:12px;padding:12px 15px}.map-panel{height:250px;border-radius:20px}.map-panel>div{left:20px;top:19px}.map-panel>a{right:12px;bottom:12px;font-size:11px}.restaurant-grid{grid-template-columns:1fr;gap:9px;margin-top:12px}.restaurant{border-radius:20px;display:grid;grid-template-columns:42% 58%}.restaurant-image{height:100%}.restaurant-body{padding:17px}.restaurant h3{font-size:22px}.card-actions{margin-top:15px}.card-actions a{padding:10px 6px;font-size:11px}.menu-banner{margin:0 12px 12px;border-radius:22px;display:block}.menu-banner>div{padding:48px 25px}.menu-banner h2{font-size:50px}.menu-banner img{height:280px;display:block}footer{margin-bottom:71px;padding:46px 20px 20px;display:block}.footer-brand+p{margin:32px 0}.footer-links{margin:34px 0}footer>span{display:block}.mobile-nav{position:fixed;z-index:4;bottom:0;left:0;right:0;height:71px;display:flex;justify-content:space-around;align-items:center;background:rgba(253,252,248,.94);backdrop-filter:blur(14px);border-top:1px solid #dde0d8}.mobile-nav a{font-size:19px;display:flex;flex-direction:column;align-items:center;gap:2px;color:#747a72}.mobile-nav small{font-size:9px;font-weight:600}.mobile-nav .active{color:#202d24}.mobile-nav .active:first-letter{background:#b5d83e;border-radius:12px;padding:1px 8px}}
</style>
