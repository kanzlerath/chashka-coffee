---
import type { RestaurantSummary } from '@chashka-coffee/contracts'

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
let restaurants: RestaurantSummary[] = []
let apiUnavailable = false

try {
  const response = await fetch(`${apiUrl}/api/restaurants`)
  if (!response.ok) throw new Error(`Catalog request failed with ${response.status}`)
  restaurants = (await response.json()).restaurants
} catch {
  apiUnavailable = true
}

const formatLabels = {
  CITY: 'В городе',
  PARK: 'В парке',
  AIRPORT: 'В аэропорту',
  APART_HOTEL: 'Апарт-отель',
} as const
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Рестораны сети «Чашка кофе»: адреса, часы работы и меню." />
    <title>Рестораны — Чашка кофе</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Чашка кофе, на главную"><span>☕</span> Чашка кофе</a>
      <nav aria-label="Основная навигация"><a class="active" href="/restaurants">Рестораны</a><a href="/menu">Меню</a><a href="/delivery">Доставка</a><a href="/app">Приложение</a><a href="/about">О нас</a></nav>
      <a class="delivery" href="/app">Доставка <span>↗</span></a>
    </header>

    <main>
      <section class="hero">
        <img src="/images/restaurants-hero.png" alt="Светлый интерьер кофейни с деревянными столами" />
        <div class="hero-copy">
          <p class="eyebrow">13 точек в Новосибирске</p>
          <h1>Найдите свою<br />«Чашку кофе»</h1>
          <p>В городе, в парках и перед вылетом — с одним простым маршрутом к хорошему кофе.</p>
        </div>
      </section>

      <section class="directory" aria-labelledby="directory-title">
        <div class="directory-heading"><p class="eyebrow">Рестораны</p><h2 id="directory-title">Рядом с вами</h2><p>{restaurants.length || 13} мест для встречи, работы и короткой паузы.</p></div>
        <div class="filters" aria-label="Фильтр ресторанов">
          <button class="is-active" data-filter="all">Все <span>{restaurants.length || 13}</span></button>
          <button data-filter="CITY">В городе</button>
          <button data-filter="PARK">В парках</button>
          <button data-filter="AIRPORT">В аэропорту</button>
          <button data-filter="APART_HOTEL">Апарт-отель</button>
        </div>

        {apiUnavailable ? (
          <p class="api-note">Запустите API, чтобы увидеть актуальные точки: <code>bun run dev:backend</code>.</p>
        ) : (
          <div class="restaurant-list" id="restaurant-list">
            {restaurants.map((restaurant, index) => (
              <article class="restaurant" data-area={restaurant.area} data-apart={restaurant.isAtApartHotel} style={`--delay:${index * 45}ms`}>
                <div class="restaurant-topline"><span>{formatLabels[restaurant.format]}</span><span>0{index + 1}</span></div>
                <h3>{restaurant.name.replace('Чашка кофе — ', '')}</h3>
                <p class="address">{restaurant.address}</p>
                <div class="meta"><span>{restaurant.city}</span><span>{restaurant.openingHoursLabel}</span></div>
                <div class="actions"><a href={`/restaurants/${restaurant.slug}`}>Подробнее <span>→</span></a><a class="menu-link" href={`/restaurants/${restaurant.slug}/menu`}>Меню <span>↗</span></a></div>
              </article>
            ))}
          </div>
        )}
      </section>
    </main>

    <footer><span>© {new Date().getFullYear()} Чашка кофе</span><a href="/contacts">Контакты</a><a href="/legal">Правовая информация</a><span>Любимый вкус — всегда рядом</span></footer>

    <script>
      const filters = document.querySelectorAll<HTMLButtonElement>('[data-filter]')
      const restaurants = document.querySelectorAll<HTMLElement>('.restaurant')
      filters.forEach((filter) => filter.addEventListener('click', () => {
        filters.forEach((item) => item.classList.toggle('is-active', item === filter))
        const value = filter.dataset.filter
        restaurants.forEach((restaurant) => {
          const show = value === 'all' || restaurant.dataset.area === value || (value === 'APART_HOTEL' && restaurant.dataset.apart === 'true')
          restaurant.hidden = !show
        })
      }))
    </script>
  </body>
</html>

<style>
  :root { font-family: Inter, ui-sans-serif, system-ui, sans-serif; color: #241914; background: #f6f3ee; }
  * { box-sizing: border-box; } body { margin: 0; } a { color: inherit; text-decoration: none; }
  .site-header { height: 76px; display: flex; align-items: center; justify-content: space-between; gap: 28px; padding: 0 4vw; background: #fdfcf9; border-bottom: 1px solid #e7e0d8; position: sticky; top: 0; z-index: 3; }
  .brand { font-size: 20px; font-weight: 750; letter-spacing: -.04em; white-space: nowrap; }.brand span { color: #9e5e2f; margin-right: 5px; }
  nav { display: flex; gap: clamp(14px, 2vw, 31px); font-size: 13px; color: #746a62; } nav a { padding: 29px 0 25px; } nav .active { color: #241914; border-bottom: 2px solid #8b542e; }
  .delivery { background: #2b1d17; color: white; padding: 12px 16px; border-radius: 8px; font-size: 13px; font-weight: 650; white-space: nowrap; }.delivery span { margin-left: 8px; color: #dcb38e; }
  .hero { height: min(66vw, 635px); min-height: 430px; position: relative; overflow: hidden; background: #d8d0c6; }.hero img { width: 100%; height: 100%; object-fit: cover; object-position: center; }.hero::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(247,244,239,.98) 0%, rgba(247,244,239,.76) 32%, rgba(247,244,239,.06) 65%); }.hero-copy { position: absolute; z-index: 1; top: 50%; left: max(4vw, calc((100vw - 1320px)/2)); transform: translateY(-50%); max-width: 495px; }.eyebrow { text-transform: uppercase; letter-spacing: .14em; font-size: 11px; font-weight: 700; color: #956036; margin: 0 0 14px; }.hero h1 { font-size: clamp(46px, 6.8vw, 94px); line-height: .94; letter-spacing: -.075em; margin: 0; }.hero-copy > p:last-child { max-width: 340px; margin: 27px 0 0; color: #5d5048; font-size: 18px; line-height: 1.45; }
  .directory { max-width: 1320px; margin: 0 auto; padding: 110px 4vw 130px; }.directory-heading { display: grid; grid-template-columns: 1fr 1.1fr 1fr; align-items: end; border-bottom: 1px solid #dcd4cb; padding-bottom: 28px; }.directory-heading .eyebrow { grid-column: 1 / -1; }.directory h2 { margin: 0; font-size: clamp(36px, 4vw, 61px); letter-spacing: -.065em; line-height: .95; }.directory-heading > p:last-child { margin: 0; max-width: 260px; color: #6f625a; line-height: 1.45; }
  .filters { display: flex; flex-wrap: wrap; gap: 8px; padding: 26px 0 36px; }.filters button { font: inherit; border: 1px solid #d9d0c7; background: transparent; border-radius: 999px; padding: 10px 15px; color: #5e5148; cursor: pointer; transition: .2s; }.filters button:hover, .filters .is-active { background: #2b1d17; color: white; border-color: #2b1d17; }.filters span { opacity: .6; margin-left: 3px; }
  .restaurant-list { border-top: 1px solid #dcd4cb; }.restaurant { padding: 26px 0 27px; display: grid; grid-template-columns: 80px 1.25fr 1fr 1.35fr; gap: 20px; align-items: center; border-bottom: 1px solid #dcd4cb; animation: rise .5s both; animation-delay: var(--delay); }.restaurant-topline { display: contents; }.restaurant-topline span { font-size: 12px; color: #9a704f; }.restaurant-topline span:last-child { grid-column: 4; text-align: right; color: #b5aaa0; }.restaurant h3 { grid-column: 2; margin: 0; font-size: 23px; letter-spacing: -.04em; }.address { margin: 0; color: #685c54; }.meta { grid-column: 2 / 4; display: flex; gap: 22px; color: #81756c; font-size: 13px; }.actions { grid-column: 4; grid-row: 2 / 4; display: flex; justify-content: flex-end; gap: 8px; }.actions a { padding: 10px 13px; border-radius: 5px; border: 1px solid #d3c9c0; font-size: 13px; transition: .2s; }.actions .menu-link { background: #2b1d17; color: #fff; border-color: #2b1d17; }.actions a:hover { transform: translateY(-2px); }
  .api-note { padding: 30px 0; color: #7e5540; } code { font-family: ui-monospace, monospace; font-size: .9em; }.restaurant[hidden] { display: none; }
  footer { border-top: 1px solid #e2dad1; min-height: 95px; padding: 30px 4vw; display: flex; gap: 25px; flex-wrap: wrap; align-items: center; justify-content: space-between; color: #7c7067; font-size: 12px; } footer a:hover { color: #2b1d17; }
  @keyframes rise { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  @media (max-width: 760px) { .site-header { height: 64px; padding: 0 18px; }.brand { font-size: 18px; } nav { display: none; }.delivery { padding: 10px 12px; }.hero { min-height: 520px; height: 78svh; }.hero img { object-position: 62% center; }.hero::after { background: linear-gradient(180deg, rgba(247,244,239,.94) 0%, rgba(247,244,239,.76) 46%, rgba(247,244,239,.12) 78%); }.hero-copy { left: 18px; right: 18px; top: 32%; transform: none; }.hero h1 { font-size: 55px; }.directory { padding: 66px 18px 82px; }.directory-heading { display: block; }.directory-heading > p:last-child { margin-top: 18px; }.restaurant { grid-template-columns: 1fr auto; gap: 10px; padding: 21px 0; }.restaurant-topline { display: flex; grid-column: 1 / -1; justify-content: space-between; }.restaurant-topline span:last-child { grid-column: auto; }.restaurant h3 { grid-column: 1 / -1; font-size: 21px; }.address { grid-column: 1 / -1; }.meta { grid-column: 1 / -1; flex-direction: column; gap: 4px; }.actions { grid-column: 1 / -1; grid-row: auto; justify-content: flex-start; margin-top: 8px; }.filters { overflow-x: auto; flex-wrap: nowrap; padding-bottom: 23px; }.filters button { white-space: nowrap; } footer { padding: 24px 18px; justify-content: flex-start; gap: 14px 22px; } }
</style>
