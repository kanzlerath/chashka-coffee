---
import PageShell from '../layouts/PageShell.astro';
const benefits=[['Быстрый заказ','Любимые блюда и напитки — без лишних шагов.'],['Доставка и самовывоз','Выбирайте сценарий, который удобен сегодня.'],['Бонусы','Копите баллы и открывайте новые привилегии.'],['Всё в одном месте','Меню, рестораны, акции и любимый кофе.']];
---
<PageShell title="Приложение" description="Приложение Чашка кофе: заказ, доставка, бонусы и любимое меню." active="app"><section class="hero"><div><p>Чашка кофе — всегда рядом</p><h1>Любимое<br/>в телефоне</h1><span>Заказывайте в пару касаний, копите бонусы и находите свою «Чашку кофе» по пути.</span><div class="stores"><a href="#download">App Store ↗</a><a href="#download">Google Play ↗</a></div></div><div class="phone"><small>Доброе утро</small><strong>Что будем<br/>сегодня?</strong><b>☕</b><i>Ваш любимый латте уже ждёт</i></div></section><section class="delivery"><b>↗</b><div><p>Когда хочется без ожидания</p><h2>Доставка<br/>из ресторана</h2></div><span>Заказывайте любимое в приложении или переходите в Яндекс Еду.</span><a href="/delivery">Как заказать →</a></section><section class="benefits"><div class="heading"><p>Зачем приложение</p><h2>Всё складывается<br/>в хороший день</h2></div><div>{benefits.map(([title,copy],index)=><article><b>0{index+1}</b><h3>{title}</h3><span>{copy}</span></article>)}</div></section><section id="download" class="download"><div><p>Уже в приложении</p><h2>Выбирайте<br/>любимое быстрее</h2><span>Наведите камеру на QR-код или откройте магазин приложений.</span><div class="stores"><a href="#">App Store ↗</a><a href="#">Google Play ↗</a></div></div><b class="qr">ЧК</b></section></PageShell>
<style>.hero{min-height:650px;margin:0 2vw;padding:clamp(55px,8vw,120px);border-radius:29px;background:#dfe8c9;display:grid;grid-template-columns:1fr 1fr;align-items:center;overflow:hidden}.hero p,.heading p,.delivery p,.download p{margin:0;color:#809d29;text-transform:uppercase;letter-spacing:.14em;font-size:11px;font-weight:800}.hero h1,.heading h2,.download h2{margin:20px 0;font-size:clamp(57px,6vw,106px);line-height:.84;letter-spacing:-.1em}.hero span,.download span{display:block;max-width:400px;font-size:15px;line-height:1.6}.stores{display:flex;gap:9px;flex-wrap:wrap;margin-top:30px}.stores a,.delivery a{padding:15px 18px;border-radius:99px;background:#20382b;color:#fff;text-decoration:none;font-size:12px;font-weight:700}.phone{justify-self:center;width:238px;height:455px;padding:62px 25px;border:9px solid #20382b;border-radius:40px;background:#f8f7f2;box-shadow:22px 23px 0 rgba(84,105,59,.13);transform:rotate(7deg)}.phone small{font-size:11px;color:#70806e}.phone strong{display:block;margin-top:9px;font-size:31px;line-height:.85;letter-spacing:-.09em}.phone b{width:134px;aspect-ratio:1;display:grid;place-items:center;margin:46px auto 20px;border-radius:50%;background:#b9dc3d;font-size:62px}.phone i{display:block;font-style:normal;text-align:center;font-size:10px;line-height:1.4}.delivery{margin:15px 2vw;min-height:170px;padding:30px clamp(24px,5vw,76px);border-radius:27px;background:#20382b;color:#fff;display:grid;grid-template-columns:58px 1fr 1fr auto;align-items:center;gap:25px}.delivery>b{display:grid;place-items:center;width:58px;height:58px;border-radius:17px;background:#b9dc3d;color:#20382b;font-size:28px}.delivery p{color:#b9dc3d}.delivery h2{margin:7px 0 0;font-size:clamp(28px,3vw,48px);line-height:.88;letter-spacing:-.08em}.delivery>span{max-width:280px;font-size:13px;line-height:1.55;color:#d8e1d6}.delivery a{background:#f8f7f2;color:#20382b}.benefits{padding:clamp(90px,11vw,165px) 7vw}.heading h2{font-size:clamp(48px,5vw,87px)}.benefits>div:last-child{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:55px}.benefits article{min-height:270px;padding:25px;border-radius:23px;background:#edf0e8}.benefits article:nth-child(2){background:#dfe8c9}.benefits article:nth-child(3){background:#20382b;color:#fff}.benefits b{font-size:12px;color:#809d29}.benefits h3{margin:92px 0 11px;font-size:26px;line-height:.92;letter-spacing:-.07em}.benefits span{display:block;font-size:12px;line-height:1.55}.download{margin:0 2vw;padding:clamp(48px,7vw,105px);min-height:470px;border-radius:28px;background:#eee5da;display:grid;grid-template-columns:1fr 1fr;align-items:center}.download h2{font-size:clamp(48px,5vw,82px)}.qr{justify-self:center;width:220px;aspect-ratio:1;display:grid;place-items:center;border:13px solid #20382b;background:repeating-linear-gradient(90deg,#20382b 0 10px,#f8f7f2 10px 19px),repeating-linear-gradient(#20382b 0 10px,#f8f7f2 10px 19px);background-blend-mode:multiply;color:#20382b;font-size:40px;letter-spacing:-.15em}@media(max-width:700px){.hero{margin:0;min-height:690px;padding:56px 20px 0;display:block;border-radius:0}.hero h1{font-size:59px}.hero span{font-size:14px}.phone{margin:49px auto -58px;transform:rotate(5deg) scale(.82);transform-origin:bottom}.delivery{margin:12px;padding:25px;grid-template-columns:52px 1fr;gap:13px 17px;border-radius:22px}.delivery>b{width:52px;height:52px}.delivery>span,.delivery a{grid-column:1/-1}.benefits{padding:84px 20px}.heading h2{font-size:52px}.benefits>div:last-child{grid-template-columns:1fr 1fr;gap:8px;margin-top:34px}.benefits article{min-height:225px;padding:18px;border-radius:19px}.benefits h3{margin-top:72px;font-size:22px}.benefits span{font-size:10px}.download{margin:0;padding:62px 20px;border-radius:0;display:block}.download h2{font-size:53px}.qr{width:185px;margin:42px auto 0}}</style>
