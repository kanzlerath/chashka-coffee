---
import PageShell from '../layouts/PageShell.astro';
const levels=[['Знакомство','1%', 'Начните с первой чашки'],['Свой человек','3%', 'Больше любимого — больше бонусов'],['Близкий друг','5%', 'Максимум привилегий для постоянных гостей']]
---
<PageShell title="Программа лояльности" active="loyalty"><section class="hero"><div><p class="eyebrow">клуб друзей</p><h1>Каждая чашка<br/>возвращается</h1><p>Копите баллы, получайте больше любимого и оставайтесь ближе к «Чашке кофе».</p><a class="button" href="/app">Стать участником <span>→</span></a></div><div class="coin" aria-hidden="true"><span>ЧК</span><i>★</i></div></section><section class="how"><p class="eyebrow">как это работает</p><h2>Пейте кофе.<br/>Получайте больше.</h2><div class="how-grid"><article><b>01</b><h3>Покажите карту</h3><p>Карта программы живёт в приложении.</p></article><article><b>02</b><h3>Копите баллы</h3><p>За каждую покупку начисляются бонусы.</p></article><article><b>03</b><h3>Тратьте с удовольствием</h3><p>Оплачивайте баллами любимые позиции.</p></article></div></section><section class="levels"><div><p class="eyebrow">уровни программы</p><h2>Чем ближе,<br/>тем больше</h2></div><div>{levels.map(([title,percent,text],index)=><article><span>0{index+1}</span><strong>{percent}</strong><h3>{title}</h3><p>{text}</p></article>)}</div></section><section class="app"><div><p class="eyebrow">в приложении</p><h2>Все баллы<br/>под рукой</h2><p>Уровень, баланс и приятные предложения — в вашем телефоне.</p><a class="button" href="/app">Скачать приложение <span>→</span></a></div><div class="phone" aria-hidden="true"><small>Ваш баланс</small><b>1 250</b><span>баллов</span><i>+ 120 баллов</i></div></section></PageShell>
<style>
@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap');:root{font-family:Montserrat,Arial,sans-serif;color:#1b201b;background:#eaebe5}*{box-sizing:border-box}body{margin:0;padding:14px;background:#eaebe5}a{color:inherit;text-decoration:none}.shell{max-width:1680px;margin:auto;overflow:hidden;border-radius:30px;background:#fdfcf8;box-shadow:0 14px 55px rgba(34,40,29,.08)}header{height:104px;padding:0 clamp(34px,4.2vw,72px);display:flex;align-items:center;gap:34px}.brand,.footer-brand{display:flex;align-items:center;gap:10px;font-size:22px;font-weight:800;line-height:.86;letter-spacing:-.075em}header nav{display:flex;gap:30px;margin:auto}header nav a{font-size:14px;font-weight:600}header nav .active{padding-bottom:7px;border-bottom:2px solid #9bbe2b}.top-cta,.button{padding:15px 21px;border-radius:999px;background:#202d24;color:#fff;font-size:14px;font-weight:700}.top-cta span{color:#b9d93d;margin-left:7px}.hero{margin:0 14px;padding:clamp(60px,8vw,130px);min-height:620px;border-radius:25px;background:#e5eec5;display:grid;grid-template-columns:1fr 1fr;align-items:center;overflow:hidden}.eyebrow{margin:0 0 14px;color:#8baa27;text-transform:uppercase;letter-spacing:.14em;font-size:11px;font-weight:700}.hero h1,.how h2,.levels h2,.app h2{margin:0;font-size:clamp(58px,6vw,106px);line-height:.85;letter-spacing:-.095em}.hero p:not(.eyebrow),.app p:not(.eyebrow){max-width:420px;margin:27px 0;font-size:17px;line-height:1.55;color:#576057}.button{display:inline-flex;gap:27px;align-items:center}.coin{justify-self:center;position:relative;width:330px;aspect-ratio:1;border:24px solid #a9cc32;border-radius:50%;background:#202d24;color:#fdfcf8;display:grid;place-items:center;font-size:86px;font-weight:800;letter-spacing:-.15em;box-shadow:22px 25px 0 rgba(78,100,42,.13);transform:rotate(-10deg)}.coin i{position:absolute;right:-18px;top:32px;width:80px;aspect-ratio:1;border-radius:50%;display:grid;place-items:center;background:#fdfcf8;color:#a9cc32;font-style:normal;font-size:36px}.how{padding:clamp(100px,11vw,170px) clamp(34px,6.5vw,108px)}.how h2,.levels h2{font-size:clamp(52px,5vw,90px)}.how-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:60px}.how-grid article{min-height:265px;padding:27px;border-radius:23px;background:#eef0e8}.how-grid b{font-size:13px;color:#8eae26}.how-grid h3{margin:70px 0 10px;font-size:29px;line-height:.92;letter-spacing:-.07em}.how-grid p{margin:0;font-size:14px;line-height:1.5;color:#5c645a}.levels{margin:0 14px;padding:clamp(50px,7vw,105px);border-radius:25px;background:#202d24;color:#fff;display:grid;grid-template-columns:.85fr 1.15fr;gap:50px}.levels .eyebrow{color:#b8d93c}.levels>div:last-child{display:grid;gap:1px}.levels article{display:grid;grid-template-columns:52px 90px 1fr;gap:18px;align-items:center;padding:24px 0;border-bottom:1px solid rgba(255,255,255,.18)}.levels span{font-size:12px;color:#b8d93c}.levels strong{font-size:38px;letter-spacing:-.08em}.levels h3{margin:0;font-size:23px}.levels p{grid-column:3;margin:4px 0 0;font-size:12px;color:#d4dcd4}.app{margin:0 14px 14px;padding:clamp(48px,7vw,108px);min-height:460px;border-radius:25px;background:#eee6db;display:grid;grid-template-columns:1fr 1fr;align-items:center}.app h2{font-size:clamp(48px,5vw,82px)}.phone{justify-self:center;width:220px;height:370px;padding:74px 26px;border:9px solid #202d24;border-radius:36px;background:#fdfcf8;box-shadow:18px 21px 0 rgba(76,81,66,.13);transform:rotate(7deg)}.phone small,.phone span{display:block;font-size:12px;color:#6e776d}.phone b{display:block;margin:10px 0 0;font-size:46px;letter-spacing:-.09em}.phone i{display:block;margin-top:75px;padding:12px;border-radius:999px;background:#b7d93d;text-align:center;font-size:11px;font-style:normal;font-weight:700}footer{padding:70px clamp(34px,6.5vw,105px) 22px;background:#202d24;color:#fff;display:grid;grid-template-columns:1fr 1.2fr 1fr;gap:35px}.footer-brand{font-size:25px}.footer-brand+p{margin:0;font-size:clamp(28px,3vw,43px);line-height:.93;font-weight:700;letter-spacing:-.07em}.links{display:flex;gap:15px}.links a,footer>span{font-size:12px;color:#d1d9d0}footer>span{grid-column:1/-1;padding-top:20px;border-top:1px solid rgba(255,255,255,.16)}@media(max-width:840px){body{padding:0;background:#fdfcf8}.shell{border-radius:0;box-shadow:none}header{height:72px;padding:0 20px}.brand{font-size:18px}.brand img{width:39px;height:39px}header nav,.top-cta{display:none}.hero{margin:0;padding:56px 20px 0;display:block;min-height:690px;border-radius:0}.hero h1{font-size:57px}.hero p:not(.eyebrow),.app p:not(.eyebrow){font-size:15px;margin:22px 0}.coin{width:245px;margin:55px auto 0;border-width:18px;font-size:64px}.coin i{width:60px;font-size:27px}.how{padding:85px 20px}.how h2,.levels h2{font-size:52px}.how-grid{grid-template-columns:1fr;gap:8px;margin-top:34px}.how-grid article{min-height:180px;padding:20px}.how-grid h3{margin:35px 0 7px;font-size:25px}.levels{margin:0 12px;padding:48px 25px;border-radius:22px;display:block}.levels>div:last-child{margin-top:34px}.levels article{grid-template-columns:36px 70px 1fr;gap:10px}.levels strong{font-size:30px}.levels h3{font-size:18px}.app{margin:12px;padding:48px 25px 0;border-radius:22px;display:block;min-height:680px}.app h2{font-size:51px}.phone{margin:58px auto -52px;transform:rotate(5deg) scale(.86);transform-origin:bottom center}footer{padding:46px 20px 20px;display:block}.footer-brand+p{margin:30px 0}.links{margin:30px 0}footer>span{display:block}}
</style>
