---
const formats = [
  ['01', 'Городская кофейня', 'От 80 м²', 'Полноценное место для завтраков, встреч и длинных разговоров.'],
  ['02', 'Кофейня to go', 'От 25 м²', 'Компактный формат для делового потока и оживлённых улиц.'],
  ['03', 'Кофе в парке', 'Сезонный формат', 'Точка притяжения там, где люди выбирают прогулку.'],
  ['04', 'Транспортный хаб', 'От 15 м²', 'Быстрый, понятный сервис в местах с высоким трафиком.'],
];
const stages = ['Знакомимся', 'Оцениваем локацию', 'Проектируем', 'Открываемся'];
---
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Франшиза Чашка кофе — открывайте кофейню с живым брендом и поддержкой команды." />
    <title>Франшиза — Чашка кофе</title>
  </head>
  <body>
    <main>
      <a class="brand" href="/"><img src="/brand/logo.png" alt="Логотип Чашка кофе" />Чашка кофе</a>
      <section class="hero">
        <img src="/images/restaurants-hero.png" alt="Интерьер кофейни" />
        <div class="hero-copy">
          <p>франшиза чашка кофе</p>
          <h1>Открывайте<br />место, куда<br />хочется вернуться</h1>
          <span>Не просто точку с кофе — живую кофейню с характером, понятной моделью и поддержкой на каждом шаге.</span>
          <a href="#form">Получить презентацию <b>↓</b></a>
        </div>
        <div class="mark">ЧК<br /><em>coffee<br />people</em></div>
      </section>

      <section class="proof">
        <p>вместе с 2006 года</p>
        <h2>Строим не сеть.<br />Строим привычку заходить.</h2>
        <div class="numbers"><article><b>20</b><span>лет рядом<br />с гостями</span></article><article><b>13</b><span>кофеен<br />в Новосибирске</span></article><article><b>4</b><span>формата для<br />разных локаций</span></article></div>
      </section>

      <section class="formats">
        <div class="formats-heading"><p>форматы</p><h2>Найдём форму<br />для вашей точки</h2></div>
        <div class="format-list">{formats.map(([number,title,metric,description]) => <article><b>{number}</b><h3>{title}</h3><strong>{metric}</strong><p>{description}</p><a href="#form" aria-label={`Узнать о формате ${title}`}>↗</a></article>)}</div>
      </section>

      <section class="support">
        <div><p>с вами до открытия и дальше</p><h2>Делимся<br />всем, что<br />работает</h2></div>
        <ul><li>Поможем выбрать и оценить локацию</li><li>Создадим проект и подготовим команду</li><li>Передадим стандарты, рецептуры и закупки</li><li>Останемся на связи после запуска</li></ul>
      </section>

      <section class="road"><p>путь к открытию</p><div>{stages.map((stage,index)=><article><b>0{index+1}</b><span>{stage}</span></article>)}</div></section>

      <section class="form" id="form">
        <div><p>узнать условия</p><h2>Давайте<br />обсудим<br />вашу идею</h2><span>Оставьте контакты — пришлём презентацию и договоримся о первом разговоре.</span></div>
        <form><label>Ваше имя<input placeholder="Как к вам обращаться" /></label><label>Телефон<input type="tel" placeholder="+7" /></label><label>E-mail<input type="email" placeholder="name@mail.ru" /></label><label>Город<input placeholder="Где хотите открыть кофейню" /></label><button type="button">Получить презентацию <b>→</b></button><small>Нажимая кнопку, вы соглашаетесь с обработкой персональных данных.</small></form>
      </section>
    </main>
  </body>
</html>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap');
  :root{font-family:Montserrat,Arial,sans-serif;color:#20251f;background:#f7f6f0}*{box-sizing:border-box}body{margin:0}.brand{height:94px;display:flex;align-items:center;gap:9px;padding:0 6vw;color:inherit;font-weight:800;font-size:20px;text-decoration:none}.brand img{width:43px;height:43px;object-fit:contain}.hero{min-height:700px;margin:0 2vw;position:relative;overflow:hidden;border-radius:30px;background:#183a2c;color:#fff}.hero>img{width:100%;height:100%;position:absolute;inset:0;object-fit:cover}.hero:after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,#16372a 0%,rgba(22,55,42,.9) 34%,rgba(22,55,42,.13) 68%)}.hero-copy{position:relative;z-index:1;padding:clamp(58px,8vw,130px);max-width:765px}.hero p,.proof>p,.formats p,.support p,.road>p,.form>div p{margin:0;text-transform:uppercase;letter-spacing:.15em;font-size:11px;font-weight:800;color:#b5db39}.hero h1,.proof h2,.formats h2,.support h2,.form h2{margin:20px 0;font-size:clamp(60px,6.8vw,116px);line-height:.84;letter-spacing:-.095em}.hero-copy>span{max-width:435px;display:block;font-size:16px;line-height:1.55}.hero a{margin-top:32px;display:inline-flex;gap:31px;padding:18px 21px;border-radius:100px;background:#b6dc3a;color:#1b301f;text-decoration:none;font-size:13px;font-weight:800}.hero .mark{position:absolute;z-index:2;right:6vw;bottom:52px;font-size:clamp(45px,7vw,100px);line-height:.72;text-align:right;font-weight:800;letter-spacing:-.12em}.mark em{font-family:'21Cent',cursive;font-size:.42em;font-weight:400;letter-spacing:0}.proof{padding:clamp(100px,13vw,200px) 7vw}.proof h2{font-size:clamp(49px,5.8vw,94px);max-width:900px}.numbers{margin-top:65px;display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid #cbd1c7}.numbers article{padding:23px 20px 0 0;display:flex;gap:19px;border-right:1px solid #cbd1c7}.numbers article+article{padding-left:25px}.numbers b{font-size:clamp(46px,5vw,76px);line-height:.8;color:#779b24;letter-spacing:-.1em}.numbers span{font-size:13px;line-height:1.45}.formats{padding:0 2vw 2vw;display:grid;grid-template-columns:.78fr 1.22fr;gap:18px}.formats-heading{border-radius:28px;background:#e2ead8;padding:clamp(38px,5vw,75px)}.formats h2{font-size:clamp(43px,4.5vw,74px)}.format-list{display:grid;grid-template-columns:1fr 1fr;gap:12px}.format-list article{min-height:275px;padding:24px;position:relative;border-radius:24px;background:#e8e5dc}.format-list article:nth-child(2){background:#dbe8ca}.format-list article:nth-child(3){background:#c9ddd1}.format-list article:nth-child(4){background:#dfd8ca}.format-list b{font-size:12px;color:#729723}.format-list h3{margin:67px 0 8px;font-size:28px;line-height:.96;letter-spacing:-.075em}.format-list strong{font-size:12px}.format-list article p{margin-top:17px;max-width:260px;text-transform:none;letter-spacing:0;font-size:12px;line-height:1.55;color:#4a5149}.format-list a{position:absolute;right:20px;bottom:18px;color:#25392b;font-size:25px;text-decoration:none}.support{margin:0 2vw;padding:clamp(55px,7vw,105px);border-radius:28px;background:#213c30;color:#fff;display:grid;grid-template-columns:1fr 1fr;gap:80px}.support h2{font-size:clamp(50px,5vw,86px)}.support ul{align-self:end;margin:0;padding:0;list-style:none}.support li{padding:17px 0;border-top:1px solid rgba(255,255,255,.28);font-size:18px;font-weight:600}.support li:before{content:'↗';color:#bbdf3a;margin-right:16px}.road{padding:clamp(90px,11vw,160px) 7vw}.road>div{display:grid;grid-template-columns:repeat(4,1fr);margin-top:38px}.road article{min-height:130px;border-top:1px solid #bdc5b9;padding:17px 16px 0 0}.road article+article{padding-left:18px}.road b{font-size:12px;color:#719626;display:block}.road span{display:block;margin-top:50px;font-size:19px;font-weight:700;letter-spacing:-.04em}.form{margin:0 2vw 2vw;padding:clamp(50px,7vw,110px);border-radius:28px;background:#d8e6ce;display:grid;grid-template-columns:.9fr 1.1fr;gap:85px}.form h2{font-size:clamp(48px,5vw,82px)}.form>div span{display:block;max-width:310px;font-size:13px;line-height:1.6}.form form{display:grid;grid-template-columns:1fr 1fr;gap:12px;align-content:center}.form label{font-size:11px;font-weight:700}.form input{display:block;width:100%;margin-top:7px;border:0;border-radius:10px;padding:16px;background:#fff;font:13px Montserrat}.form button{grid-column:1/-1;margin-top:14px;padding:18px 20px;display:flex;justify-content:space-between;border:0;border-radius:100px;background:#1d392c;color:#fff;font:700 13px Montserrat;text-align:left}.form small{grid-column:1/-1;font-size:10px;line-height:1.45;color:#566155}@media(max-width:700px){.brand{height:72px;padding:0 20px}.hero{min-height:640px;margin:0;border-radius:0}.hero:after{background:linear-gradient(90deg,rgba(18,51,38,.94),rgba(18,51,38,.32))}.hero-copy{padding:58px 20px}.hero h1{font-size:62px}.hero-copy>span{font-size:14px}.hero .mark{right:20px;bottom:39px;font-size:65px}.proof{padding:88px 20px}.proof h2{font-size:52px}.numbers{gap:0;margin-top:43px}.numbers article{display:block;padding-right:8px}.numbers article+article{padding-left:10px}.numbers b{font-size:47px}.numbers span{margin-top:8px;display:block;font-size:10px}.formats{padding:0;display:block}.formats-heading{border-radius:0;padding:66px 20px}.formats h2{font-size:52px}.format-list{padding:8px;gap:8px}.format-list article{min-height:245px;padding:18px;border-radius:19px}.format-list h3{margin-top:55px;font-size:22px}.format-list article p{font-size:10px}.support{margin:50px 0 0;padding:64px 20px;border-radius:0;display:block}.support h2{font-size:57px}.support ul{margin-top:46px}.support li{font-size:15px}.road{padding:83px 20px}.road>div{grid-template-columns:1fr 1fr}.road article{min-height:120px}.road article+article{padding-left:10px}.road span{font-size:15px;margin-top:39px}.form{margin:0;border-radius:0;padding:64px 20px;display:block}.form h2{font-size:57px}.form form{margin-top:42px;grid-template-columns:1fr}.form small{font-size:10px}}
</style>
