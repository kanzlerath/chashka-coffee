---
import PageShell from '../layouts/PageShell.astro';
type ArticleRow = [string, string, string, string]
let articles: ArticleRow[] = [['coffee-morning','Кофе для первого тёплого утра','Гид · 5 минут','Как выбрать напиток, который не спорит с вашим настроением.'],['croissant-now','Почему круассан лучше есть сразу','Еда · 3 минуты','Немного масла, много слоёв и один простой совет от кондитера.'],['novosibirsk-route','Маршрут выходного дня по Новосибирску','Город · 7 минут','Парки, набережная и кофейни, в которых удобно сделать паузу.'],['after-roasting','Что происходит с зерном после обжарки','Кофе · 6 минут','Разбираемся без сложных слов — только вкус и любопытство.']]
try { const response = await fetch(`${import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'}/api/content?type=ARTICLE`); if (response.ok) { const data = await response.json(); articles = data.entries.map((entry: any): ArticleRow => [entry.slug, entry.title, 'Журнал · читать', entry.excerpt ?? 'Открывайте историю целиком на странице материала.']) } } catch { /* editorial fallback remains available */ }
---
<PageShell title="Журнал" active="journal"><section class="hero"><p>журнал чашка кофе</p><h1>О кофе,<br/>городе<br/>и людях</h1><span>Небольшие истории для тех, кто любит знать, что у него в чашке и что происходит вокруг.</span><b>читать<br/><i>медленнее</i></b></section><section class="lead"><div><p>выбор редакции</p><h2>Хороший кофе —<br/>это всегда<br/>про внимание.</h2><span>К зерну, человеку за стойкой, гостю напротив и времени, которое вы решили оставить себе.</span><a href="#articles">Читать историю →</a></div><img src="/images/home-hero-v1.png" alt="Кофе и выпечка"/></section><section id="articles" class="articles"><p>все материалы</p><div>{articles.map(([slug,title,meta,copy],index)=><article><b>0{index+1}</b><p>{meta}</p><h3>{title}</h3><span>{copy}</span><a href={`/journal/${slug}`}>Читать <i>→</i></a></article>)}</div></section></PageShell>
<style>@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap');:root{font-family:Montserrat,Arial,sans-serif;color:#20251f;background:#f8f7f2}*{box-sizing:border-box}body{margin:0}.brand{height:94px;padding:0 6vw;display:flex;align-items:center;gap:9px;color:inherit;text-decoration:none;font-size:20px;font-weight:800}.brand img{width:43px;height:43px;object-fit:contain}.hero{position:relative;min-height:570px;margin:0 2vw;padding:clamp(60px,8vw,125px);overflow:hidden;border-radius:30px;background:#dbe9d0}.hero>p,.lead p,.articles>p{margin:0;color:#6f9024;text-transform:uppercase;letter-spacing:.15em;font-size:11px;font-weight:800}.hero h1,.lead h2{margin:20px 0;font-size:clamp(62px,7vw,116px);line-height:.83;letter-spacing:-.1em}.hero span{display:block;max-width:420px;font-size:16px;line-height:1.6}.hero>b{position:absolute;right:7vw;bottom:45px;color:#203c2e;font-size:clamp(70px,9vw,145px);line-height:.7;letter-spacing:-.12em;text-align:right}.hero i{font-family:'21Cent',cursive;font-size:.35em;letter-spacing:0;font-weight:400}.lead{display:grid;grid-template-columns:1fr 1fr;margin:clamp(70px,10vw,150px) 2vw 0;overflow:hidden;border-radius:29px;background:#e8e4d9}.lead>div{padding:clamp(45px,6vw,105px)}.lead h2{font-size:clamp(49px,5vw,84px)}.lead span{display:block;max-width:350px;font-size:13px;line-height:1.65}.lead a{display:inline-block;margin-top:28px;padding:18px 20px;border-radius:99px;background:#203c2e;color:#fff;text-decoration:none;font-size:12px;font-weight:700}.lead img{width:100%;height:100%;min-height:480px;object-fit:cover}.articles{padding:clamp(100px,12vw,180px) 7vw}.articles>div{display:grid;grid-template-columns:repeat(2,1fr);gap:11px;margin-top:37px}.articles article{position:relative;min-height:330px;padding:25px;border-radius:25px;background:#edf0e8}.articles article:nth-child(2){background:#e7e0d4}.articles article:nth-child(3){background:#d4e5cd}.articles article:nth-child(4){background:#d3ded5}.articles b{font-size:12px;color:#739724}.articles article p{margin:77px 0 9px;color:#6f7b38;text-transform:uppercase;letter-spacing:.1em;font-size:10px;font-weight:700}.articles h3{max-width:375px;margin:0;font-size:30px;line-height:.97;letter-spacing:-.075em}.articles span{display:block;max-width:350px;margin-top:15px;font-size:12px;line-height:1.65}.articles a{position:absolute;left:25px;bottom:23px;color:inherit;font-size:11px;font-weight:700;text-decoration:none}.articles i{font-style:normal;margin-left:14px}@media(max-width:700px){.brand{height:72px;padding:0 20px}.hero{margin:0;min-height:570px;padding:58px 20px;border-radius:0}.hero h1{font-size:64px}.hero span{font-size:14px}.hero>b{right:20px;bottom:38px;font-size:73px}.lead{display:block;margin:0;border-radius:0}.lead>div{padding:65px 20px}.lead h2{font-size:53px}.lead img{min-height:330px}.articles{padding:86px 20px}.articles>div{grid-template-columns:1fr;gap:8px}.articles article{min-height:300px;padding:21px;border-radius:19px}.articles article p{margin-top:65px}.articles h3{font-size:27px}.articles a{left:21px;bottom:19px}}</style>
