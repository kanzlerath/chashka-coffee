---
const jobs = [
  ['Бариста', 'Рестораны в центре', 'от 45 000 ₽', 'Готовить кофе, улыбаться гостям и знать любимый десерт постоянных гостей.'],
  ['Менеджер зала', 'Красный проспект', 'от 55 000 ₽', 'Собирать спокойную смену и делать так, чтобы гостям хотелось задержаться.'],
  ['Кондитер', 'Производство', 'по итогам встречи', 'Работать со свежей выпечкой и превращать простые ингредиенты в повод зайти.'],
];
---
<html lang="ru"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><meta name="description" content="Вакансии сети Чашка кофе в Новосибирске."/><title>Вакансии — Чашка кофе</title></head><body><main>
<a class="brand" href="/"><img src="/brand/logo.png" alt="Логотип Чашка кофе"/>Чашка кофе</a>
<section class="hero"><img src="/images/home-hero-v1.png" alt="Кофе и свежая выпечка"/><div><p>команда чашка кофе</p><h1>Работа,<br/>в которой<br/>есть вкус</h1><span>Мы ищем внимательных людей: тех, кому важны команда, гости и хорошо приготовленный кофе.</span><a href="#vacancies">Смотреть вакансии ↓</a></div></section>
<section class="intro"><p>люди делают место</p><h2>Каждая смена —<br/>это чей-то хороший день.</h2><span>Учим с нуля, поддерживаем в начале и даём расти тем, кто хочет быть больше, чем просто должность.</span></section>
<section class="values"><article><b>01</b><h3>Без лишней<br/>иерархии</h3><p>Мы разговариваем друг с другом прямо и уважительно.</p></article><article><b>02</b><h3>С заботой<br/>о госте</h3><p>Качество — в деталях: от первого «доброе утро» до последней крошки.</p></article><article><b>03</b><h3>Можно<br/>расти</h3><p>Бариста становится тренером, менеджер — управляющим, если ему это интересно.</p></article></section>
<section id="vacancies" class="vacancies"><div class="heading"><p>открытые позиции</p><h2>Найдите<br/>свою чашку</h2><span>Нет подходящей роли? Всё равно напишите нам — хорошие люди нужны всегда.</span></div><div class="job-list">{jobs.map(([title,place,pay,copy])=><article><div><p>{place}</p><h3>{title}</h3><strong>{pay}</strong><span>{copy}</span></div><a href="#form">Откликнуться <b>→</b></a></article>)}</div></section>
<section class="strip"><p>Чашка кофе</p><span>вместо слова «работа» — место, где тебя знают по имени</span><i>★</i></section>
<section id="form" class="form"><div><p>стать частью команды</p><h2>Расскажите<br/>о себе</h2><span>Мы прочитаем каждое сообщение и ответим, если найдём подходящее совпадение.</span></div><form><label>Ваше имя<input placeholder="Как к вам обращаться"/></label><label>Телефон<input type="tel" placeholder="+7"/></label><label class="wide">Какая вакансия интересна?<input placeholder="Например, бариста"/></label><button type="button">Отправить отклик <b>→</b></button><small>Нажимая кнопку, вы соглашаетесь с обработкой персональных данных.</small></form></section>
</main></body></html>
<style>@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap');:root{font-family:Montserrat,Arial,sans-serif;color:#20251f;background:#f7f6f0}*{box-sizing:border-box}body{margin:0}.brand{height:94px;padding:0 6vw;display:flex;align-items:center;gap:9px;color:inherit;text-decoration:none;font-size:20px;font-weight:800}.brand img{width:43px;height:43px;object-fit:contain}.hero{position:relative;overflow:hidden;min-height:670px;margin:0 2vw;border-radius:30px;color:#fff;background:#273d2d}.hero>img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}.hero:after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,#1c3b2d 0%,rgba(28,59,45,.86) 36%,transparent 70%)}.hero>div{position:relative;z-index:1;padding:clamp(58px,8vw,125px);max-width:760px}.hero p,.intro>p,.heading>p,.form p{margin:0;color:#b8dc3d;text-transform:uppercase;letter-spacing:.15em;font-size:11px;font-weight:800}.hero h1,.intro h2,.heading h2,.form h2{margin:20px 0;font-size:clamp(62px,7vw,118px);line-height:.83;letter-spacing:-.1em}.hero span{max-width:420px;display:block;font-size:16px;line-height:1.55}.hero a{display:inline-block;margin-top:31px;padding:18px 22px;border-radius:99px;background:#b8dc3d;color:#1d3326;text-decoration:none;font-size:13px;font-weight:800}.intro{padding:clamp(95px,12vw,180px) 7vw;display:grid;grid-template-columns:1.2fr .8fr;gap:70px}.intro h2{grid-column:1;font-size:clamp(50px,5.7vw,95px)}.intro>span{align-self:end;margin-bottom:24px;max-width:320px;line-height:1.6;font-size:14px}.values{margin:0 2vw;display:grid;grid-template-columns:repeat(3,1fr);gap:12px}.values article{min-height:330px;border-radius:26px;padding:28px;background:#dcebd2}.values article:nth-child(2){background:#e7e2d9}.values article:nth-child(3){background:#c7ddd0}.values b{font-size:12px;color:#759a24}.values h3{margin:100px 0 14px;font-size:31px;line-height:.92;letter-spacing:-.08em}.values p{max-width:250px;margin:0;font-size:12px;line-height:1.6}.vacancies{padding:clamp(100px,12vw,180px) 7vw;display:grid;grid-template-columns:.72fr 1.28fr;gap:80px}.heading h2{font-size:clamp(47px,5vw,84px)}.heading span{max-width:275px;display:block;font-size:13px;line-height:1.6}.job-list{display:grid;gap:11px}.job-list article{padding:27px 0;border-top:1px solid #c8cfc4;display:flex;justify-content:space-between;gap:25px}.job-list article:last-child{border-bottom:1px solid #c8cfc4}.job-list p{margin:0;color:#769623;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.09em}.job-list h3{margin:10px 0 8px;font-size:30px;letter-spacing:-.075em}.job-list strong{font-size:12px}.job-list span{display:block;max-width:465px;margin-top:16px;font-size:12px;line-height:1.6}.job-list a{align-self:center;white-space:nowrap;padding:15px 17px;border:1px solid #859183;border-radius:99px;color:inherit;text-decoration:none;font-size:12px;font-weight:700}.job-list a b{margin-left:20px}.strip{margin:0 2vw;padding:38px clamp(20px,5vw,80px);display:flex;align-items:center;gap:40px;border-radius:27px;background:#203c2e;color:#fff}.strip p{margin:0;font-family:'21Cent',cursive;font-size:49px;line-height:.8}.strip span{font-size:18px;font-weight:600}.strip i{margin-left:auto;color:#b7da3d;font-size:31px}.form{margin:clamp(70px,10vw,150px) 2vw 2vw;padding:clamp(52px,7vw,108px);display:grid;grid-template-columns:.9fr 1.1fr;gap:85px;border-radius:28px;background:#e8e4d9}.form h2{font-size:clamp(49px,5vw,82px)}.form>div>span{display:block;max-width:300px;font-size:13px;line-height:1.6}.form form{display:grid;grid-template-columns:1fr 1fr;gap:12px;align-content:center}.form label{font-size:11px;font-weight:700}.form label.wide{grid-column:1/-1}.form input{width:100%;display:block;margin-top:7px;padding:16px;border:0;border-radius:10px;background:#fff;font:13px Montserrat}.form button{grid-column:1/-1;margin-top:12px;padding:18px 20px;border:0;border-radius:99px;background:#203c2e;color:#fff;text-align:left;font:700 13px Montserrat;display:flex;justify-content:space-between}.form small{font-size:10px;line-height:1.5;color:#62655f}@media(max-width:700px){.brand{height:72px;padding:0 20px}.hero{min-height:640px;margin:0;border-radius:0}.hero:after{background:linear-gradient(90deg,rgba(20,53,39,.93),rgba(20,53,39,.32))}.hero>div{padding:58px 20px}.hero h1{font-size:63px}.hero span{font-size:14px}.intro{padding:85px 20px;display:block}.intro h2{font-size:53px}.intro>span{margin-top:26px}.values{margin:0;grid-template-columns:1fr;gap:8px}.values article{border-radius:0;min-height:260px;padding:24px}.values h3{margin-top:74px;font-size:30px}.vacancies{padding:85px 20px;display:block}.heading h2{font-size:54px}.job-list{margin-top:52px}.job-list article{display:block;padding:25px 0}.job-list h3{font-size:27px}.job-list a{display:flex;justify-content:space-between;margin-top:21px}.strip{margin:0;border-radius:0;display:block;padding:42px 20px}.strip p{font-size:44px}.strip span{display:block;margin-top:20px;font-size:16px}.strip i{display:block;margin-top:22px}.form{margin:0;border-radius:0;padding:64px 20px;display:block}.form h2{font-size:57px}.form form{margin-top:42px;grid-template-columns:1fr}.form small{font-size:10px}}</style>
