---
import PageShell from '../layouts/PageShell.astro';
const steps=['Выберите ресторан и блюда в приложении','Укажите доставку или самовывоз','Оплатите заказ и ждите любимое'];
---
<PageShell title="Доставка" description="Заказывайте доставку и самовывоз из Чашки кофе через приложение." active="delivery"><section class="hero"><div><p>Любимое — ближе</p><h1>Доставка<br/>из ресторана</h1><span>Заказывайте любимые блюда и кофе через приложение. Быстро, бережно и без лишних шагов.</span><a href="/app">Заказать в приложении →</a></div><b>ЧК<i>☕</i></b></section><section class="steps"><div><p>Как это работает</p><h2>Всё просто</h2></div><ol>{steps.map((step,index)=><li><b>0{index+1}</b><span>{step}</span><i>→</i></li>)}</ol></section><section class="alternatives"><article><p>В приложении</p><h2>Доставка<br/>и самовывоз</h2><span>Меню, бонусы и привычные рестораны — всё в одном месте.</span><a href="/app">Открыть приложение →</a></article><article><p>Через сервис</p><h2>Яндекс Еда</h2><span>Если так удобнее — переходите к заказу в сервисе доставки.</span><a href="https://eda.yandex.ru/" target="_blank" rel="noreferrer">Перейти в Яндекс Еду ↗</a></article></section></PageShell>
<style>.hero{min-height:620px;margin:0 2vw;padding:clamp(56px,8vw,130px);border-radius:29px;background:#20382b;color:#fff;display:grid;grid-template-columns:1fr 1fr;align-items:center}.hero p,.steps p,.alternatives p{margin:0;color:#b9dc3d;text-transform:uppercase;letter-spacing:.14em;font-size:11px;font-weight:800}.hero h1,.steps h2,.alternatives h2{margin:20px 0;font-size:clamp(57px,6vw,106px);line-height:.84;letter-spacing:-.1em}.hero span{display:block;max-width:420px;font-size:16px;line-height:1.6;color:#d8e2d7}.hero a,.alternatives a{display:inline-block;margin-top:30px;padding:17px 20px;border-radius:99px;background:#f8f7f2;color:#20382b;text-decoration:none;font-size:12px;font-weight:800}.hero>b{justify-self:center;width:290px;height:350px;padding:92px 42px;border-radius:34px 34px 18px 18px;background:#b9dc3d;color:#20382b;font-size:83px;line-height:.78;letter-spacing:-.18em;transform:rotate(7deg);box-shadow:19px 23px 0 rgba(0,0,0,.12)}.hero>b i{display:block;margin:44px auto 0;width:110px;aspect-ratio:1;border-radius:50%;background:#f8f7f2;text-align:center;padding-top:25px;font-style:normal;font-size:53px}.steps{padding:clamp(90px,11vw,160px) 7vw;display:grid;grid-template-columns:.75fr 1.25fr;gap:70px}.steps h2{font-size:clamp(51px,5vw,87px)}ol{margin:0;padding:0;list-style:none;border-top:1px solid #ccd2c8}li{display:grid;grid-template-columns:80px 1fr auto;gap:18px;align-items:center;padding:27px 0;border-bottom:1px solid #ccd2c8}li b{font-size:12px;color:#7b9d29}li span{font-size:22px;font-weight:700;letter-spacing:-.05em}li i{font-style:normal;font-size:23px}.alternatives{margin:0 2vw;display:grid;grid-template-columns:1fr 1fr;gap:12px}.alternatives article{min-height:390px;padding:clamp(43px,6vw,92px);border-radius:26px;background:#dfe8d4}.alternatives article+article{background:#eee5da}.alternatives article+article p{color:#9d7447}.alternatives h2{font-size:clamp(44px,4.5vw,77px)}.alternatives span{display:block;max-width:330px;font-size:14px;line-height:1.65}.alternatives article+article a{border:1px solid #bfc8bf;background:transparent}@media(max-width:700px){.hero{margin:0;min-height:690px;padding:57px 20px 0;display:block;border-radius:0}.hero h1{font-size:58px}.hero span{font-size:14px}.hero>b{display:block;width:230px;height:280px;margin:54px auto -42px;padding:75px 34px;font-size:67px}.hero>b i{width:87px;margin-top:31px;padding-top:19px;font-size:42px}.steps{display:block;padding:85px 20px}.steps h2{font-size:53px}.steps ol{margin-top:34px}li{grid-template-columns:45px 1fr auto;padding:22px 0}li span{font-size:18px}.alternatives{margin:0;display:block}.alternatives article{min-height:350px;margin-bottom:8px;padding:52px 20px;border-radius:0}.alternatives h2{font-size:51px}}</style>
