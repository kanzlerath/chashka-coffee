---
import PageShell from '../layouts/PageShell.astro';
import LeadForm from '../components/LeadForm.astro';
const contacts=[['Центральный офис','+73831232020','hello@chashkacoffee.ru'],['Банкеты и события','+73831232020','events@chashkacoffee.ru'],['Кондитерская','+73831232020','cake@chashkacoffee.ru'],['Корпоративным клиентам','+73831232020','business@chashkacoffee.ru'],['Франшиза','+73831232020','franchise@chashkacoffee.ru'],['Вакансии','+73831232020','team@chashkacoffee.ru']];
---
<PageShell title="Контакты" active="about"><section class="hero"><p>Всегда на связи</p><h1>Давайте<br/>найдёмся</h1><span>Выберите подходящее направление — ответим и поможем.</span></section><section class="grid">{contacts.map(([title,phone,email],i)=><article><b>0{i+1}</b><h2>{title}</h2><a href={`tel:${phone}`}>{phone}</a><a href={`mailto:${email}`}>{email}</a><small>Пн–Пт · 09:00–18:00</small></article>)}</section><section class="contact-form"><div><p>Напишите нам</p><h2>Оставьте<br/>сообщение</h2><span>Если вопрос не срочный, команда ответит по указанным контактам.</span></div><LeadForm type="CONTACT" submitLabel="Отправить сообщение" subjectLabel="Тема обращения" /></section></PageShell>
<style>.hero{min-height:440px;margin:0 2vw;padding:clamp(60px,8vw,130px);border-radius:29px;background:#dcebd1}.hero p,.contact-form>div>p{margin:0;color:#739728;text-transform:uppercase;letter-spacing:.15em;font-size:11px;font-weight:800}.hero h1,.contact-form h2{margin:20px 0;font-size:clamp(62px,7vw,118px);line-height:.83;letter-spacing:-.1em}.hero span,.contact-form>div>span{display:block;max-width:390px;font-size:15px;line-height:1.65}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;padding:clamp(80px,10vw,145px) 7vw}.grid article{min-height:250px;padding:25px;border-radius:24px;background:#edf0e8;display:flex;flex-direction:column;align-items:flex-start}.grid article:nth-child(2n){background:#e9e3d8}.grid b{font-size:12px;color:#769a27}.grid h2{margin:58px 0 18px;font-size:25px;line-height:.96;letter-spacing:-.06em}.grid a{color:#203c2e;text-decoration:none;font-size:12px;font-weight:600;line-height:1.8}.grid small{margin-top:auto;font-size:10px;color:#687068}.contact-form{margin:0 2vw;padding:clamp(48px,7vw,100px);border-radius:29px;background:#20382b;color:#fff;display:grid;grid-template-columns:.8fr 1.2fr;gap:70px}.contact-form>div>p{color:#b9dc3d}.contact-form h2{font-size:clamp(47px,5vw,80px)}.contact-form>div>span{color:#d8e0d9}@media(max-width:700px){.hero{margin:0;padding:63px 20px;border-radius:0}.hero h1{font-size:61px}.grid{grid-template-columns:1fr;padding:8px;gap:8px}.grid article{min-height:220px;border-radius:19px;padding:21px}.grid h2{margin-top:48px}.contact-form{margin:0;border-radius:0;display:block;padding:58px 20px}.contact-form h2{font-size:52px}.contact-form form{margin-top:35px}}</style>
