const contacts=[['Центральный офис','+7 (383) 123-20-20','hello@chashkacoffee.ru'],['Вакансии','+7 (383) 123-20-21','hr@chashkacoffee.ru'],['Франшиза','+7 (383) 123-20-22','franchise@chashkacoffee.ru'],['Банкеты','+7 (383) 123-20-23','banquet@chashkacoffee.ru'],['Кондитерская','+7 (383) 123-20-24','cake@chashkacoffee.ru'],['Партнёрства','+7 (383) 123-20-25','partner@chashkacoffee.ru']]
---
<html lang="ru"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><title>Контакты — Чашка кофе</title></head><body><main><a class="brand" href="/"><img src="/brand/logo.png" alt=""/>Чашка кофе</a><section class="hero"><p>всегда на связи</p><h1>Давайте<br/>найдёмся</h1><span>Выберите подходящее направление — ответим и поможем.</span></section><section class="grid">{contacts.map(([title,phone,email],i)=><article><b>0{i+1}</b><h2>{title}</h2><a href={`tel:${phone}`}>{phone}</a><a href={`mailto:${email}`}>{email}</a><small>Пн–Пт · 09:00–18:00</small></article>)}</section></main></body></html>
<style>@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap');:root{font-family:Montserrat,Arial,sans-serif;color:#1b211d;background:#f8f7f2}*{box-sizing:border-box}body{margin:0}.brand{height:94px;padding:0 6vw;display:flex;align-items:center;gap:10px;font-size:20px;font-weight:800;text-decoration:none;color:inherit}.brand img{width:45px;height:45px;object-fit:contain}.hero{margin:0 2vw;padding:clamp(55px,8vw,130px);min-height:460px;border-radius:27px;background:#e7ecdc url('/images/home-hero-v1.png') right center/58% auto no-repeat}.hero p{font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:700;color:#8ba925}.hero h1{margin:18px 0;font-size:clamp(58px,6vw,106px);line-height:.84;letter-spacing:-.1em}.hero span{display:block;max-width:410px;font-size:16px;line-height:1.55}.grid{padding:clamp(75px,9vw,140px) 7vw;display:grid;grid-template-columns:repeat(3,1fr);gap:13px}.grid article{min-height:260px;padding:25px;border:1px solid #dde2d9;border-radius:22px;display:flex;flex-direction:column}.grid b{font-size:12px;color:#8eae26}.grid h2{margin:54px 0 20px;font-size:26px;line-height:.94;letter-spacing:-.06em}.grid a{font-size:13px;color:#405d47;text-decoration:none;margin-top:7px}.grid small{margin-top:auto;padding-top:20px;font-size:11px;color:#727a72}@media(max-width:700px){.brand{height:72px;padding:0 20px}.hero{margin:0;min-height:470px;border-radius:0;padding:50px 20px;background-size:auto 44%;background-position:right bottom}.hero h1{font-size:62px}.hero span{font-size:15px;max-width:300px}.grid{padding:72px 20px;grid-template-columns:1fr;gap:8px}.grid article{min-height:210px;padding:20px}.grid h2{margin-top:35px}}</style>
