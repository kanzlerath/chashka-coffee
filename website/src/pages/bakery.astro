<html lang="ru"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><title>Кондитерская — Чашка кофе</title></head><body><div class="shell"><header><a class="brand" href="/"><img src="/brand/logo.png" alt="" width="44" height="44"/><span>Чашка<br/>кофе</span></a><nav><a href="/restaurants">Рестораны</a><a href="/restaurants/krasny-prospekt/menu">Меню</a><a href="/coffee">Кофе</a><a class="active" href="/bakery">Кондитерская</a></nav><a class="top" href="/app">В приложение ↗</a></header><main><section class="hero"><div><p class="eyebrow">кондитерская чашки кофе</p><h1>Повод<br/>для сладкого<br/>настроения</h1><p>Десерты на каждый день, торты к особому случаю и много маленьких радостей.</p><a class="button" href="#ready">Выбрать десерт <span>→</span></a></div><img src="/images/home-hero-v1.png" alt="Свежая выпечка и кофе"/></section><section id="ready" class="ready"><div><p class="eyebrow">готовая продукция</p><h2>Сегодня<br/>хочется это</h2></div><div class="grid">{desserts.map(([name,label,price],i)=><article><span>{label}</span><i>{i%2?'◒':'✦'}</i><h3>{name}</h3><p>{price}</p><a href="/app">В приложение ↗</a></article>)}</div></section><section class="custom"><div><p class="eyebrow">индивидуальный заказ</p><h2>Торт<br/>для вашего дня</h2><p>Расскажите о празднике, а мы подберём вкус, оформление и формат. Стоимость рассчитывается индивидуально.</p><a class="button" href="/contacts">Оставить заявку <span>→</span></a></div><div class="cake" aria-hidden="true"><b>ЧК</b><i>✦</i></div></section></main><footer><div class="footer-brand"><img src="/brand/logo.png" alt="" width="58" height="58"/><span>Чашка<br/>кофе</span></div><p>Ваше место<br/>для хорошего дня.</p><a href="/contacts">Контакты</a><span>© 2026 Чашка кофе</span></footer></div></body></html>
<style>
@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap');:root{font-family:Montserrat,Arial,sans-serif;color:#1b201b;background:#eaebe5}*{box-sizing:border-box}body{margin:0;padding:14px;background:#eaebe5}a{color:inherit;text-decoration:none}.shell{max-width:1680px;margin:auto;overflow:hidden;border-radius:30px;background:#fdfcf8;box-shadow:0 14px 55px rgba(34,40,29,.08)}header{height:104px;padding:0 clamp(34px,4vw,72px);display:flex;align-items:center;gap:34px}.brand,.footer-brand{display:flex;align-items:center;gap:10px;font-size:22px;font-weight:800;line-height:.86;letter-spacing:-.075em}header nav{display:flex;gap:34px;margin:auto}header nav a{font-size:14px;font-weight:600}header nav .active{padding-bottom:7px;border-bottom:2px solid #9bbe2b}.top,.button{padding:15px 21px;border-radius:999px;background:#202d24;color:#fff;font-size:14px;font-weight:700}.hero{margin:0 14px;min-height:620px;border-radius:25px;overflow:hidden;display:grid;grid-template-columns:.9fr 1.1fr;background:#efe4db}.hero>div{padding:clamp(52px,7vw,112px)}.eyebrow{margin:0 0 14px;color:#8baa27;text-transform:uppercase;letter-spacing:.14em;font-size:11px;font-weight:700}.hero h1,.ready h2,.custom h2{margin:0;font-size:clamp(57px,6vw,105px);line-height:.84;letter-spacing:-.1em}.hero p:not(.eyebrow),.custom p:not(.eyebrow){max-width:400px;margin:26px 0;font-size:17px;line-height:1.55;color:#5d615a}.button{display:inline-flex;gap:27px;align-items:center}.hero img{width:100%;height:100%;object-fit:cover}.ready{padding:clamp(100px,11vw,170px) clamp(34px,6.5vw,108px)}.ready h2{font-size:clamp(52px,5vw,90px)}.grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:60px}.grid article{min-height:310px;padding:24px;border-radius:23px;background:#f0ebe3;position:relative}.grid article:nth-child(2){background:#dfebcb}.grid article:nth-child(3){background:#e8dfcf}.grid article:nth-child(4){background:#dfe9df}.grid span{font-size:11px;color:#7a842e;font-weight:700}.grid i{position:absolute;right:22px;top:20px;font-size:67px;color:#d49869;font-style:normal}.grid h3{margin:100px 0 9px;font-size:25px;line-height:.93;letter-spacing:-.07em}.grid p{margin:0;font-size:16px;font-weight:700}.grid a{display:block;margin-top:32px;font-size:11px;font-weight:700}.custom{margin:0 14px 14px;padding:clamp(52px,7vw,112px);min-height:490px;border-radius:25px;background:#20372b;color:#fff;display:grid;grid-template-columns:1fr 1fr;align-items:center}.custom .eyebrow{color:#b8d93c}.custom h2{font-size:clamp(48px,5vw,84px)}.custom p:not(.eyebrow){color:#d8e0d5}.cake{justify-self:center;width:280px;aspect-ratio:1;border-radius:50% 50% 17% 17%;background:#f8f2e8;color:#20372b;display:grid;place-items:center;font-size:84px;font-weight:800;letter-spacing:-.15em;box-shadow:0 36px 0 #b5d83d}.cake i{position:absolute;font-size:55px;color:#b5d83d}footer{padding:70px clamp(34px,6.5vw,105px) 22px;background:#202d24;color:#fff;display:grid;grid-template-columns:1fr 1.2fr 1fr;gap:35px}.footer-brand{font-size:25px}.footer-brand+p{margin:0;font-size:clamp(28px,3vw,43px);line-height:.93;font-weight:700;letter-spacing:-.07em}footer a,footer>span{font-size:12px;color:#d1d9d0}footer>span{grid-column:1/-1;padding-top:20px;border-top:1px solid rgba(255,255,255,.16)}@media(max-width:840px){body{padding:0;background:#fdfcf8}.shell{border-radius:0;box-shadow:none}header{height:72px;padding:0 20px}.brand{font-size:18px}.brand img{width:39px;height:39px}header nav,.top{display:none}.hero{margin:0;display:block;border-radius:0}.hero>div{padding:55px 20px}.hero h1{font-size:57px}.hero p:not(.eyebrow),.custom p:not(.eyebrow){font-size:15px}.hero img{height:310px;display:block}.ready{padding:84px 20px}.ready h2{font-size:52px}.grid{grid-template-columns:1fr 1fr;gap:8px;margin-top:35px}.grid article{min-height:230px;padding:18px}.grid i{font-size:48px}.grid h3{margin-top:66px;font-size:22px}.custom{margin:0 12px 12px;padding:48px 25px 0;display:block;min-height:620px;border-radius:22px}.custom h2{font-size:50px}.cake{width:210px;margin:60px auto -25px;font-size:62px}footer{padding:46px 20px 20px;display:block}.footer-brand+p{margin:30px 0}footer>span{display:block;margin-top:30px}}
