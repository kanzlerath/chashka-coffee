---
import PageShell from '../layouts/PageShell.astro';
const offers = [
  ['summer-breakfasts', 'Летние завтраки', 'До 12:00 по будням', 'Когда утро хочется начать не на бегу: любимые блюда и кофе по специальной цене.', '−20%'],
  ['coffee-to-go', 'Кофе с собой', 'Каждый день', 'Второй напиток для прогулки, дороги или человека, с которым хочется задержаться.', '2-й за 99 ₽'],
  ['dessert-cappuccino', 'Десерт к капучино', 'До конца месяца', 'Выбирайте любимый десерт — мы добавим к напитку немного сладкого настроения.', 'от 190 ₽'],
];
---
<PageShell title="Акции" active="promotions"><section class="hero"><img src="/images/home-hero-v1.png" alt="Кофе и выпечка"/><div><p>сегодня в чашке кофе</p><h1>Маленькие<br/>поводы<br/>зайти</h1><span>Собрали предложения, которые делают обычный день чуть вкуснее.</span><a href="#offers">Смотреть акции ↓</a></div><strong>вкусно<br/>сейчас</strong></section><section id="offers" class="offers"><div class="headline"><p>активные предложения</p><h2>Выберите<br/>свой повод</h2></div><div class="offer-list">{offers.map(([slug,title,date,copy,badge],index)=><article><b>0{index+1}</b><div><p>{date}</p><h3>{title}</h3><span>{copy}</span></div><strong>{badge}</strong><a href={`/promotions/${slug}`}>Подробнее <i>→</i></a></article>)}</div></section><section class="note"><div><p>важное</p><h2>Все акции —<br/>в приложении.</h2><span>Там они появляются первыми, а ещё можно копить баллы и оплачивать ими любимый кофе.</span><a href="/app">Узнать о приложении →</a></div><b>ЧК</b></section></PageShell>
<style>@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap');:root{font-family:Montserrat,Arial,sans-serif;color:#20251f;background:#f8f7f2}*{box-sizing:border-box}body{margin:0}.brand{height:94px;padding:0 6vw;display:flex;align-items:center;gap:9px;color:inherit;text-decoration:none;font-size:20px;font-weight:800}.brand img{width:43px;height:43px;object-fit:contain}.hero{position:relative;overflow:hidden;min-height:670px;margin:0 2vw;border-radius:30px;background:#263b2d;color:#fff}.hero>img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}.hero:after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,#203c2e 0%,rgba(32,60,46,.86) 35%,rgba(32,60,46,.03) 72%)}.hero>div{position:relative;z-index:1;padding:clamp(60px,8vw,126px);max-width:730px}.hero p,.headline>p,.note p{margin:0;color:#b9dc3d;text-transform:uppercase;letter-spacing:.15em;font-size:11px;font-weight:800}.hero h1,.headline h2,.note h2{margin:20px 0;font-size:clamp(62px,7vw,118px);line-height:.83;letter-spacing:-.1em}.hero span{display:block;max-width:400px;font-size:16px;line-height:1.55}.hero a,.note a{display:inline-block;margin-top:30px;padding:18px 21px;background:#b7dc39;color:#1f3528;border-radius:99px;text-decoration:none;font-size:13px;font-weight:800}.hero>strong{position:absolute;right:6vw;bottom:52px;z-index:2;color:#b7dc39;font-family:'21Cent',cursive;font-size:clamp(55px,8vw,130px);line-height:.72;text-align:right}.offers{padding:clamp(100px,12vw,180px) 7vw;display:grid;grid-template-columns:.7fr 1.3fr;gap:70px}.headline h2{font-size:clamp(49px,5vw,86px)}.offer-list{display:grid;gap:10px}.offer-list article{position:relative;min-height:250px;padding:25px;border-radius:25px;background:#e5e8d9;display:grid;grid-template-columns:50px 1fr auto;gap:16px}.offer-list article:nth-child(2){background:#d7e6ca}.offer-list article:nth-child(3){background:#e7ded1}.offer-list article>b{font-size:12px;color:#719525}.offer-list p{margin:0;color:#6d752e;text-transform:uppercase;letter-spacing:.1em;font-size:10px;font-weight:700}.offer-list h3{margin:9px 0 11px;font-size:30px;letter-spacing:-.07em}.offer-list span{display:block;max-width:390px;font-size:12px;line-height:1.65}.offer-list strong{font-size:clamp(23px,3vw,39px);letter-spacing:-.08em}.offer-list a{position:absolute;bottom:22px;right:25px;color:inherit;text-decoration:none;font-size:11px;font-weight:700}.offer-list i{font-style:normal;margin-left:13px}.note{position:relative;overflow:hidden;margin:0 2vw 2vw;padding:clamp(55px,7vw,115px);border-radius:28px;background:#203c2e;color:#fff}.note h2{font-size:clamp(51px,5vw,86px)}.note>div{position:relative;z-index:1;max-width:600px}.note span{display:block;max-width:360px;font-size:13px;line-height:1.65}.note b{position:absolute;right:-.06em;bottom:-.32em;color:#b7dc39;font-size:clamp(220px,31vw,600px);line-height:1;letter-spacing:-.18em}@media(max-width:700px){.brand{height:72px;padding:0 20px}.hero{margin:0;border-radius:0;min-height:640px}.hero:after{background:linear-gradient(90deg,rgba(27,55,41,.93),rgba(27,55,41,.29))}.hero>div{padding:58px 20px}.hero h1{font-size:63px}.hero span{font-size:14px}.hero>strong{right:20px;bottom:40px;font-size:71px}.offers{display:block;padding:87px 20px}.headline h2{font-size:54px}.offer-list{margin-top:48px}.offer-list article{min-height:270px;grid-template-columns:32px 1fr;gap:11px;padding:19px;border-radius:20px}.offer-list strong{grid-column:2}.offer-list a{right:19px;bottom:19px}.offer-list span{padding-bottom:37px}.note{margin:0;border-radius:0;padding:65px 20px}.note h2{font-size:56px}.note b{font-size:275px}}</style>
