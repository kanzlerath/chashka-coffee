---
import PageShell from '../../../layouts/PageShell.astro';
import type { RestaurantMenuResponse } from '@chashka-coffee/contracts'
import { getRestaurantSlugs } from '../../../lib/public-api';

export async function getStaticPaths() { return (await getRestaurantSlugs(['krasny-prospekt', 'ulitsa-lenina', 'akademgorodok', 'galereya-novosibirsk', 'rechnoy-vokzal', 'ploshchad-lenina', 'vertical-apart-hotel', 'central-park', 'zaeltsovsky-park', 'mikhaylovskaya-naberegnaya', 'tolmachevo-domestic', 'tolmachevo-international', 'tolmachevo-arrivals'])).map((slug) => ({ params: { slug } })) }
const { slug } = Astro.params
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
let data: RestaurantMenuResponse | null = null
try { const response = await fetch(`${apiUrl}/api/restaurants/${slug}/menu`); if (response.ok) data = await response.json() } catch { /* static page remains available */ }
const price = (kopecks: number) => `${new Intl.NumberFormat('ru-RU').format(kopecks / 100)} ₽`
const dishImage = (index: number) => index % 3 === 0 ? '/images/home-hero-v1.png' : '/images/restaurants-hero.png'
const badgeLabel = (badge: string | null) => ({ NEW: 'Новинка', HIT: 'Хит', SEASONAL: 'Сезонное', SPECIAL: 'Специальное' }[badge ?? ''] ?? null)
const badgeTone = (badge: string | null) => ({ NEW: 'new', HIT: 'hit', SEASONAL: 'seasonal', SPECIAL: 'special' }[badge ?? ''] ?? 'special')
const dietaryLabel = (mark: string) => ({ VEGETARIAN: 'Вегетарианское', SPICY: 'Острое', LACTOSE_FREE: 'Без лактозы', GLUTEN_FREE: 'Без глютена', LIGHT: 'Лёгкое' }[mark] ?? mark)
const allergenLabel = (allergen: string) => ({ egg: 'Яйцо', gluten: 'Глютен', nuts: 'Орехи', milk: 'Молочный продукт', fish: 'Рыба' }[allergen] ?? allergen)
const dishPayload = (item: RestaurantMenuResponse['categories'][number]['items'][number], categoryName: string, imageUrl: string) => JSON.stringify({
  name: item.name,
  categoryName,
  description: item.description ?? '',
  ingredients: item.ingredients ?? '',
  allergens: item.allergens.map(allergenLabel),
  dietaryMarks: item.dietaryMarks.map(dietaryLabel),
  weight: item.weightGrams ? `${item.weightGrams} г` : '1 порция',
  price: price(item.priceKopecks),
  calories: item.calories === null ? null : String(item.calories),
  proteins: item.proteins === null ? null : `${item.proteins} г`,
  fats: item.fats === null ? null : `${item.fats} г`,
  carbohydrates: item.carbohydrates === null ? null : `${item.carbohydrates} г`,
  imageUrl,
  badge: badgeLabel(item.marketingBadge),
  badgeTone: badgeTone(item.marketingBadge),
})
---

<PageShell title="Меню ресторана" active="menu">{data ? <>
  <section class="hero"><img src="/images/home-hero-v1.png" alt="Кофе и свежая выпечка" /><div><p class="eyebrow">меню ресторана</p><h1>{data.restaurant.name.replace('Чашка кофе — ', '')}</h1><p>{data.restaurant.address}</p><a class="point-picker" href="/restaurants">Выбрать другую точку <span>⌄</span></a></div></section>
  <nav class="category-nav" aria-label="Категории меню">{data.categories.map((category) => <a href={`#${category.slug}`}>{category.name}</a>)}</nav>
  <div class="menu-shell">{data.categories.map((category, categoryIndex) => <section id={category.slug} class="category"><div class="category-title"><p class="eyebrow">0{categoryIndex + 1} · категория</p><h2>{category.name}</h2><span>{category.items.length} позиций</span></div><div class="items">{category.items.map((item, itemIndex) => {
    const imageUrl = item.imageUrl ?? dishImage(itemIndex + categoryIndex)
    const badge = badgeLabel(item.marketingBadge)
    return <button class="item" type="button" data-dish-trigger data-dish={dishPayload(item, category.name, imageUrl)} aria-haspopup="dialog" aria-label={`Открыть карточку блюда: ${item.name}`}>
      <div class="item-image"><img src={imageUrl} alt="" loading="lazy" />{badge && <span class={`badge badge--${badgeTone(item.marketingBadge)}`}>{badge}</span>}</div>
      <div class="item-copy"><small class="item-category">{category.name}</small><h3>{item.name}</h3><div class="item-bottom"><span>{item.weightGrams ? `${item.weightGrams} г` : '1 порция'}</span><strong>{price(item.priceKopecks)}</strong></div></div>
    </button>
  } )}</div></section>)}</div>
  <dialog class="dish-dialog" data-dish-dialog aria-labelledby="dish-dialog-title">
    <div class="dish-dialog-inner">
      <button class="dish-dialog-close" type="button" data-dish-close aria-label="Закрыть карточку блюда"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 5 14 14M19 5 5 19" /></svg></button>
      <div class="dish-dialog-media"><img data-dish-image src="" alt="" /><span class="dish-dialog-badge" data-dish-badge hidden></span></div>
      <div class="dish-dialog-content">
        <p class="dish-dialog-category" data-dish-category></p>
        <h2 id="dish-dialog-title" data-dish-name></h2>
        <p class="dish-dialog-description" data-dish-description></p>
        <dl class="dish-dialog-details">
          <div data-dish-ingredients-row><dt>Состав</dt><dd data-dish-ingredients></dd></div>
          <div data-dish-allergens-row><dt>Аллергены</dt><dd data-dish-allergens></dd></div>
          <div class="dish-dialog-marks" data-dish-marks-row><dt>Особенности</dt><dd data-dish-marks></dd></div>
        </dl>
        <section class="dish-dialog-nutrition" aria-labelledby="dish-nutrition-title">
          <p id="dish-nutrition-title">Пищевая ценность</p>
          <div><span><b data-dish-calories></b><small>ккал</small></span><span><b data-dish-proteins></b><small>белки</small></span><span><b data-dish-fats></b><small>жиры</small></span><span><b data-dish-carbohydrates></b><small>углеводы</small></span></div>
        </section>
        <footer class="dish-dialog-footer"><div><span data-dish-output></span><strong data-dish-price></strong></div><a class="button" href="/app">Заказать в приложении</a></footer>
      </div>
    </div>
  </dialog>
  <section class="app-banner"><div><p class="eyebrow">больше в приложении</p><h2>Любимое меню<br />всегда с вами</h2><p>Заказывайте доставку, копите бонусы и выбирайте привычное ещё быстрее.</p><a class="button" href="/app">Открыть приложение <span>→</span></a></div><div class="app-shape" aria-hidden="true"><b>Чашка<br />кофе</b><i>☕</i></div></section>
</> : <section class="unavailable"><p class="eyebrow">меню</p><h1>Данные появятся после запуска API.</h1><a href="/restaurants">Вернуться к ресторанам</a></section>}</PageShell>

<style>
@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap');:root{font-family:Montserrat,Arial,sans-serif;color:#1b201b;background:#eaebe5}*{box-sizing:border-box}body{margin:0;padding:14px;background:#eaebe5}a{color:inherit;text-decoration:none}.page-shell{max-width:1680px;margin:auto;background:#fdfcf8;border-radius:30px;overflow:hidden;box-shadow:0 14px 55px rgba(34,40,29,.08)}.header{height:104px;padding:0 clamp(34px,4.2vw,72px);display:flex;align-items:center;gap:34px}.brand,.footer-brand{display:flex;align-items:center;gap:10px;font-weight:800;line-height:.86;letter-spacing:-.075em;font-size:22px}.brand img{object-fit:contain}.header nav{display:flex;gap:34px;margin:auto}.header nav a{font-size:14px;font-weight:600}.header nav .active{border-bottom:2px solid #9bbe2b;padding-bottom:7px}.header-cta{background:#202d24;color:#fff;border-radius:999px;padding:15px 21px;font-size:14px;font-weight:700}.header-cta span{color:#b8d83e;margin-left:7px}.hero{height:min(34vw,530px);min-height:430px;position:relative;margin:0 14px;overflow:hidden;border-radius:25px}.hero img{width:100%;height:100%;object-fit:cover}.hero:after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,#fdfcf8 0%,rgba(253,252,248,.89) 35%,rgba(253,252,248,.08) 69%,transparent)}.hero>div{position:absolute;z-index:1;left:clamp(35px,6vw,105px);top:50%;transform:translateY(-50%)}.eyebrow{margin:0 0 14px;font-size:11px;text-transform:uppercase;letter-spacing:.14em;font-weight:700;color:#8baa27}.hero h1,.category-title h2,.app-banner h2,.unavailable h1{margin:0;font-size:clamp(53px,5.8vw,98px);letter-spacing:-.09em;line-height:.86}.hero>div>p:not(.eyebrow){font-size:16px;color:#576057;margin:22px 0}.point-picker{display:inline-flex;align-items:center;gap:33px;padding:14px 17px;border:1px solid #d7dbd3;border-radius:999px;background:#fffefa;font-size:13px;font-weight:700}.point-picker span{font-size:18px}.category-nav{margin:0 clamp(34px,6.5vw,108px);padding:28px 0;border-bottom:1px solid #d9ddd4;display:flex;gap:9px;overflow:auto}.category-nav a{white-space:nowrap;padding:13px 17px;border-radius:999px;border:1px solid #d7dbd3;font-size:13px;font-weight:700}.category-nav a:first-child{background:#202d24;border-color:#202d24;color:#fff}.menu-shell{padding:40px clamp(34px,6.5vw,108px) 130px}.category{display:grid;grid-template-columns:280px 1fr;gap:48px;padding:72px 0 0}.category-title{position:sticky;top:30px;height:max-content}.category-title h2{font-size:clamp(39px,3.7vw,63px);margin-bottom:17px}.category-title>span{font-size:13px;color:#697168}.items{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:13px}.item{min-height:420px;border:1px solid #e0e3dc;border-radius:22px;overflow:hidden;background:#fffefa;display:flex;flex-direction:column}.item>img{height:193px;width:100%;object-fit:cover}.item-copy{display:flex;flex-direction:column;flex:1;padding:19px}.item-head{display:flex;gap:10px;align-items:start;justify-content:space-between}.item h3{margin:0;font-size:22px;letter-spacing:-.055em;line-height:1.02}.badge{border-radius:999px;background:#a8ce32;color:#25321e;padding:6px 8px;font-size:10px;font-weight:800;white-space:nowrap}.item-copy>p{font-size:12px;line-height:1.5;color:#5b645a;margin:13px 0}.item-bottom{margin-top:auto;padding-top:18px;display:flex;align-items:end;justify-content:space-between}.item-bottom span{font-size:11px;color:#7b827a}.item-bottom strong{font-size:21px;letter-spacing:-.06em}.marks{display:flex;gap:5px;flex-wrap:wrap;margin-top:15px}.marks span{border:1px solid #dbe0d8;border-radius:999px;padding:5px 7px;font-size:9px;color:#687169}.app-banner{margin:0 14px 14px;padding:clamp(43px,6vw,92px);min-height:420px;border-radius:25px;overflow:hidden;background:#e8e1d9;display:grid;grid-template-columns:1.15fr .85fr;position:relative}.app-banner h2{font-size:clamp(46px,5vw,82px)}.app-banner p:not(.eyebrow){max-width:390px;font-size:16px;line-height:1.55;color:#5d625a;margin:23px 0}.button{display:inline-flex;align-items:center;gap:27px;border-radius:999px;padding:18px 21px;background:#202d24;color:#fff;font-size:14px;font-weight:700}.app-shape{justify-self:center;align-self:end;width:220px;height:350px;border:9px solid #202d24;border-radius:37px;background:#fdfcf8;transform:rotate(8deg);padding:51px 22px;font-size:26px;font-weight:800;line-height:.87;letter-spacing:-.08em;box-shadow:17px 18px 0 rgba(77,94,69,.15)}.app-shape i{display:grid;place-items:center;width:130px;aspect-ratio:1;margin:42px auto 0;border-radius:48% 52% 42% 58%;background:#a8cd32;font-style:normal;font-size:61px}.unavailable{min-height:70vh;padding:18vh 10vw}.unavailable a{font-size:15px;font-weight:700;border-bottom:1px solid}footer{padding:75px clamp(34px,6.5vw,105px) 23px;background:#202d24;color:#f7f6ed;display:grid;grid-template-columns:1fr 1.2fr 1fr;gap:35px;align-items:start}.footer-brand{font-size:25px}.footer-brand img{object-fit:contain}.footer-brand+p{font-size:clamp(28px,3vw,43px);font-weight:700;line-height:.93;letter-spacing:-.07em;margin:0}.footer-links{display:flex;gap:14px;flex-wrap:wrap}.footer-links a,footer>span{font-size:12px;color:#d1d9d0}footer>span{grid-column:1/-1;border-top:1px solid rgba(255,255,255,.16);padding-top:20px}.mobile-nav{display:none}@media(max-width:840px){body{padding:0;background:#fdfcf8}.page-shell{border-radius:0;box-shadow:none}.header{height:72px;padding:0 20px}.brand{font-size:18px}.brand img{width:39px;height:39px}.header nav,.header-cta{display:none}.hero{height:490px;min-height:0;margin:0;border-radius:0}.hero:after{background:linear-gradient(180deg,#fdfcf8 0%,rgba(253,252,248,.86) 52%,rgba(253,252,248,.05) 95%,transparent)}.hero>div{left:20px;top:61px;right:20px;transform:none}.hero h1{font-size:52px}.hero>div>p:not(.eyebrow){font-size:14px;margin:17px 0}.point-picker{font-size:11px;padding:12px 14px}.category-nav{margin:0;padding:22px 20px;border-bottom:0;gap:7px}.category-nav a{font-size:11px;padding:11px 14px}.menu-shell{padding:8px 20px 80px}.category{display:block;padding-top:63px}.category-title{position:static}.category-title h2{font-size:47px}.items{grid-template-columns:1fr;gap:9px;margin-top:24px}.item{min-height:0;display:grid;grid-template-columns:42% 58%;border-radius:19px}.item>img{height:100%;min-height:190px}.item-copy{padding:16px}.item h3{font-size:20px}.item-copy>p{font-size:11px;margin:10px 0}.item-bottom{padding-top:10px}.item-bottom strong{font-size:19px}.marks{display:none}.app-banner{margin:0 12px 12px;padding:48px 25px 0;display:block;border-radius:22px;min-height:650px}.app-banner h2{font-size:50px}.app-banner p:not(.eyebrow){font-size:15px}.app-shape{margin:45px auto -50px;transform:rotate(6deg) scale(.84);transform-origin:bottom center}footer{margin-bottom:71px;padding:46px 20px 20px;display:block}.footer-brand+p{margin:32px 0}.footer-links{margin:34px 0}footer>span{display:block}.mobile-nav{position:fixed;z-index:4;bottom:0;left:0;right:0;height:71px;display:flex;justify-content:space-around;align-items:center;background:rgba(253,252,248,.94);backdrop-filter:blur(14px);border-top:1px solid #dde0d8}.mobile-nav a{font-size:19px;display:flex;flex-direction:column;align-items:center;gap:2px;color:#747a72}.mobile-nav small{font-size:9px;font-weight:600}.mobile-nav .active{color:#202d24}.mobile-nav .active:first-letter{background:#b5d83e;border-radius:12px;padding:1px 8px}}
.item{min-height:390px;padding:11px;border:1px solid #e0e3dc;border-radius:22px;background:#f7f5f0;display:flex;flex-direction:column;transition:transform .24s,box-shadow .24s,background .24s}.item:hover{background:#fffefa;box-shadow:0 15px 30px rgba(40,48,35,.09);transform:translateY(-4px)}.item-image{position:relative;height:215px;overflow:hidden;border-radius:15px;background:#ebe8e1}.item-image>img{width:100%;height:100%;object-fit:cover;transition:transform .4s}.item:hover .item-image>img{transform:scale(1.05)}.item-copy{display:flex;flex-direction:column;flex:1;padding:17px 5px 4px}.item-category{color:#6d746a;text-transform:uppercase;letter-spacing:.1em;font-size:9px;font-weight:800}.item h3{margin:9px 0 0;font-size:22px;letter-spacing:-.055em;line-height:1.02}.badge{position:absolute;top:12px;left:12px;z-index:1;border-radius:999px;background:rgba(255,254,250,.94);color:#25321e;padding:7px 9px;font-size:9px;font-weight:800;white-space:nowrap;text-transform:uppercase}.item-bottom{margin-top:auto;padding-top:18px;display:flex;align-items:end;justify-content:space-between}.item-bottom span{font-size:11px;color:#7b827a}.item-bottom strong{font-size:16px;letter-spacing:-.06em}.marks,.item-copy>p,.item-head{display:none}@media(max-width:840px){.item{min-height:0;display:grid;grid-template-columns:42% 58%;gap:0;border-radius:19px}.item-image{height:100%;min-height:190px;border-radius:13px}.item-copy{padding:16px 7px 8px 16px}.item h3{font-size:20px}.item-bottom{padding-top:10px}.item-bottom strong{font-size:16px}}
</style>

<style>
  .item{width:100%;appearance:none;border:1px solid #e0e3dc;color:inherit;font:inherit;text-align:left;cursor:pointer}
  .item:focus-visible{outline:3px solid #bddb3d;outline-offset:4px}
  .badge{border:1px solid transparent;border-radius:var(--radius);box-shadow:0 5px 14px rgba(45,34,26,.14)}
  .badge--hit{background:#536c42;color:#fff;border-color:#789163}
  .badge--new{background:#bddb3d;color:#1f3b2e;border-color:#d7eb83}
  .badge--seasonal{background:#eda46b;color:#4c2816;border-color:#f5c291}
  .badge--special{background:#6c7ea6;color:#fff;border-color:#9eabd0}
  .dish-dialog{width:min(1160px,calc(100vw - 48px));max-width:none;max-height:calc(100svh - 48px);margin:auto;padding:0;border:0;border-radius:var(--radius);background:#fcfbf8;color:#231e1b;box-shadow:0 28px 90px rgba(22,28,22,.28);overflow:hidden}
  .dish-dialog::backdrop{background:rgba(27,32,26,.58);backdrop-filter:blur(7px)}
  .dish-dialog[open]{animation:dish-dialog-in .3s cubic-bezier(.22,1,.36,1)}
  @keyframes dish-dialog-in{from{opacity:0;transform:translateY(18px) scale(.985)}to{opacity:1;transform:none}}
  .dish-dialog-inner{display:grid;grid-template-columns:minmax(0,1.08fr) minmax(360px,.92fr);min-height:min(690px,calc(100svh - 48px))}
  .dish-dialog-close{position:absolute;z-index:3;top:19px;right:19px;display:grid;place-items:center;width:46px;height:46px;padding:0;border:1px solid rgba(35,30,27,.11);border-radius:var(--radius);background:rgba(252,251,248,.94);color:#231e1b;cursor:pointer;transition:background-color .2s ease,transform .2s ease}
  .dish-dialog-close:hover{background:#bddb3d;transform:rotate(4deg)}
  .dish-dialog-close:focus-visible{outline:3px solid #bddb3d;outline-offset:3px}
  .dish-dialog-close svg{width:22px;height:22px;fill:none;stroke:currentColor;stroke-linecap:round;stroke-width:1.8}
  .dish-dialog-media{position:relative;min-height:0;overflow:hidden;background:#eeece6}
  .dish-dialog-media img{display:block;width:100%;height:100%;object-fit:cover}
  .dish-dialog-badge{position:absolute;top:24px;left:24px;padding:8px 12px;border:1px solid transparent;border-radius:var(--radius);font-size:10px;font-weight:900;letter-spacing:.08em;text-transform:uppercase;box-shadow:0 5px 14px rgba(45,34,26,.15)}
  .dish-dialog-badge--hit{background:#536c42;color:#fff;border-color:#789163}.dish-dialog-badge--new{background:#bddb3d;color:#1f3b2e;border-color:#d7eb83}.dish-dialog-badge--seasonal{background:#eda46b;color:#4c2816;border-color:#f5c291}.dish-dialog-badge--special{background:#6c7ea6;color:#fff;border-color:#9eabd0}
  .dish-dialog-content{display:flex;min-height:0;flex-direction:column;padding:clamp(38px,4vw,64px);overflow:auto}
  .dish-dialog-category{margin:0;color:#1f3b2e;font-size:10px;font-weight:800;letter-spacing:.12em;text-transform:uppercase}
  .dish-dialog-content h2{margin:12px 54px 0 0;font-size:clamp(32px,3.2vw,54px);line-height:.9;letter-spacing:-.08em}
  .dish-dialog-description{margin:18px 0 0;color:#635e57;font-size:15px;line-height:1.55}
  .dish-dialog-details{display:grid;gap:19px;margin:31px 0 0;padding-top:28px;border-top:1px solid #e4dfd7}
  .dish-dialog-details>div{display:grid;gap:7px}.dish-dialog-details dt,.dish-dialog-nutrition>p{color:#817a71;font-size:11px;font-weight:700}.dish-dialog-details dd{margin:0;color:#2a2622;font-size:14px;line-height:1.5}
  .dish-dialog-marks dd{display:flex;flex-wrap:wrap;gap:6px}.dish-dialog-marks dd span{padding:6px 9px;border-radius:var(--radius);background:#e3eadb;color:#27432f;font-size:10px;font-weight:800}
  .dish-dialog-nutrition{margin-top:28px;padding-top:25px;border-top:1px solid #e4dfd7}.dish-dialog-nutrition>p{margin:0}.dish-dialog-nutrition>div{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:8px;margin-top:12px}.dish-dialog-nutrition span{display:grid;gap:3px;color:#29251f}.dish-dialog-nutrition b{font-size:16px;letter-spacing:-.04em}.dish-dialog-nutrition small{color:#817a71;font-size:9px;font-weight:700;text-transform:uppercase}
  .dish-dialog-footer{display:flex;align-items:center;justify-content:space-between;gap:18px;margin-top:auto;padding-top:35px}.dish-dialog-footer>div{display:grid;gap:5px}.dish-dialog-footer span{color:#7d766c;font-size:11px}.dish-dialog-footer strong{font-size:28px;letter-spacing:-.075em}.dish-dialog-footer .button{min-width:218px;padding:0 21px;border:0;border-radius:var(--radius);font:800 12px Montserrat,Arial,sans-serif}
  @media(max-width:760px){.dish-dialog{position:fixed;right:12px;bottom:12px;left:12px;width:auto;max-height:calc(100svh - 24px);margin:0;border-radius:var(--radius)}.dish-dialog-inner{display:block;min-height:0;max-height:calc(100svh - 24px);overflow:auto}.dish-dialog-media{height:min(48svh,390px)}.dish-dialog-content{overflow:visible;padding:29px 22px 25px}.dish-dialog-close{top:12px;right:12px;width:42px;height:42px}.dish-dialog-badge{top:16px;left:16px}.dish-dialog-content h2{margin-top:10px;font-size:36px}.dish-dialog-description{font-size:14px}.dish-dialog-details{margin-top:24px;padding-top:22px}.dish-dialog-nutrition{margin-top:24px;padding-top:21px}.dish-dialog-nutrition>div{grid-template-columns:repeat(2,minmax(0,1fr));gap:11px}.dish-dialog-footer{align-items:stretch;flex-direction:column;padding-top:29px}.dish-dialog-footer>div{grid-template-columns:1fr auto;align-items:end}.dish-dialog-footer>div span{grid-row:1}.dish-dialog-footer>div strong{grid-row:1;font-size:27px}.dish-dialog-footer .button{width:100%;min-width:0;min-height:50px}}
  @media(prefers-reduced-motion:reduce){.dish-dialog[open]{animation:none}.dish-dialog-close,.item{transition:none}}
</style>

<script>
  type DishPayload = {
    name: string
    categoryName: string
    description: string
    ingredients: string
    allergens: string[]
    dietaryMarks: string[]
    weight: string
    price: string
    calories: string | null
    proteins: string | null
    fats: string | null
    carbohydrates: string | null
    imageUrl: string
    badge: string | null
    badgeTone: string
  }

  const dialog = document.querySelector<HTMLDialogElement>('[data-dish-dialog]')
  const triggers = document.querySelectorAll<HTMLButtonElement>('[data-dish-trigger]')
  const setText = (selector: string, value: string | null) => {
    const element = dialog?.querySelector<HTMLElement>(selector)
    if (element) element.textContent = value ?? '—'
  }
  const setRow = (selector: string, shouldShow: boolean) => {
    const element = dialog?.querySelector<HTMLElement>(selector)
    if (element) element.hidden = !shouldShow
  }

  const openDish = (payload: DishPayload) => {
    if (!dialog) return
    const image = dialog.querySelector<HTMLImageElement>('[data-dish-image]')
    if (image) {
      image.src = payload.imageUrl
      image.alt = `Фото блюда: ${payload.name}`
    }
    setText('[data-dish-category]', payload.categoryName)
    setText('[data-dish-name]', payload.name)
    setText('[data-dish-description]', payload.description)
    setText('[data-dish-ingredients]', payload.ingredients)
    setText('[data-dish-allergens]', payload.allergens.join(' · '))
    setText('[data-dish-output]', payload.weight)
    setText('[data-dish-price]', payload.price)
    setText('[data-dish-calories]', payload.calories)
    setText('[data-dish-proteins]', payload.proteins)
    setText('[data-dish-fats]', payload.fats)
    setText('[data-dish-carbohydrates]', payload.carbohydrates)
    setRow('[data-dish-ingredients-row]', Boolean(payload.ingredients))
    setRow('[data-dish-allergens-row]', payload.allergens.length > 0)
    setRow('[data-dish-marks-row]', payload.dietaryMarks.length > 0)

    const marks = dialog.querySelector<HTMLElement>('[data-dish-marks]')
    if (marks) {
      marks.replaceChildren(...payload.dietaryMarks.map((mark) => {
        const tag = document.createElement('span')
        tag.textContent = mark
        return tag
      }))
    }

    const badge = dialog.querySelector<HTMLElement>('[data-dish-badge]')
    if (badge) {
      badge.hidden = !payload.badge
      badge.textContent = payload.badge ?? ''
      badge.className = `dish-dialog-badge dish-dialog-badge--${payload.badgeTone}`
    }
    dialog.showModal()
    dialog.querySelector<HTMLButtonElement>('[data-dish-close]')?.focus()
  }

  triggers.forEach((trigger) => trigger.addEventListener('click', () => {
    const rawPayload = trigger.dataset.dish
    if (!rawPayload) return
    try {
      openDish(JSON.parse(rawPayload) as DishPayload)
    } catch {
      // Invalid client data should never prevent using the rest of the menu.
    }
  }))

  dialog?.querySelector('[data-dish-close]')?.addEventListener('click', () => dialog.close())
  dialog?.addEventListener('click', (event) => {
    if (event.target === dialog) dialog.close()
  })
</script>
