---
type RestaurantPage = {
  slug: string
  title: string
  address: string
  phone: string
  format: string
  schedule: string
  description: string
  image: string
}

const restaurants: RestaurantPage[] = [
  { slug: 'krasny-prospekt', title: 'Красный проспект', address: 'Красный проспект, 25, Новосибирск', phone: '+7 (383) 123-20-20', format: 'Городская кофейня', schedule: 'Пн–Пт 07:30–22:00 · Сб–Вс 08:00–23:00', description: 'Светлая городская кофейня на главной улице. Здесь удобно встретиться утром, поработать днём и задержаться после прогулки по центру.', image: '/images/restaurants-hero.png' },
  { slug: 'ulitsa-lenina', title: 'Улица Ленина', address: 'ул. Ленина, 12, Новосибирск', phone: '+7 (383) 123-20-21', format: 'Городская кофейня', schedule: 'Ежедневно 08:00–22:00', description: 'Место для завтрака перед делами и разговоров, которые не хочется торопить.', image: '/images/restaurants-hero.png' },
  { slug: 'akademgorodok', title: 'Академгородок', address: 'проспект Академика Коптюга, 4, Новосибирск', phone: '+7 (383) 123-20-22', format: 'Городская кофейня', schedule: 'Ежедневно 08:00–22:00', description: 'Кофе, выпечка и спокойный ритм между встречами и прогулками по Академгородку.', image: '/images/restaurants-hero.png' },
  { slug: 'galereya-novosibirsk', title: 'Галерея Новосибирск', address: 'ул. Гоголя, 13, Новосибирск', phone: '+7 (383) 123-20-23', format: 'Городская кофейня', schedule: 'Ежедневно 10:00–22:00', description: 'Удобная пауза во время прогулки по городу и шопинга.', image: '/images/restaurants-hero.png' },
  { slug: 'rechnoy-vokzal', title: 'Речной вокзал', address: 'ул. Большевистская, 12, Новосибирск', phone: '+7 (383) 123-20-24', format: 'Городская кофейня', schedule: 'Ежедневно 08:00–22:00', description: 'Кофейня на пути к набережной — для кофе с собой или неспешного завтрака.', image: '/images/home-hero-v1.png' },
  { slug: 'ploshchad-lenina', title: 'Площадь Ленина', address: 'Красный проспект, 29, Новосибирск', phone: '+7 (383) 123-20-25', format: 'Городская кофейня', schedule: 'Ежедневно 08:00–23:00', description: 'В самом центре города — для встреч перед театром и долгих разговоров за чашкой кофе.', image: '/images/restaurants-hero.png' },
  { slug: 'vertical-apart-hotel', title: 'Vertical', address: 'ул. Советская, 8, Новосибирск', phone: '+7 (383) 123-20-26', format: 'Кофейня при апарт-отеле', schedule: 'Ежедневно 07:00–23:00', description: 'Утренний кофе для гостей города и привычное место для тех, кто живёт рядом.', image: '/images/restaurants-hero.png' },
  { slug: 'central-park', title: 'Центральный парк', address: 'ул. Мичурина, 8, Новосибирск', phone: '+7 (383) 123-20-27', format: 'Кофейня в парке', schedule: 'Ежедневно 09:00–21:00', description: 'Кофе и десерты для прогулки по парку — берите с собой или оставайтесь на веранде.', image: '/images/home-hero-v1.png' },
  { slug: 'zaeltsovsky-park', title: 'Заельцовский парк', address: 'ул. Парковая, 88, Новосибирск', phone: '+7 (383) 123-20-28', format: 'Кофейня в парке', schedule: 'Ежедневно 09:00–21:00', description: 'Точка притяжения среди сосен, тишины и длинных прогулок.', image: '/images/home-hero-v1.png' },
  { slug: 'mikhaylovskaya-naberegnaya', title: 'Михайловская набережная', address: 'ул. Большевистская, 12Б, Новосибирск', phone: '+7 (383) 123-20-29', format: 'Кофейня в парке', schedule: 'Ежедневно 09:00–21:00', description: 'Кофе с видом на реку и прогулка без маршрута.', image: '/images/home-hero-v1.png' },
  { slug: 'tolmachevo-domestic', title: 'Толмачёво — вылеты по России', address: 'аэропорт Толмачёво, сектор A, Обь', phone: '+7 (383) 123-20-30', format: 'Кофейня в аэропорту', schedule: 'Ежедневно 06:00–23:00', description: 'Время на хороший кофе есть даже перед вылетом.', image: '/images/restaurants-hero.png' },
  { slug: 'tolmachevo-international', title: 'Толмачёво — международные вылеты', address: 'аэропорт Толмачёво, сектор B, Обь', phone: '+7 (383) 123-20-31', format: 'Кофейня в аэропорту', schedule: 'Ежедневно 06:00–23:00', description: 'Пауза перед большим путешествием — с любимым вкусом рядом.', image: '/images/restaurants-hero.png' },
  { slug: 'tolmachevo-arrivals', title: 'Толмачёво — зал прилёта', address: 'аэропорт Толмачёво, зал прилёта, Обь', phone: '+7 (383) 123-20-32', format: 'Кофейня в аэропорту', schedule: 'Ежедневно 06:00–23:00', description: 'Встречайте близких и начинайте дорогу домой с чашки хорошего кофе.', image: '/images/home-hero-v1.png' },
]

export function getStaticPaths() {
  return ['krasny-prospekt', 'ulitsa-lenina', 'akademgorodok', 'galereya-novosibirsk', 'rechnoy-vokzal', 'ploshchad-lenina', 'vertical-apart-hotel', 'central-park', 'zaeltsovsky-park', 'mikhaylovskaya-naberegnaya', 'tolmachevo-domestic', 'tolmachevo-international', 'tolmachevo-arrivals'].map((slug) => ({ params: { slug } }))
}

const restaurant = restaurants.find(({ slug }) => slug === Astro.params.slug) ?? restaurants[0]
const mapsQuery = encodeURIComponent(restaurant.address)
---

<html lang="ru"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width" /><meta name="description" content={`${restaurant.title}: адрес, часы работы и меню «Чашки кофе».`} /><title>{restaurant.title} — Чашка кофе</title></head>
<body><div class="page-shell">
  <header class="header"><a class="brand" href="/"><img src="/brand/logo.png" alt="" width="44" height="44" /><span>Чашка<br />кофе</span></a><nav><a class="active" href="/restaurants">Рестораны</a><a href={`/restaurants/${restaurant.slug}/menu`}>Меню</a><a href="/app">Приложение</a><a href="/about">О нас</a></nav><a class="header-cta" href="/app">Доставка <span>↗</span></a></header>
  <main>
    <div class="crumbs"><a href="/">Главная</a><span>·</span><a href="/restaurants">Рестораны</a><span>·</span><b>{restaurant.title}</b></div>
    <section class="intro"><div class="intro-copy"><p class="eyebrow">{restaurant.format}</p><h1>Чашка кофе —<br />{restaurant.title}</h1><p>{restaurant.description}</p><div class="actions"><a class="button dark" href={`/restaurants/${restaurant.slug}/menu`}>Смотреть меню <span>→</span></a><a class="button light" href={`https://yandex.ru/maps/?text=${mapsQuery}`} target="_blank" rel="noreferrer">Построить маршрут <span>↗</span></a></div></div><div class="photo-grid"><img class="photo-large" src={restaurant.image} alt={`Интерьер ресторана «Чашка кофе — ${restaurant.title}»`} /><img src="/images/home-hero-v1.png" alt="Кофе и выпечка" /><div class="photo-note"><span>●</span> любимый вкус<br />всегда рядом</div></div></section>
    <section class="facts" aria-label="Информация о ресторане"><div><span>⌖</span><p>Адрес</p><strong>{restaurant.address}</strong><a href={`https://yandex.ru/maps/?text=${mapsQuery}`} target="_blank" rel="noreferrer">Открыть карту ↗</a></div><div><span>◔</span><p>Режим работы</p><strong>{restaurant.schedule}</strong><a href="/contacts">Все контакты ↗</a></div><div><span>⌕</span><p>Телефон</p><strong>{restaurant.phone}</strong><a href={`tel:${restaurant.phone.replaceAll(/[\s()-]/g, '')}`}>Позвонить ↗</a></div><aside><p>Сегодня</p><strong>Ждём вас<br />до 22:00</strong><span>без перерыва</span></aside></section>
    <section class="about"><div><p class="eyebrow">о ресторане</p><h2>Встречи без повода<br />и кофе без спешки</h2></div><p>{restaurant.description} Здесь можно начать день с завтрака, забежать за кофе по пути или встретиться с друзьями вечером.</p></section>
    <section class="map-section"><div class="map-copy"><p class="eyebrow">как найти</p><h2>Мы рядом</h2><p>{restaurant.address}</p><div><a class="map-link" href={`https://yandex.ru/maps/?text=${mapsQuery}`} target="_blank" rel="noreferrer">Яндекс Карты <span>→</span></a><a class="map-link" href={`https://2gis.ru/novosibirsk/search/${mapsQuery}`} target="_blank" rel="noreferrer">2ГИС <span>→</span></a></div></div><div class="map-plane" aria-hidden="true"><span>Чашка<br />кофе</span><i></i><b>Красный проспект</b><em>Новосибирск</em></div></section>
    <section class="menu-callout"><div><p class="eyebrow">меню ресторана</p><h2>У каждого места<br />свой вкус</h2><p>Посмотрите блюда, напитки и актуальные цены именно этой точки.</p><a class="button dark" href={`/restaurants/${restaurant.slug}/menu`}>Открыть меню <span>→</span></a></div><img src="/images/home-hero-v1.png" alt="Круассан и чашка кофе" /></section>
  </main>
  <footer><div class="footer-brand"><img src="/brand/logo.png" alt="" width="58" height="58" /><span>Чашка<br />кофе</span></div><p>Ваше место<br />для хорошего дня.</p><div class="footer-links"><a href="/restaurants">Рестораны</a><a href="/contacts">Контакты</a><a href="/privacy">Политика</a></div><span>© 2026 Чашка кофе</span></footer>
</div><nav class="mobile-nav"><a href="/">⌂<small>Главная</small></a><a class="active" href="/restaurants">⌖<small>Кофейни</small></a><a href={`/restaurants/${restaurant.slug}/menu`}>≡<small>Меню</small></a><a href="/app">◒<small>Приложение</small></a></nav></body></html>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap');@font-face{font-family:'21Cent';src:url('/brand/21Cent-Italic.ttf') format('truetype');font-style:italic;font-display:swap}:root{font-family:Montserrat,Arial,sans-serif;color:#1b201b;background:#eaebe5}*{box-sizing:border-box}body{margin:0;padding:14px;background:#eaebe5}a{color:inherit;text-decoration:none}.page-shell{max-width:1680px;margin:auto;background:#fdfcf8;border-radius:30px;overflow:hidden;box-shadow:0 14px 55px rgba(34,40,29,.08)}.header{height:104px;padding:0 clamp(34px,4.2vw,72px);display:flex;align-items:center;gap:34px}.brand,.footer-brand{display:flex;align-items:center;gap:10px;font-weight:800;line-height:.86;letter-spacing:-.075em;font-size:22px}.brand img{object-fit:contain}.header nav{display:flex;gap:34px;margin:auto}.header nav a{font-size:14px;font-weight:600}.header nav .active{border-bottom:2px solid #9bbe2b;padding-bottom:7px}.header-cta{background:#202d24;color:#fff;border-radius:999px;padding:15px 21px;font-size:14px;font-weight:700}.header-cta span{color:#b8d83e;margin-left:7px}.crumbs{padding:14px clamp(34px,4.2vw,72px) 0;font-size:12px;color:#7b8078;display:flex;gap:9px}.crumbs b{color:#30352e}.intro{padding:42px clamp(34px,4.2vw,72px) 56px;display:grid;grid-template-columns:.92fr 1.08fr;gap:60px;align-items:center}.eyebrow{margin:0 0 15px;font-size:11px;text-transform:uppercase;letter-spacing:.14em;font-weight:700;color:#8bab25}.intro h1,.about h2,.map-copy h2,.menu-callout h2{font-size:clamp(53px,5.6vw,98px);line-height:.87;letter-spacing:-.09em;margin:0}.intro-copy>p:not(.eyebrow){max-width:475px;font-size:17px;line-height:1.55;color:#5b6259;margin:29px 0}.actions{display:flex;gap:11px;flex-wrap:wrap}.button{border-radius:999px;padding:18px 21px;display:inline-flex;gap:27px;align-items:center;font-size:14px;font-weight:700}.dark{background:#202d24;color:#fff}.light{border:1px solid #d3d8cf}.photo-grid{min-height:470px;display:grid;grid-template-columns:1.25fr .75fr;grid-template-rows:1fr 1fr;gap:11px;position:relative}.photo-grid img{width:100%;height:100%;object-fit:cover;border-radius:25px}.photo-large{grid-row:span 2}.photo-note{position:absolute;bottom:17px;right:17px;padding:13px 16px;border-radius:14px;background:#fdfcf8;font-size:12px;line-height:1.15;font-weight:700}.photo-note span{color:#a8cb31}.facts{margin:0 14px;padding:31px clamp(22px,3vw,52px);border-radius:25px;background:#eff0e9;display:grid;grid-template-columns:repeat(3,1fr) 1.05fr;gap:25px}.facts>div{padding-right:23px;border-right:1px solid #d8dcd2}.facts span{font-size:22px;color:#8baa27}.facts p,.facts aside p{font-size:12px;color:#70776e;margin:14px 0 8px}.facts strong{font-size:16px;line-height:1.45;display:block}.facts a{display:inline-block;margin-top:17px;font-size:12px;font-weight:700;border-bottom:1px solid #bdc4ba}.facts aside{border-radius:19px;background:#d9e9a6;padding:20px 23px}.facts aside p{margin-top:0;color:#60731a}.facts aside strong{font-size:23px;line-height:.92;letter-spacing:-.07em}.facts aside span{display:block;margin-top:13px;font-size:11px;color:#64701f}.about{padding:clamp(95px,11vw,165px) clamp(34px,9vw,150px);display:grid;grid-template-columns:1.1fr .9fr;gap:70px}.about h2{font-size:clamp(49px,5vw,85px)}.about>p{margin:64px 0 0;font-size:17px;line-height:1.65;color:#50584f}.map-section{margin:0 14px 110px;min-height:450px;border-radius:25px;overflow:hidden;background:#e5e8de;display:grid;grid-template-columns:.75fr 1.25fr}.map-copy{padding:55px}.map-copy h2{font-size:65px}.map-copy>p:not(.eyebrow){font-size:15px;line-height:1.5;color:#586058}.map-copy>div{display:flex;gap:8px;flex-wrap:wrap;margin-top:34px}.map-link{padding:13px 16px;border:1px solid #cbd1c6;border-radius:999px;font-size:13px;font-weight:700}.map-link span{margin-left:10px}.map-plane{position:relative;overflow:hidden;background:linear-gradient(125deg,#d1e1cf 0 15%,#edf0e8 15% 34%,#d7e4ec 34% 41%,#edf0e8 41% 72%,#d1e1cf 72%);isolation:isolate}.map-plane:before,.map-plane:after{content:'';position:absolute;inset:20% -10%;border-top:16px solid rgba(255,255,255,.78);transform:rotate(-14deg);box-shadow:0 90px 0 rgba(255,255,255,.75),0 180px 0 rgba(255,255,255,.6)}.map-plane:after{transform:rotate(43deg);inset:6% -30%;border-width:10px;box-shadow:0 120px 0 rgba(255,255,255,.65)}.map-plane span{position:absolute;z-index:1;left:55%;top:45%;width:95px;aspect-ratio:1;border-radius:48% 48% 48% 0;display:grid;place-items:center;background:#202d24;color:#fff;text-align:center;font-size:14px;font-weight:800;line-height:.85;transform:rotate(-45deg)}.map-plane span::first-line{transform:rotate(45deg)}.map-plane i{position:absolute;z-index:1;left:59%;top:54%;width:15px;height:15px;border-radius:50%;background:#b2d53c}.map-plane b,.map-plane em{position:absolute;z-index:1;font-size:14px;color:#73806b}.map-plane b{left:22%;top:23%}.map-plane em{right:14%;bottom:18%}.menu-callout{margin:0 14px 14px;min-height:470px;border-radius:25px;overflow:hidden;display:grid;grid-template-columns:.9fr 1.1fr;background:#d8e6cf}.menu-callout>div{padding:clamp(42px,6vw,95px)}.menu-callout h2{font-size:clamp(47px,5vw,83px)}.menu-callout p:not(.eyebrow){max-width:375px;font-size:16px;line-height:1.55;color:#4e5d4f;margin:27px 0}.menu-callout img{width:100%;height:100%;object-fit:cover}.menu-callout .button{margin-top:5px}footer{padding:75px clamp(34px,6.5vw,105px) 23px;background:#202d24;color:#f7f6ed;display:grid;grid-template-columns:1fr 1.2fr 1fr;gap:35px;align-items:start}.footer-brand{font-size:25px}.footer-brand img{object-fit:contain}.footer-brand+ p{font-size:clamp(28px,3vw,43px);font-weight:700;line-height:.93;letter-spacing:-.07em;margin:0}.footer-links{display:flex;gap:14px;flex-wrap:wrap}.footer-links a,footer>span{font-size:12px;color:#d1d9d0}footer>span{grid-column:1/-1;border-top:1px solid rgba(255,255,255,.16);padding-top:20px}.mobile-nav{display:none}@media(max-width:840px){body{padding:0;background:#fdfcf8}.page-shell{border-radius:0;box-shadow:none}.header{height:72px;padding:0 20px}.brand{font-size:18px}.brand img{width:39px;height:39px}.header nav,.header-cta{display:none}.crumbs{padding:13px 20px 0;font-size:10px;white-space:nowrap;overflow:hidden}.intro{padding:35px 20px 62px;display:block}.intro h1{font-size:53px}.intro-copy>p:not(.eyebrow){font-size:15px;margin:22px 0}.photo-grid{min-height:430px;margin-top:43px;grid-template-columns:1.16fr .84fr;gap:8px}.photo-grid img{border-radius:19px}.photo-note{right:10px;bottom:10px;font-size:10px;padding:10px}.facts{margin:0 12px;padding:25px 20px;display:block;border-radius:22px}.facts>div{border:0;border-bottom:1px solid #d8dcd2;padding:0 0 21px;margin-bottom:21px}.facts aside{padding:19px}.about{padding:82px 20px;display:block}.about h2{font-size:51px}.about>p{margin-top:29px;font-size:15px}.map-section{margin:0 12px 70px;display:block;border-radius:22px}.map-copy{padding:38px 25px}.map-copy h2{font-size:54px}.map-plane{min-height:300px}.menu-callout{margin:0 12px 12px;display:block;border-radius:22px}.menu-callout>div{padding:48px 25px}.menu-callout h2{font-size:51px}.menu-callout img{height:300px;display:block}footer{margin-bottom:71px;padding:46px 20px 20px;display:block}.footer-brand+ p{margin:32px 0}.footer-links{margin:34px 0}footer>span{display:block}.mobile-nav{position:fixed;z-index:3;bottom:0;left:0;right:0;height:71px;display:flex;justify-content:space-around;align-items:center;background:rgba(253,252,248,.94);backdrop-filter:blur(14px);border-top:1px solid #dde0d8}.mobile-nav a{font-size:19px;display:flex;flex-direction:column;align-items:center;gap:2px;color:#747a72}.mobile-nav small{font-size:9px;font-weight:600}.mobile-nav .active{color:#202d24}.mobile-nav .active:first-letter{background:#b5d83e;border-radius:12px;padding:1px 8px}}
</style>
