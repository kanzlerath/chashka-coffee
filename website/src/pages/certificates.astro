---
const values=['1 000 ₽','2 000 ₽','3 000 ₽','5 000 ₽']
---
<html lang="ru"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><title>Сертификаты — Чашка кофе</title></head><body><main><a class="brand" href="/"><img src="/brand/logo.png" alt=""/>Чашка кофе</a><section class="hero"><p>подарок со вкусом</p><h1>Дарите<br/>любимое</h1><span>Чашка кофе</span><a href="/app">Выбрать в приложении →</a></section><section><h2>Выберите номинал</h2><div class="cards">{values.map((value,i)=><article><b>ЧК</b><strong>{value}</strong><small>электронный сертификат</small></article>)}</div></section><section class="rules"><h2>Важное<br/>о сертификате</h2><div><p>Сертификат доступен в приложении.</p><p>Им можно оплатить покупки в «Чашке кофе».</p><p>Срок действия и правила — в приложении.</p><a href="/app">Открыть приложение →</a></div></section></main></body></html>
<style>@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap');:root{font-family:Montserrat,Arial,sans-serif;color:#1d241e;background:#f7f6f1}*{box-sizing:border-box}body{margin:0}.brand{height:94px;padding:0 6vw;display:flex;align-items:center;gap:10px;font-size:20px;font-weight:800;text-decoration:none;color:inherit}.brand img{width:45px;height:45px;object-fit:contain}.hero{margin:0 2vw;min-height:620px;border-radius:27px;padding:clamp(45px,7vw,112px);background:#b5d83d;color:#203025;position:relative;overflow:hidden}.hero p{font-size:12px;text-transform:uppercase;letter-spacing:.14em;font-weight:700}.hero h1,.rules h2,section>h2{margin:22px 0;font-size:clamp(62px,7vw,118px);line-height:.83;letter-spacing:-.11em}.hero span{position:absolute;right:-2vw;bottom:-7vw;font-size:clamp(120px,19vw,330px);font-weight:800;letter-spacing:-.15em;color:#f7f6f1;white-space:nowrap}.hero a,.rules a{display:inline-block;position:relative;margin-top:20px;padding:17px 21px;background:#203025;color:#fff;border-radius:999px;text-decoration:none;font-size:14px;font-weight:700}section:not(.hero){padding:clamp(90px,11vw,160px) 7vw}.cards{display:grid;grid-template-columns:repeat(4,1fr);gap:13px;margin-top:55px}.cards article{min-height:230px;padding:25px;border-radius:21px;background:#203025;color:#fff;display:flex;flex-direction:column}.cards article:nth-child(even){background:#e6dfd5;color:#203025}.cards b{font-size:43px;letter-spacing:-.15em}.cards strong{font-size:30px;letter-spacing:-.07em;margin:auto 0 7px}.cards small{font-size:11px}.rules{margin:0 2vw 2vw;border-radius:27px;background:#e5eadb;display:grid;grid-template-columns:1fr 1fr;gap:60px}.rules h2{font-size:clamp(48px,5vw,86px)}.rules p{padding:21px 0;border-bottom:1px solid #cbd3c6;font-size:17px;line-height:1.5;margin:0}@media(max-width:700px){.brand{height:72px;padding:0 20px}.hero{margin:0;min-height:530px;border-radius:0;padding:50px 20px}.hero h1{font-size:65px}.hero span{font-size:130px;right:-55px;bottom:-25px}.cards{grid-template-columns:1fr 1fr;gap:8px;margin-top:30px}.cards article{min-height:185px;padding:18px}.cards strong{font-size:24px}section:not(.hero){padding:82px 20px}.rules{margin:0;border-radius:0;display:block;padding:60px 20px!important}.rules h2{font-size:52px}}</style>
