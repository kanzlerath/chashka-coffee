---
import PageShell from '../layouts/PageShell.astro';
const values=['1 000 ₽','2 000 ₽','3 000 ₽','5 000 ₽'];
---
<PageShell title="Сертификаты"><section class="hero"><p>Подарок со вкусом</p><h1>Дарите<br/>любимое</h1><span>Чашка кофе</span><a href="/app">Выбрать в приложении →</a></section><section class="nominals"><h2>Выберите номинал</h2><div>{values.map((value)=><article><b>ЧК</b><strong>{value}</strong><small>Электронный сертификат</small></article>)}</div></section><section class="rules"><h2>Важное<br/>о сертификате</h2><div><p>Сертификат доступен в приложении.</p><p>Им можно оплатить покупки в «Чашке кофе».</p><p>Срок действия и правила — в приложении.</p><a href="/certificate-rules">Правила сертификатов →</a></div></section></PageShell>
<style>.hero{position:relative;min-height:620px;margin:0 2vw;padding:clamp(48px,7vw,112px);border-radius:27px;overflow:hidden;background:#b9dc3d;color:#20382b}.hero p{font-size:11px;text-transform:uppercase;letter-spacing:.14em;font-weight:800}.hero h1,.nominals h2,.rules h2{margin:22px 0;font-size:clamp(62px,7vw,118px);line-height:.83;letter-spacing:-.11em}.hero span{position:absolute;right:-2vw;bottom:-7vw;color:#f8f7f2;font-size:clamp(120px,19vw,330px);font-weight:800;letter-spacing:-.15em;white-space:nowrap}.hero a,.rules a{position:relative;display:inline-block;margin-top:20px;padding:17px 21px;border-radius:99px;background:#20382b;color:#fff;text-decoration:none;font-size:13px;font-weight:700}.nominals{padding:clamp(90px,11vw,160px) 7vw}.nominals>div{display:grid;grid-template-columns:repeat(4,1fr);gap:13px;margin-top:55px}.nominals article{min-height:230px;padding:25px;border-radius:21px;background:#20382b;color:#fff;display:flex;flex-direction:column}.nominals article:nth-child(even){background:#e6dfd5;color:#20382b}.nominals b{font-size:43px;letter-spacing:-.15em}.nominals strong{margin:auto 0 7px;font-size:30px;letter-spacing:-.07em}.nominals small{font-size:11px}.rules{margin:0 2vw;padding:clamp(52px,7vw,105px);border-radius:27px;background:#e5eadb;display:grid;grid-template-columns:1fr 1fr;gap:60px}.rules h2{font-size:clamp(48px,5vw,86px)}.rules p{margin:0;padding:21px 0;border-bottom:1px solid #cbd3c6;font-size:16px;line-height:1.5}@media(max-width:700px){.hero{margin:0;min-height:530px;padding:50px 20px;border-radius:0}.hero h1{font-size:65px}.hero span{font-size:130px;right:-55px;bottom:-25px}.nominals{padding:82px 20px}.nominals>div{grid-template-columns:1fr 1fr;gap:8px;margin-top:30px}.nominals article{min-height:185px;padding:18px}.nominals strong{font-size:24px}.rules{margin:0;padding:60px 20px;border-radius:0;display:block}.rules h2{font-size:52px}}</style>
