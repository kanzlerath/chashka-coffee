---
import PageShell from '../layouts/PageShell.astro';
import type { ContentEntry, HomepagePublicResponse, RestaurantSummary } from '@chashka-coffee/contracts';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
let homepage: HomepagePublicResponse | null = null
let promotions: ContentEntry[] = []
let events: ContentEntry[] = []
let articles: ContentEntry[] = []
let restaurants: RestaurantSummary[] = []

try {
  const [homepageResponse, promotionResponse, eventResponse, articleResponse, restaurantResponse] = await Promise.all([
    fetch(`${apiUrl}/api/homepage`),
    fetch(`${apiUrl}/api/content?type=PROMOTION`),
    fetch(`${apiUrl}/api/content?type=EVENT`),
    fetch(`${apiUrl}/api/content?type=ARTICLE`),
    fetch(`${apiUrl}/api/restaurants`),
  ])
  if (homepageResponse.ok) homepage = await homepageResponse.json()
  if (promotionResponse.ok) promotions = (await promotionResponse.json()).entries
  if (eventResponse.ok) events = (await eventResponse.json()).entries
  if (articleResponse.ok) articles = (await articleResponse.json()).entries
  if (restaurantResponse.ok) restaurants = (await restaurantResponse.json()).restaurants
} catch { /* Local fallbacks keep the public landing page complete before the API is available. */ }

const defaultSlides = [
  { mediaType: 'IMAGE', mediaUrl: '/images/home-morning-v2.png', posterUrl: null, eyebrow: 'С хорошего кофе', title: 'Начните день\nв своём ритме', description: 'Завтрак, любимый кофе и немного времени для себя.', ctaLabel: 'Открыть меню', ctaUrl: '/restaurants/krasny-prospekt/menu', durationSeconds: 7 },
  { mediaType: 'IMAGE', mediaUrl: '/images/home-breakfast.png', posterUrl: null, eyebrow: 'В каждом районе', title: 'Место, куда\nхочется зайти', description: 'Встретиться, поработать или просто сделать паузу.', ctaLabel: 'Найти кофейню', ctaUrl: '/restaurants', durationSeconds: 7 },
  { mediaType: 'IMAGE', mediaUrl: '/images/restaurants-hero.png', posterUrl: null, eyebrow: 'Любимое — ближе', title: 'Кофе и еда\nс доставкой', description: 'Привезём из ближайшей «Чашки кофе» бережно и вовремя.', ctaLabel: 'Заказать доставку', ctaUrl: '/delivery', durationSeconds: 7 },
]
const slides = homepage?.slides.length ? homepage.slides : defaultSlides
const productFallbacks = ['/images/home-breakfast.png', '/images/home-hero-v1.png', '/images/home-morning-v2.png', '/images/restaurants-hero.png']
const defaultBestsellers = [
  { slug: 'avocado-toast', name: 'Тост с авокадо', description: 'Хрустящий хлеб, авокадо и яйцо пашот.', price: '590 ₽', badge: 'хит', imageUrl: productFallbacks[0], categoryName: 'Завтраки' },
  { slug: 'cappuccino', name: 'Капучино', description: 'Эспрессо и воздушное молоко.', price: '290 ₽', badge: 'классика', imageUrl: productFallbacks[1], categoryName: 'Кофе' },
  { slug: 'ricotta-syrniki', name: 'Сырники из рикотты', description: 'С ягодным соусом и сметаной.', price: '490 ₽', badge: 'любимое', imageUrl: productFallbacks[2], categoryName: 'Завтраки' },
  { slug: 'filter-coffee', name: 'Фильтр-кофе', description: 'Сезонное зерно собственной обжарки.', price: '240 ₽', badge: 'новинка', imageUrl: productFallbacks[3], categoryName: 'Кофе' },
]
const bestsellers = homepage?.bestsellers.length
  ? homepage.bestsellers.map((entry, index) => ({ slug: entry.item.slug, name: entry.item.name, description: entry.item.description ?? 'Выбранная позиция из меню «Чашки кофе».', price: `${Math.round(entry.item.priceKopecks / 100)} ₽`, badge: entry.badge ?? entry.item.marketingBadge?.toLowerCase() ?? entry.item.categoryName, imageUrl: entry.item.imageUrl ?? productFallbacks[index % productFallbacks.length], categoryName: entry.item.categoryName }))
  : defaultBestsellers
const featuredPromotion = promotions.at(0) ?? null
const featuredEvent = events.at(0) ?? null
const journal = articles.slice(0, 3).length ? articles.slice(0, 3) : [
  { slug: 'coffee-morning', title: 'Кофе для первого тёплого утра', excerpt: 'Как выбрать напиток, который не спорит с вашим настроением.', imageUrl: '/images/home-breakfast.png' },
  { slug: 'croissant-now', title: 'Почему круассан лучше есть сразу', excerpt: 'Немного масла, много слоёв и один простой совет от кондитера.', imageUrl: '/images/home-hero-v1.png' },
  { slug: 'novosibirsk-route', title: 'Маршрут выходного дня по Новосибирску', excerpt: 'Парки, набережная и кофейни, в которых удобно сделать паузу.', imageUrl: '/images/restaurants-hero.png' },
]
const routeRestaurants = restaurants.filter((restaurant) => restaurant.city === 'Новосибирск').slice(0, 3)
const placeRows = routeRestaurants.length ? routeRestaurants : [
  { slug: 'krasny-prospekt', name: 'Чашка кофе — Красный проспект', address: 'Красный проспект, 25', openingHoursLabel: 'Пн–Пт: с 07:30', coverImageUrl: '/images/restaurants-hero.png' },
  { slug: 'central-park', name: 'Чашка кофе — Центральный парк', address: 'ул. Мичурина, 8', openingHoursLabel: 'Ежедневно: с 09:00', coverImageUrl: '/images/home-hero-v1.png' },
  { slug: 'ulitsa-lenina', name: 'Чашка кофе — улица Ленина', address: 'ул. Ленина, 12', openingHoursLabel: 'Пн–Пт: с 07:30', coverImageUrl: '/images/home-breakfast.png' },
]
const eventDate = featuredEvent?.eventStartsAt ? new Date(featuredEvent.eventStartsAt).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long' }) : 'Каждую неделю'
---

<PageShell title="Чашка кофе" description="Чашка кофе — сеть кофеен в Новосибирске: завтраки, десерты, кофе и места для хорошего дня." image="/images/home-morning-v2.png">
  <div class="home-page">
    <section class="home-gallery" data-home-gallery aria-label="Актуальное в Чашке кофе">
      <div class="gallery-stage">
        {slides.map((slide, index) => <article class:list={['gallery-slide', { 'is-active': index === 0 }]} data-duration={slide.durationSeconds} data-slide aria-hidden={index === 0 ? 'false' : 'true'}>
          {slide.mediaType === 'VIDEO'
            ? <video autoplay={index === 0} loop muted playsinline poster={slide.posterUrl ?? undefined} preload={index === 0 ? 'auto' : 'metadata'} src={slide.mediaUrl}></video>
            : <img src={slide.mediaUrl} alt="" fetchpriority={index === 0 ? 'high' : undefined} loading={index === 0 ? 'eager' : 'lazy'} />}
          <div class="gallery-shade"></div>
          <div class="gallery-copy">
            {slide.eyebrow && <p>{slide.eyebrow}</p>}
            <h1>{slide.title.split('\n').map((line) => <>{line}<br /></>)}</h1>
            {slide.description && <span>{slide.description}</span>}
            {slide.ctaLabel && slide.ctaUrl && <a href={slide.ctaUrl}>{slide.ctaLabel}<b>→</b></a>}
          </div>
        </article>)}
        <div class="gallery-controls"><button type="button" data-gallery-prev aria-label="Предыдущий слайд">←</button><div aria-label="Выбор слайда" class="gallery-dots">{slides.map((slide, index) => <button class:list={{ 'is-active': index === 0 }} type="button" data-gallery-dot={index} aria-label={`Слайд ${index + 1}: ${slide.title.replace('\n', ' ')}`}></button>)}</div><button type="button" data-gallery-next aria-label="Следующий слайд">→</button></div>
      </div>
    </section>

    <section class="home-bestsellers" aria-labelledby="bestsellers-title">
      <header class="section-heading"><div><p class="eyebrow">выбирают чаще всего</p><h2 id="bestsellers-title">Бестселлеры</h2></div><a href="/restaurants/krasny-prospekt/menu">Всё меню <span>→</span></a></header>
      <div class="bestseller-list">{bestsellers.map((item) => <a href="/restaurants/krasny-prospekt/menu" class="bestseller-card"><div class="bestseller-image"><img src={item.imageUrl} alt="" loading="lazy" /><span>{item.badge}</span></div><div class="bestseller-info"><small>{item.categoryName}</small><h3>{item.name}</h3><p>{item.description}</p><strong>{item.price}</strong></div></a>)}</div>
    </section>

    <section class="home-bento" aria-label="Разделы Чашки кофе">
      <a class="bento-card bento-app" href="/app"><div><p>Приложение</p><h2>Чашка кофе<br />в телефоне</h2></div><span class="round-arrow">↗</span><div class="bento-phone" aria-hidden="true"><b>ЧК</b><i>☕</i></div></a>
      <a class="bento-card bento-coffee" href="/coffee"><div><p>Кофе для дома</p><h2>Любимый<br />ритуал</h2></div><span class="round-arrow">↗</span><div class="coffee-pack" aria-hidden="true"><b>ЧК</b><small>зерно</small></div></a>
      <a class="bento-card bento-event" href={featuredEvent ? `/events/${featuredEvent.slug}` : '/events'}><div><p>{eventDate} · события</p><h2>{featuredEvent?.title ?? 'Вечер\nв Чашке'}</h2></div><span class="round-arrow">↗</span><i aria-hidden="true">♪</i></a>
      <a class="bento-card bento-promo" href={featuredPromotion ? `/promotions/${featuredPromotion.slug}` : '/promotions'}><div><p>Акции</p><h2>Повод зайти<br />сегодня</h2></div><span class="round-arrow">↗</span><strong>{featuredPromotion?.ctaLabel ?? 'new'}</strong></a>
      <a class="bento-card bento-bakery" href="/bakery"><div><p>Кондитерская</p><h2>Десерты<br />на каждый день</h2></div><span class="round-arrow">↗</span><i aria-hidden="true">◒</i></a>
      <a class="bento-card bento-certificates" href="/certificates"><div><p>Сертификаты</p><h2>Подарок,<br />который ждут</h2></div><span class="round-arrow">↗</span><i aria-hidden="true">✦</i></a>
    </section>

    <section class="home-moment" aria-labelledby="moment-title">
      <div class="moment-image"><img src={featuredPromotion?.imageUrl ?? '/images/home-breakfast.png'} alt="" loading="lazy" /></div>
      <div class="moment-copy"><p class="eyebrow">сейчас в чашке кофе</p><h2 id="moment-title">{featuredPromotion?.title ?? 'Вкус, который\nхочется поймать'}</h2><p>{featuredPromotion?.excerpt ?? 'Новые позиции, сезонные напитки и маленькие причины выбраться из дома.'}</p><a href={featuredPromotion ? `/promotions/${featuredPromotion.slug}` : '/promotions'}>Узнать больше <span>→</span></a></div>
    </section>

    <section class="home-menu" aria-labelledby="menu-title">
      <header class="section-heading"><div><p class="eyebrow">всё для хорошего дня</p><h2 id="menu-title">Меню по настроению</h2></div><a href="/restaurants/krasny-prospekt/menu">Открыть меню <span>→</span></a></header>
      <div class="menu-grid"><a class="menu-tile menu-main" href="/restaurants/krasny-prospekt/menu"><img src="/images/home-breakfast.png" alt="Завтрак" loading="lazy" /><span>Завтраки</span><b>Утро в Чашке кофе</b></a><a class="menu-tile menu-tile-coffee" href="/restaurants/krasny-prospekt/menu"><span>Кофе</span><i>☕</i></a><a class="menu-tile menu-tile-seasonal" href="/promotions"><span>Летние<br />хиты</span><strong>new</strong></a><a class="menu-tile menu-tile-hot" href="/restaurants/krasny-prospekt/menu"><span>Горячие<br />блюда</span><i>⌁</i></a><a class="menu-tile menu-tile-salad" href="/restaurants/krasny-prospekt/menu"><span>Закуски<br />и салаты</span><i>●</i></a><a class="menu-tile menu-tile-dessert" href="/bakery"><span>Десерты<br />и выпечка</span><i>✳</i></a></div>
    </section>

    <section class="home-route" aria-labelledby="route-title">
      <div class="route-main"><img src={placeRows[0].coverImageUrl ?? '/images/restaurants-hero.png'} alt="Интерьер кофейни" loading="lazy" /><div><p class="eyebrow">кофейни в новосибирске</p><h2 id="route-title">Городской<br />маршрут<br />за кофе</h2><a href="/restaurants">Все кофейни <span>→</span></a></div></div>
      <div class="route-list">{placeRows.map((restaurant) => <a href={`/restaurants/${restaurant.slug}`}><span>{restaurant.name.replace('Чашка кофе — ', '')}</span><small>{restaurant.address} · {restaurant.openingHoursLabel}</small><b class="round-arrow">↗</b></a>)}</div>
    </section>

    <section class="home-home-coffee" aria-labelledby="home-coffee-title"><div><p class="eyebrow">кофе для дома</p><h2 id="home-coffee-title">Заварите<br />свой момент</h2><p>Зерно, дрипы и капсулы для утра дома, офиса или дороги, которую вы выбираете сами.</p><a href="/coffee">Выбрать кофе <span>→</span></a></div><div class="home-coffee-visual" aria-hidden="true"><span>ЧК</span><small>зерно<br />для дома</small><i>☕</i></div></section>

    <section class="home-app-loyalty" aria-labelledby="loyalty-title"><div class="loyalty-copy"><p class="eyebrow">приложение и клуб друзей</p><h2 id="loyalty-title">Любимое —<br />под рукой</h2><p>Заказывайте быстрее, копите бонусы и узнавайте о новинках раньше всех.</p><a href="/app">О приложении <span>→</span></a></div><div class="loyalty-points"><strong>1<span>₽</span> = 1 балл</strong><p>Начисляем за любимые заказы</p><div><b>ЧК</b><i>●</i><i>●</i><i>●</i></div></div></section>

    <section class="home-journal" aria-labelledby="journal-title"><header class="section-heading"><div><p class="eyebrow">журнал чашка кофе</p><h2 id="journal-title">Читайте<br />медленнее</h2></div><a href="/journal">Все статьи <span>→</span></a></header><div class="journal-list">{journal.map((article, index) => <a href={`/journal/${article.slug}`} class:list={['journal-entry', { 'journal-featured': index === 0 }]}><img src={article.imageUrl ?? productFallbacks[index]} alt="" loading="lazy" /><div><small>журнал · {index + 1}</small><h3>{article.title}</h3><p>{article.excerpt}</p><span>Читать <b>→</b></span></div></a>)}</div></section>

    <div class="home-marquee" aria-label="Чашка кофе: кофе, завтраки, десерты и встречи"><div>ЧАШКА КОФЕ <i>✦</i> КОФЕ <i>✦</i> ЗАВТРАКИ <i>✦</i> ДЕСЕРТЫ <i>✦</i> ВСТРЕЧИ <i>✦</i> ЧАШКА КОФЕ <i>✦</i> КОФЕ <i>✦</i> ЗАВТРАКИ <i>✦</i> ДЕСЕРТЫ <i>✦</i> ВСТРЕЧИ <i>✦</i></div></div>
  </div>
</PageShell>

<script>
  const gallery = document.querySelector<HTMLElement>('[data-home-gallery]')
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)')
  if (gallery) {
    const slides = [...gallery.querySelectorAll<HTMLElement>('[data-slide]')]
    const dots = [...gallery.querySelectorAll<HTMLButtonElement>('[data-gallery-dot]')]
    const previous = gallery.querySelector<HTMLButtonElement>('[data-gallery-prev]')
    const next = gallery.querySelector<HTMLButtonElement>('[data-gallery-next]')
    let active = 0
    let timeout = 0
    let paused = false
    const show = (index: number) => {
      active = (index + slides.length) % slides.length
      slides.forEach((slide, slideIndex) => {
        const isActive = slideIndex === active
        slide.classList.toggle('is-active', isActive)
        slide.setAttribute('aria-hidden', String(!isActive))
        const video = slide.querySelector('video')
        if (!video) return
        if (isActive) void video.play().catch(() => undefined)
        else { video.pause(); video.currentTime = 0 }
      })
      dots.forEach((dot, dotIndex) => dot.classList.toggle('is-active', dotIndex === active))
      schedule()
    }
    const schedule = () => {
      window.clearTimeout(timeout)
      if (paused || reduceMotion.matches || slides.length < 2) return
      const duration = Number(slides[active]?.dataset.duration ?? 7) * 1_000
      timeout = window.setTimeout(() => show(active + 1), duration)
    }
    const pause = () => { paused = true; window.clearTimeout(timeout) }
    const resume = () => { paused = false; schedule() }
    previous?.addEventListener('click', () => show(active - 1))
    next?.addEventListener('click', () => show(active + 1))
    dots.forEach((dot, index) => dot.addEventListener('click', () => show(index)))
    gallery.addEventListener('mouseenter', pause)
    gallery.addEventListener('mouseleave', resume)
    gallery.addEventListener('focusin', pause)
    gallery.addEventListener('focusout', resume)
    document.addEventListener('visibilitychange', () => document.hidden ? pause() : resume())
    reduceMotion.addEventListener('change', schedule)
    schedule()
  }
</script>

<style>
