---
import PageShell from '../layouts/PageShell.astro';
import type { ContentEntry, HomepagePublicResponse, RestaurantSummary } from '@chashka-coffee/contracts';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
let homepage: HomepagePublicResponse | null = null
let promotions: ContentEntry[] = []
let events: ContentEntry[] = []
let articles: ContentEntry[] = []
let restaurants: RestaurantSummary[] = []

try {
  const [homepageResponse, promotionResponse, eventResponse, articleResponse, restaurantResponse] = await Promise.all([
    fetch(`${apiUrl}/api/homepage`),
    fetch(`${apiUrl}/api/content?type=PROMOTION`),
    fetch(`${apiUrl}/api/content?type=EVENT`),
    fetch(`${apiUrl}/api/content?type=ARTICLE`),
    fetch(`${apiUrl}/api/restaurants`),
  ])
  if (homepageResponse.ok) homepage = await homepageResponse.json()
  if (promotionResponse.ok) promotions = (await promotionResponse.json()).entries
  if (eventResponse.ok) events = (await eventResponse.json()).entries
  if (articleResponse.ok) articles = (await articleResponse.json()).entries
  if (restaurantResponse.ok) restaurants = (await restaurantResponse.json()).restaurants
} catch { /* The local fallback keeps the storefront complete before the API is available. */ }

const defaultSlides = [
  { mediaType: 'IMAGE', mediaUrl: '/images/home-morning-v2.png', posterUrl: null, eyebrow: 'С хорошего кофе', title: 'Начните день\nв своём ритме', description: 'Завтрак, любимый кофе и немного времени для себя.', ctaLabel: 'Открыть меню', ctaUrl: '/restaurants/krasny-prospekt/menu', durationSeconds: 7 },
  { mediaType: 'IMAGE', mediaUrl: '/images/home-breakfast.png', posterUrl: null, eyebrow: 'В каждом районе', title: 'Место, куда\nхочется зайти', description: 'Встретиться, поработать или просто сделать паузу.', ctaLabel: 'Найти кофейню', ctaUrl: '/restaurants', durationSeconds: 7 },
  { mediaType: 'IMAGE', mediaUrl: '/images/restaurants-hero.png', posterUrl: null, eyebrow: 'Любимое — ближе', title: 'Кофе и еда\nс доставкой', description: 'Привезём из ближайшей «Чашки кофе» бережно и вовремя.', ctaLabel: 'Заказать доставку', ctaUrl: '/delivery', durationSeconds: 7 },
]
const slides = homepage?.slides.length ? homepage.slides : defaultSlides
const productFallbacks = ['/images/home-breakfast.png', '/images/home-hero-v1.png', '/images/home-morning-v2.png', '/images/restaurants-hero.png']
const badgeLabel = (value: string | null | undefined) => ({ NEW: 'Новинка', HIT: 'Хит', SEASONAL: 'Сезонное', SPECIAL: 'Специальное' }[value ?? ''] ?? value ?? null)
const outputLabel = (weightGrams: number | null) => weightGrams ? `${weightGrams} г` : '1 порция'
const defaultBestsellers = [
  { slug: 'avocado-toast', name: 'Тост с авокадо', price: '590 ₽', output: '260 г', badge: 'Хит', imageUrl: productFallbacks[0], categoryName: 'Завтраки' },
  { slug: 'cappuccino', name: 'Капучино', price: '290 ₽', output: '300 мл', badge: 'Классика', imageUrl: productFallbacks[1], categoryName: 'Кофе' },
  { slug: 'ricotta-syrniki', name: 'Сырники из рикотты', price: '490 ₽', output: '220 г', badge: 'Любимое', imageUrl: productFallbacks[2], categoryName: 'Завтраки' },
  { slug: 'filter-coffee', name: 'Фильтр-кофе', price: '240 ₽', output: '250 мл', badge: 'Новинка', imageUrl: productFallbacks[3], categoryName: 'Кофе' },
]
const bestsellers = homepage?.bestsellers.length
  ? homepage.bestsellers.map((entry, index) => ({
      slug: entry.item.slug,
      name: entry.item.name,
      price: `${Math.round(entry.item.priceKopecks / 100)} ₽`,
      output: outputLabel(entry.item.weightGrams),
      badge: badgeLabel(entry.badge ?? entry.item.marketingBadge),
      imageUrl: entry.item.imageUrl ?? productFallbacks[index % productFallbacks.length],
      categoryName: entry.item.categoryName,
    }))
  : defaultBestsellers
const featuredPromotion = promotions.at(0) ?? null
const featuredEvent = events.at(0) ?? null
const journal = articles.slice(0, 2).length ? articles.slice(0, 2) : [
  { slug: 'coffee-morning', title: 'Кофе для первого тёплого утра', excerpt: 'Как выбрать напиток, который не спорит с вашим настроением.', imageUrl: '/images/home-breakfast.png' },
  { slug: 'croissant-now', title: 'Почему круассан лучше есть сразу', excerpt: 'Немного масла, много слоёв и один простой совет от кондитера.', imageUrl: '/images/home-hero-v1.png' },
]
const fallbackPlaces: RestaurantSummary[] = [
  { id: '019a2f17-453e-7c1a-9c04-4e468e7eb514', slug: 'krasny-prospekt', name: 'Чашка кофе — Красный проспект', format: 'CITY', area: 'CITY', isAtApartHotel: false, city: 'Новосибирск', address: 'Красный проспект, 25', phone: '+7 (383) 123-20-20', openingHoursLabel: 'Пн–Вс: 07:30–23:00', coverImageUrl: '/images/restaurants-hero.png' },
  { id: '019a2f17-453e-7c1a-9c04-4e468e7eb515', slug: 'tolmachevo-domestic', name: 'Чашка кофе — Толмачёво, вылеты по России', format: 'AIRPORT', area: 'AIRPORT', isAtApartHotel: false, city: 'Обь', address: 'Аэропорт Толмачёво, сектор A', phone: '+7 (383) 123-20-30', openingHoursLabel: 'Ежедневно:  круглосуточно', coverImageUrl: '/images/home-hero-v1.png' },
]
const availablePlaces = restaurants.length ? restaurants : fallbackPlaces
const cityPlaces = availablePlaces.filter((place) => place.area !== 'AIRPORT')
const airportPlaces = availablePlaces.filter((place) => place.area === 'AIRPORT')
const placeGroups = [
  { id: 'city', label: 'Город', places: cityPlaces },
  { id: 'airport', label: 'Аэропорт', places: airportPlaces },
]
const allPlaces = placeGroups.flatMap((group) => group.places.map((place) => ({ ...place, group: group.id })))
const eventTitle = featuredEvent?.title ?? 'Вечер в Чашке'
---

<PageShell title="Чашка кофе" description="Чашка кофе — сеть кофеен в Новосибирске: завтраки, десерты, кофе и места для хорошего дня." image="/images/home-morning-v2.png">
  <div class="home-page">
    <section class="home-stories" data-home-stories aria-label="Актуальное в Чашке кофе">
      <div class="stories-media">
        {slides.map((slide, index) => <article class:list={['story-media-item', { 'is-active': index === 0 }]} data-story-media aria-hidden={index === 0 ? 'false' : 'true'}>
          {slide.mediaType === 'VIDEO'
            ? <video autoplay={index === 0} loop muted playsinline poster={slide.posterUrl ?? undefined} preload={index === 0 ? 'auto' : 'metadata'} src={slide.mediaUrl}></video>
            : <img src={slide.mediaUrl} alt="" fetchpriority={index === 0 ? 'high' : undefined} loading={index === 0 ? 'eager' : 'lazy'} />}
        </article>)}
        <div class="story-progress" aria-label="Выбор истории">
          {slides.map((slide, index) => <button class:list={{ 'is-active': index === 0 }} type="button" data-story-control={index} style={`--story-duration:${slide.durationSeconds}s`} aria-label={`История ${index + 1}: ${slide.title.replace('\n', ' ')}`}></button>)}
        </div>
      </div>
      <div class="stories-copy">
        {slides.map((slide, index) => <article class:list={['story-copy-item', { 'is-active': index === 0 }]} data-story-copy aria-hidden={index === 0 ? 'false' : 'true'}>
          {slide.eyebrow && <p class="story-kicker">{slide.eyebrow}</p>}
          <h1>{slide.title.split('\n').map((line) => <>{line}<br /></>)}</h1>
          {slide.description && <p class="story-description">{slide.description}</p>}
          {slide.ctaLabel && slide.ctaUrl && <a class="ui-button ui-button--fill" href={slide.ctaUrl}>{slide.ctaLabel}</a>}
        </article>)}
      </div>
    </section>

    <section class="home-bestsellers home-section" aria-labelledby="bestsellers-title">
      <header class="home-section-head"><div><h2 id="bestsellers-title">Бестселлеры</h2><p>Выбирают чаще всего</p></div></header>
      <div class="bestseller-list">{bestsellers.map((item) => <a href="/restaurants/krasny-prospekt/menu" class="product-card"><div class="product-card-image"><img src={item.imageUrl} alt="" loading="lazy" />{item.badge && <span>{item.badge}</span>}</div><div class="product-card-info"><small>{item.categoryName}</small><h3>{item.name}</h3><div><span>{item.output}</span><strong>{item.price}</strong></div></div></a>)}</div>
      <a class="ui-button ui-button--outline section-action" href="/restaurants/krasny-prospekt/menu">Смотреть все</a>
    </section>

    <section class="home-bento" aria-label="Разделы Чашки кофе">
      <a class="bento-card bento-app" href="/app"><h2>Приложение<br />«Чашка кофе»</h2><div class="bento-art bento-phone" aria-hidden="true"><b>ЧК</b><i>☕</i></div></a>
      <a class="bento-card bento-coffee" href="/coffee"><h2>Кофе<br />для дома</h2><div class="bento-art coffee-pack" aria-hidden="true"><b>ЧК</b><small>зерно</small></div></a>
      <a class="bento-card bento-event" href={featuredEvent ? `/events/${featuredEvent.slug}` : '/events'}><h2>{eventTitle}</h2><i class="event-note" aria-hidden="true">♪</i></a>
      <a class="bento-card bento-promo" href={featuredPromotion ? `/promotions/${featuredPromotion.slug}` : '/promotions'}><h2>Акции<br />и новинки</h2><strong>{featuredPromotion?.ctaLabel ?? '−20%'}</strong></a>
      <a class="bento-card bento-bakery" href="/bakery"><h2>Кондитерская</h2><i aria-hidden="true">◒</i></a>
      <a class="bento-card bento-certificates" href="/certificates"><h2>Сертификаты</h2><i aria-hidden="true">✦</i></a>
    </section>

    <section class="home-day" aria-labelledby="day-title">
      <div class="day-intro"><p class="story-kicker">День в Чашке кофе</p><h2 id="day-title">Поводы<br />зайти сегодня</h2><p>Сначала завтрак, потом встреча, а вечером — время для себя. Выбирайте свой ритм.</p></div>
      <div class="day-stops">
        <a href="/restaurants/krasny-prospekt/menu"><small>Утро</small><h3>Завтраки<br />до 12:00</h3><p>Медленные утра и кофе, который не нужно торопить.</p></a>
        <a href="/restaurants"><small>Днём</small><h3>Встречи<br />в городе</h3><p>Кофейня рядом, когда нужно место для своих людей.</p></a>
        <a href={featuredEvent ? `/events/${featuredEvent.slug}` : '/events'}><small>Вечером</small><h3>События<br />и музыка</h3><p>Поводы задержаться дольше обычного.</p></a>
      </div>
    </section>

    <section class="home-menu home-section" aria-labelledby="menu-title">
      <header class="home-section-head"><div><h2 id="menu-title">Меню по настроению</h2><p>Всё, что хочется сегодня</p></div></header>
      <div class="menu-grid">
        <a class="menu-tile menu-main" href="/restaurants/krasny-prospekt/menu"><img src="/images/home-breakfast.png" alt="Завтраки" loading="lazy" /><span>Завтраки</span></a>
        <a class="menu-tile menu-tile-coffee" href="/restaurants/krasny-prospekt/menu"><span>Кофе</span><i aria-hidden="true">☕</i></a>
        <a class="menu-tile menu-tile-seasonal" href="/promotions"><span>Летние<br />хиты</span><strong>new</strong></a>
        <a class="menu-tile menu-tile-hot" href="/restaurants/krasny-prospekt/menu"><span>Горячие<br />блюда</span><i aria-hidden="true">⌁</i></a>
        <a class="menu-tile menu-tile-salad" href="/restaurants/krasny-prospekt/menu"><span>Закуски<br />и салаты</span><i aria-hidden="true">●</i></a>
        <a class="menu-tile menu-tile-dessert" href="/bakery"><span>Десерты<br />и выпечка</span><i aria-hidden="true">✳</i></a>
        <a class="menu-all" href="/restaurants/krasny-prospekt/menu"><span>Посмотреть все блюда</span><b aria-hidden="true">↑</b></a>
      </div>
    </section>

    <section class="home-places home-section" data-home-places aria-labelledby="places-title">
      <header class="home-section-head places-heading"><div><h2 id="places-title">Кофейни в городе</h2><p>Места, в которые хочется возвращаться</p></div><div class="place-filters" role="tablist" aria-label="Формат кофейни">{placeGroups.map((group, index) => <button class:list={{ 'is-active': index === 0 }} data-place-filter={group.id} type="button" role="tab" aria-selected={index === 0}>{group.label}</button>)}</div></header>
      <div class="places-stage">
        <div class="place-feature">
          {allPlaces.map((place, index) => <article class:list={{ 'is-active': index === 0 }} data-place-panel={place.slug} data-place-group={place.group}>
            <img src={place.coverImageUrl ?? productFallbacks[index % productFallbacks.length]} alt="" loading="lazy" />
            <div><p>{place.group === 'airport' ? 'Аэропорт' : 'Город'}</p><h3>{place.name.replace('Чашка кофе — ', '')}</h3><span>{place.address}<br />{place.openingHoursLabel}</span><a class="ui-button ui-button--fill" href={`/restaurants/${place.slug}`}>Открыть кофейню</a></div>
          </article>)}
        </div>
        <div class="place-list">
          {placeGroups.map((group) => <div data-place-list-group={group.id}>{group.places.map((place) => <button data-place-button={place.slug} type="button"><span>{place.name.replace('Чашка кофе — ', '')}</span><small>{place.address}</small></button>)}</div>)}
        </div>
      </div>
      <a class="ui-button ui-button--outline section-action" href="/restaurants">Все кофейни</a>
    </section>

    <section class="home-home-coffee" aria-labelledby="home-coffee-title"><div><p class="story-kicker">Кофе для дома</p><h2 id="home-coffee-title">Заварите<br />свой момент</h2><p>Зерно, дрипы и капсулы для утра дома, офиса или дороги, которую вы выбираете сами.</p><a class="ui-button ui-button--fill" href="/coffee">Выбрать кофе</a></div><div class="home-coffee-visual" aria-hidden="true"><span>ЧК</span><small>зерно<br />для дома</small><i>☕</i></div></section>

    <section class="home-app-loyalty" aria-labelledby="loyalty-title"><div class="loyalty-copy"><p class="story-kicker">Приложение и клуб друзей</p><h2 id="loyalty-title">Любимое —<br />под рукой</h2><p>Заказывайте быстрее, копите бонусы и узнавайте о новинках раньше всех.</p><a class="ui-button ui-button--fill" href="/app">О приложении</a></div><div class="loyalty-points"><strong>1<span>₽</span> = 1 балл</strong><p>Начисляем за любимые заказы</p><div><b>ЧК</b><i></i><i></i><i></i></div></div></section>

    <section class="home-journal home-section" aria-labelledby="journal-title"><header class="home-section-head"><div><h2 id="journal-title">Читайте медленнее</h2><p>Истории о кофе, людях и городе</p></div></header><div class="journal-list">{journal.map((article, index) => <a href={`/journal/${article.slug}`} class="journal-card"><img src={article.imageUrl ?? productFallbacks[index]} alt="" loading="lazy" /><div><small>Журнал · {index + 1}</small><h3>{article.title}</h3><p>{article.excerpt}</p><span>Читать далее</span></div></a>)}</div><a class="ui-button ui-button--outline section-action" href="/journal">Посмотреть все</a></section>

    <div class="home-marquee" aria-label="Чашка кофе: кофе, завтраки, десерты и встречи"><div>ЧАШКА КОФЕ <i>✦</i> КОФЕ <i>✦</i> ЗАВТРАКИ <i>✦</i> ДЕСЕРТЫ <i>✦</i> ВСТРЕЧИ <i>✦</i> ЧАШКА КОФЕ <i>✦</i> КОФЕ <i>✦</i> ЗАВТРАКИ <i>✦</i> ДЕСЕРТЫ <i>✦</i> ВСТРЕЧИ <i>✦</i></div></div>
  </div>
</PageShell>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)')
  const stories = document.querySelector<HTMLElement>('[data-home-stories]')

  if (stories) {
    const media = [...stories.querySelectorAll<HTMLElement>('[data-story-media]')]
    const copy = [...stories.querySelectorAll<HTMLElement>('[data-story-copy]')]
    const controls = [...stories.querySelectorAll<HTMLButtonElement>('[data-story-control]')]
    let active = 0
    let timeout = 0
    let paused = false

    const schedule = () => {
      window.clearTimeout(timeout)
      if (paused || reduceMotion.matches || media.length < 2) return
      const control = controls[active]
      const duration = Number(control?.style.getPropertyValue('--story-duration').replace('s', '') ?? 7) * 1_000
      timeout = window.setTimeout(() => show(active + 1), duration)
    }
    const show = (index: number) => {
      active = (index + media.length) % media.length
      media.forEach((item, itemIndex) => {
        const isActive = itemIndex === active
        item.classList.toggle('is-active', isActive)
        item.setAttribute('aria-hidden', String(!isActive))
        const video = item.querySelector('video')
        if (!video) return
        if (isActive) void video.play().catch(() => undefined)
        else { video.pause(); video.currentTime = 0 }
      })
      copy.forEach((item, itemIndex) => { item.classList.toggle('is-active', itemIndex === active); item.setAttribute('aria-hidden', String(itemIndex !== active)) })
      controls.forEach((control, controlIndex) => control.classList.toggle('is-active', controlIndex === active))
      schedule()
    }
    const pause = () => { paused = true; window.clearTimeout(timeout) }
    const resume = () => { paused = false; schedule() }
    controls.forEach((control, index) => control.addEventListener('click', () => show(index)))
    stories.addEventListener('mouseenter', pause)
    stories.addEventListener('mouseleave', resume)
    stories.addEventListener('focusin', pause)
    stories.addEventListener('focusout', resume)
    document.addEventListener('visibilitychange', () => document.hidden ? pause() : resume())
    reduceMotion.addEventListener('change', schedule)
    schedule()
  }

  const places = document.querySelector<HTMLElement>('[data-home-places]')
  if (places) {
    const filters = [...places.querySelectorAll<HTMLButtonElement>('[data-place-filter]')]
    const panels = [...places.querySelectorAll<HTMLElement>('[data-place-panel]')]
    const groups = [...places.querySelectorAll<HTMLElement>('[data-place-list-group]')]
    const rows = [...places.querySelectorAll<HTMLButtonElement>('[data-place-button]')]
    const select = (slug: string) => {
      panels.forEach((panel) => panel.classList.toggle('is-active', panel.dataset.placePanel === slug))
      rows.forEach((row) => row.classList.toggle('is-active', row.dataset.placeButton === slug))
    }
    const filter = (group: string) => {
      filters.forEach((button) => { const active = button.dataset.placeFilter === group; button.classList.toggle('is-active', active); button.setAttribute('aria-selected', String(active)) })
      groups.forEach((list) => list.hidden = list.dataset.placeListGroup !== group)
      const first = panels.find((panel) => panel.dataset.placeGroup === group)
      if (first?.dataset.placePanel) select(first.dataset.placePanel)
    }
    filters.forEach((button) => button.addEventListener('click', () => filter(button.dataset.placeFilter ?? 'city')))
    rows.forEach((row) => row.addEventListener('click', () => row.dataset.placeButton && select(row.dataset.placeButton)))
  }
</script>

