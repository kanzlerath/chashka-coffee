---
import PageShell from '../layouts/PageShell.astro';

type FeaturedEntry = {
  slug: string;
  title: string;
  excerpt: string | null;
  ctaLabel: string | null;
  eventStartsAt: string | null;
}

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
let featuredEvent: FeaturedEntry | null = null
let featuredPromotion: FeaturedEntry | null = null

try {
  const [eventsResponse, promotionsResponse] = await Promise.all([
    fetch(`${apiUrl}/api/content?type=EVENT`),
    fetch(`${apiUrl}/api/content?type=PROMOTION`),
  ])
  if (eventsResponse.ok) featuredEvent = (await eventsResponse.json()).entries.at(0) ?? null
  if (promotionsResponse.ok) featuredPromotion = (await promotionsResponse.json()).entries.at(0) ?? null
} catch { /* Editorial fallbacks keep the local website complete without the API. */ }

const eventDate = featuredEvent?.eventStartsAt
  ? new Date(featuredEvent.eventStartsAt).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long' })
  : 'Каждую неделю'
---

<PageShell
  title="Чашка кофе"
  description="Чашка кофе — сеть кофеен в Новосибирске: завтраки, десерты, кофе и места для хорошего дня."
  image="/images/home-morning-v2.png"
>
  <div class="home-page">
    <section class="home-hero" aria-labelledby="page-title">
      <img src="/images/home-morning-v2.png" alt="Капучино и круассан в светлой кофейне" fetchpriority="high" />
      <div class="home-hero-copy">
        <p class="eyebrow">Чашка кофе · Новосибирск</p>
        <h1 id="page-title">День начинается<br />с любимого места</h1>
        <p class="home-lead">Кофе, завтраки и время для себя — в городе, который всегда куда-то спешит.</p>
        <div class="home-hero-actions">
          <a class="button button-dark" href="/restaurants/krasny-prospekt/menu">Выбрать меню <span>→</span></a>
          <a class="text-action" href="/restaurants">Найти кофейню <span>↗</span></a>
        </div>
      </div>
      <div class="home-hero-meta" aria-label="Ключевая информация">
        <p>Кофе, завтраки,<br />десерты и встречи</p>
        <a href="/about">О «Чашке кофе» <span>↗</span></a>
      </div>
    </section>

    <section class="home-route" aria-labelledby="route-title">
      <header class="home-route-heading">
        <p class="eyebrow">с чего начнём?</p>
        <h2 id="route-title">Выберите свой<br />сценарий</h2>
      </header>
      <nav class="home-route-links" aria-label="Основные разделы">
        <a href="/delivery"><span>01</span><strong>Заказать<br />доставку</strong><small>Любимые блюда — домой или в офис</small><b>→</b></a>
        <a href="/restaurants/krasny-prospekt/menu"><span>02</span><strong>Открыть<br />меню</strong><small>Завтраки, обеды и десерты</small><b>→</b></a>
        <a href="/restaurants"><span>03</span><strong>Найти<br />кофейню</strong><small>13 точек по всему городу</small><b>→</b></a>
        <a href="/loyalty"><span>04</span><strong>Зайти<br />в клуб</strong><small>Бонусы и привилегии для друзей</small><b>→</b></a>
      </nav>
    </section>

    <section class="home-showcase" aria-label="Главные возможности Чашки кофе">
      <a class="showcase-menu" href="/restaurants/krasny-prospekt/menu">
        <img src="/images/home-hero-v1.png" alt="Кофе и свежая выпечка" loading="lazy" />
        <div><p>Выбирайте своё</p><h2>Меню<br />на каждый час</h2><span>Завтраки, обеды, кофе и десерты <b>→</b></span></div>
      </a>
      <a class="showcase-delivery" href="/delivery">
        <div class="showcase-mark" aria-hidden="true">↗</div>
        <p>Доставка</p><h2>Любимое —<br />ближе</h2><span>Кофе и еда из ближайшей кофейни <b>→</b></span>
      </a>
      <a class="showcase-places" href="/restaurants">
        <img src="/images/restaurants-hero.png" alt="Светлый интерьер кофейни" loading="lazy" />
        <div><p>Кофейни</p><h2>Всегда<br />по пути</h2><span>Посмотреть на карте <b>→</b></span></div>
      </a>
    </section>

    <section class="home-places" aria-labelledby="places-title">
      <div class="home-places-copy">
        <p class="eyebrow">13 кофеен в новосибирске</p>
        <h2 id="places-title">Место<br />для своего<br />ритма</h2>
        <p>Забежать за фильтром, встретиться с друзьями или задержаться на длинный завтрак — выбирайте точку рядом с вами.</p>
        <a class="button button-dark" href="/restaurants">Все кофейни <span>→</span></a>
      </div>
      <div class="home-place-list">
        <a href="/restaurants/krasny-prospekt"><span>01</span><div><strong>Красный проспект</strong><small>Городская кофейня · с 07:30</small></div><b>↗</b></a>
        <a href="/restaurants"><span>02</span><div><strong>Парк Победы</strong><small>Кофе для прогулки · с 09:00</small></div><b>↗</b></a>
        <a href="/restaurants"><span>03</span><div><strong>Аэропорт Толмачёво</strong><small>Перед вылетом · с 06:00</small></div><b>↗</b></a>
      </div>
    </section>

    <section class="home-now" aria-labelledby="now-title">
      <header><p class="eyebrow">в чашке кофе сегодня</p><h2 id="now-title">Есть повод<br />заглянуть</h2></header>
      <div class="home-now-items">
        <a class="home-event" href={featuredEvent ? `/events/${featuredEvent.slug}` : '/events'}>
          <p>{eventDate} · события</p>
          <h3>{featuredEvent?.title ?? 'Вечера, которые хочется не спешить'}</h3>
          <span>{featuredEvent?.excerpt ?? 'Музыка, встречи и маленькие поводы остаться за кофе подольше.'}</span>
          <b>Смотреть афишу →</b>
          <i aria-hidden="true">♪</i>
        </a>
        <a class="home-promo" href={featuredPromotion ? `/promotions/${featuredPromotion.slug}` : '/promotions'}>
          <div><p>Акции и новинки</p><h3>{featuredPromotion?.title ?? 'Новые вкусы уже в меню'}</h3><span>{featuredPromotion?.excerpt ?? 'Собрали сезонные предложения, ради которых стоит заглянуть сегодня.'}</span><b>Все предложения →</b></div>
          <strong>{featuredPromotion?.ctaLabel ?? 'new'}</strong>
        </a>
      </div>
    </section>

    <section class="home-app" aria-labelledby="app-title">
      <div class="home-app-copy">
        <p class="eyebrow">чашка кофе в телефоне</p>
        <h2 id="app-title">Нужное —<br />под рукой</h2>
        <p>Заказывайте быстрее, копите бонусы и первыми узнавайте о том, что появляется в любимой кофейне.</p>
        <a class="button button-dark" href="/app">О приложении <span>→</span></a>
      </div>
      <div class="home-app-object" aria-hidden="true">
        <div class="app-phone"><i></i><span>ЧК</span><small>Доброе утро</small><b>Что будем<br />сегодня?</b><em>☕</em></div>
        <div class="app-note">Кофе<br />по пути <strong>↗</strong></div>
      </div>
    </section>
  </div>
</PageShell>

<style>
