---
import PageShell from '../layouts/PageShell.astro';

type FeaturedEntry = { slug: string; title: string; excerpt: string | null; ctaLabel: string | null; eventStartsAt: string | null }
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
let featuredEvent: FeaturedEntry | null = null
let featuredPromotion: FeaturedEntry | null = null

try {
  const [eventsResponse, promotionsResponse] = await Promise.all([
    fetch(`${apiUrl}/api/content?type=EVENT`),
    fetch(`${apiUrl}/api/content?type=PROMOTION`),
  ])
  if (eventsResponse.ok) featuredEvent = (await eventsResponse.json()).entries.at(0) ?? null
  if (promotionsResponse.ok) featuredPromotion = (await promotionsResponse.json()).entries.at(0) ?? null
} catch { /* editorial fallback remains available when the local API is unavailable */ }

const eventDate = featuredEvent?.eventStartsAt
  ? new Date(featuredEvent.eventStartsAt).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long' })
  : '24 мая'
---

<PageShell title="Чашка кофе" description="Чашка кофе — сеть кофеен в Новосибирске: завтраки, десерты, кофе и места для хорошего дня.">
  <div class="home">
    <section class="home-hero" aria-labelledby="page-title">
      <img src="/images/home-breakfast.png" alt="Капучино и круассан на светлом столе" />
      <div class="home-hero-copy">
        <p class="home-kicker">Новосибирск · с 2006 года</p>
        <h1 id="page-title">Хороший день<br />начинается<br />с хорошего кофе</h1>
        <p>Свежая выпечка, авторские блюда и любимый кофе — каждый день рядом.</p>
        <div class="home-actions">
          <a class="home-button home-button-dark" href="/restaurants/krasny-prospekt/menu">Смотреть меню <span>→</span></a>
          <a class="home-inline-link" href="/restaurants">Найти кофейню <span>↗</span></a>
        </div>
      </div>
      <div class="home-hero-pagination" aria-hidden="true"><i></i><i></i><i></i></div>
    </section>

    <section class="home-delivery" aria-label="Доставка">
      <div class="home-delivery-icon" aria-hidden="true">↗</div>
      <div><p>Любимое — ближе</p><h2>Доставка из ресторанов</h2><span>Привезём завтрак, кофе или десерт бережно и вовремя.</span></div>
      <a class="home-button home-button-light" href="/delivery">Заказать доставку <span>→</span></a>
    </section>

    <section class="home-index" aria-labelledby="home-index-title">
      <div class="home-section-heading"><p class="home-kicker">всё для хорошего дня</p><h2 id="home-index-title">Выберите<br />свой повод</h2></div>
      <div class="home-index-links">
        <a href="/restaurants"><b>01</b><span>⌖</span><strong>Кофейни</strong><small>Адреса и время работы</small><i>↗</i></a>
        <a href="/restaurants/krasny-prospekt/menu"><b>02</b><span>⌇</span><strong>Меню</strong><small>Завтраки, десерты, кофе</small><i>↗</i></a>
        <a href="/app"><b>03</b><span>▣</span><strong>Приложение</strong><small>Заказ и клуб друзей</small><i>↗</i></a>
        <a href="/loyalty"><b>04</b><span>✦</span><strong>Клуб друзей</strong><small>Бонусы и привилегии</small><i>↗</i></a>
      </div>
    </section>

    <section class="home-feature-grid" aria-label="Главные разделы">
      <a class="home-feature home-feature-menu" href="/restaurants/krasny-prospekt/menu">
        <img src="/images/home-hero-v1.png" alt="Кофе и выпечка" loading="lazy" />
        <div><p>Меню</p><h2>Завтраки,<br />кофе и десерты</h2><span>Открыть меню <b>→</b></span></div>
      </a>
      <a class="home-feature home-feature-places" href="/restaurants">
        <div><p>Кофейни</p><h2>13 мест<br />в городе</h2><span>Найти рядом <b>→</b></span></div>
        <img src="/images/restaurants-hero.png" alt="Интерьер кофейни" loading="lazy" />
      </a>
      <a class="home-feature home-feature-app" href="/app">
        <div><p>Приложение</p><h2>Любимое<br />в телефоне</h2><span>Быстрый заказ и бонусы</span></div>
        <div class="home-phone" aria-hidden="true"><i></i><b>ЧК</b><small>Доброе утро</small><strong>Что будем<br />сегодня?</strong><em>☕</em></div>
      </a>
    </section>

    <section class="home-today" aria-labelledby="today-title">
      <div class="home-today-heading"><p class="home-kicker">сегодня в чашке кофе</p><h2 id="today-title">Есть повод<br />заглянуть</h2></div>
      <div class="home-today-list">
        <a href={featuredPromotion ? `/promotions/${featuredPromotion.slug}` : '/promotions'} class="home-today-promo">
          <p>Акции и новинки</p><h3>{featuredPromotion?.title ?? 'Маленькие поводы зайти'}</h3><span>{featuredPromotion?.excerpt ?? 'Любимые позиции, сезонные вкусы и предложения на каждый день.'}</span><strong>{featuredPromotion?.ctaLabel ?? '−20%'}</strong><b>Смотреть акции →</b>
        </a>
        <a href={featuredEvent ? `/events/${featuredEvent.slug}` : '/events'} class="home-today-event">
          <div><p>{eventDate} · события</p><h3>{featuredEvent?.title ?? 'Вечер джаза в парке'}</h3><span>{featuredEvent?.excerpt ?? 'Живая музыка, кофе и длинный вечер в хорошей компании.'}</span><b>Смотреть афишу →</b></div><i aria-hidden="true">♪</i>
        </a>
      </div>
    </section>

    <section class="home-locations" aria-labelledby="locations-title">
      <div class="home-locations-copy"><p class="home-kicker">рядом с вами</p><h2 id="locations-title">Кофе —<br />по пути</h2><p>В центре города, в парках, у набережной и перед вылетом. Выбирайте удобную точку и приходите в гости.</p><a class="home-button home-button-dark" href="/restaurants">Все кофейни <span>→</span></a></div>
      <div class="home-location-tabs"><a href="/restaurants?area=CITY"><b>В городе</b><span>7 кофеен</span></a><a href="/restaurants?area=PARK"><b>В парках</b><span>3 кофейни</span></a><a href="/restaurants?area=AIRPORT"><b>В аэропорту</b><span>3 кофейни</span></a></div>
    </section>

    <section class="home-app-cta" aria-labelledby="app-title">
      <div><p class="home-kicker">чашка кофе — в телефоне</p><h2 id="app-title">Больше любимого<br />в приложении</h2><p>Заказывайте быстрее, копите бонусы и первыми узнавайте о новинках.</p><a class="home-button home-button-dark" href="/app">Скачать приложение <span>→</span></a></div>
      <div class="home-app-visual" aria-hidden="true"><div class="home-app-cup">☕</div><span>ЧК</span></div>
    </section>
  </div>
</PageShell>

