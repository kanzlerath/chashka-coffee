:300px}.location strong{font-size:30px}.location b{right:18px;bottom:18px}.app-cta{margin:0 12px 68px;border-radius:24px;min-height:690px;padding:48px 25px 0;display:block}.app-copy h2{font-size:51px}.app-phone{margin:46px auto -70px;transform:rotate(6deg) scale(.86);transform-origin:bottom center}.site-footer{padding:45px 20px 0;margin-bottom:71px}.footer-top{display:block}.footer-top>p{font-size:30px;margin-top:32px}.footer-grid{grid-template-columns:1fr 1fr;padding:54px 0;gap:45px 15px}.footer-action{grid-column:1/-1}.footer-bottom{flex-wrap:wrap}.footer-wordmark{font-size:24.5vw;margin-top:65px}.mobile-nav{position:fixed;display:flex;z-index:5;bottom:0;left:0;right:0;height:71px;background:rgba(246,244,239,.94);backdrop-filter:blur(15px);border-top:1px solid #dedfd8;justify-content:space-around;padding:8px 10px env(safe-area-inset-bottom)}.mobile-nav a{font-size:9px;font-weight:600;display:flex;flex-direction:column;align-items:center;gap:3px;min-width:58px;color:#71736c}.mobile-nav b{font-size:20px;font-weight:500;line-height:1}.mobile-nav .active{color:#20231d}.mobile-nav .active b{width:31px;height:25px;border-radius:12px;background:#a9cc32;display:grid;place-items:center}.location em{max-width:155px}.menu-toggle[aria-expanded='true']{background:#a9cc32}.menu-toggle[aria-expanded='true'] i{background:#20231d}}
  @media(max-width:380px){.hero h1{font-size:50px}.section-heading h2,.app-copy h2{font-size:46px}.story-copy h2{font-size:55px}.brand{font-size:16px}.footer-grid{grid-template-columns:1fr}.footer-action{grid-column:auto}}
