---
const services=['Кофе в офис','Корпоративные сертификаты','Деловые мероприятия','Банкеты и аренда площадок']
---
<html lang="ru"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><title>Для бизнеса — Чашка кофе</title></head><body><main><a class="brand" href="/"><img src="/brand/logo.png" alt=""/>Чашка кофе</a><section class="hero"><div><p>для корпоративных клиентов</p><h1>Хороший кофе<br/>для хороших<br/>дел</h1><span>Помогаем сделать рабочий день теплее — в офисе, на встрече или на большом событии.</span><a href="#form">Обсудить задачу →</a></div><img src="/images/restaurants-hero.png" alt="Интерьер кофейни"/></section><section class="services"><p>возможности</p><h2>Выберите<br/>свой формат</h2><div>{services.map((service,index)=><article><b>0{index+1}</b><h3>{service}</h3><i>↗</i></article>)}</div></section><section id="form" class="form"><div><p>корпоративная заявка</p><h2>Давайте<br/>поговорим</h2></div><form><input placeholder="Ваше имя"/><input placeholder="Компания"/><input placeholder="Телефон"/><input placeholder="E-mail"/><textarea placeholder="Расскажите, что вам нужно"></textarea><button type="button">Отправить заявку →</button></form></section></main></body></html>
<style>@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap');:root{font-family:Montserrat,Arial,sans-serif;color:#1b211d;background:#f8f7f2}*{box-sizing:border-box}body{margin:0}.brand{height:94px;padding:0 6vw;display:flex;align-items:center;gap:10px;font-size:20px;font-weight:800;text-decoration:none;color:inherit}.brand img{width:45px;height:45px;object-fit:contain}.hero{margin:0 2vw;min-height:620px;border-radius:27px;position:relative;overflow:hidden;background:#dbe8cc}.hero img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}.hero:after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,#dbe8cc 0%,rgba(219,232,204,.9) 39%,transparent 73%)}.hero div{position:relative;z-index:1;padding:clamp(50px,7vw,115px);max-width:720px}.hero p,.services>p,.form p{font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:700;color:#7d9e20}.hero h1,.services h2,.form h2{margin:18px 0;font-size:clamp(55px,6vw,105px);line-height:.84;letter-spacing:-.1em}.hero span{display:block;max-width:420px;font-size:16px;line-height:1.55}.hero a,.form button{display:inline-block;margin-top:27px;padding:17px 21px;border-radius:999px;background:#203025;color:#fff;text-decoration:none;border:0;font:700 14px Montserrat}.services{padding:clamp(90px,11vw,160px) 7vw}.services h2{font-size:clamp(50px,5vw,87px)}.services>div{display:grid;grid-template-columns:repeat(4,1fr);gap:13px;margin-top:60px}.services article{min-height:250px;padding:25px;border-radius:22px;background:#edf0e8;position:relative}.services article:nth-child(2){background:#e4dfd5}.services article:nth-child(3){background:#d9e7cf}.services b{font-size:13px;color:#86a623}.services h3{margin:80px 0 0;font-size:26px;line-height:.92;letter-spacing:-.07em}.services i{position:absolute;right:23px;bottom:20px;font-size:23px}.form{margin:0 2vw 2vw;padding:clamp(48px,7vw,100px);border-radius:27px;background:#20372b;color:#fff;display:grid;grid-template-columns:.8fr 1.2fr;gap:70px}.form p{color:#b7d93d}.form h2{font-size:clamp(47px,5vw,80px)}form{display:grid;grid-template-columns:1fr 1fr;gap:10px}input,textarea{border:0;border-radius:10px;padding:15px;font:14px Montserrat}textarea{grid-column:1/-1;min-height:100px}button{grid-column:1/-1;justify-self:start;background:#b7d93d!important;color:#203025!important}@media(max-width:700px){.brand{height:72px;padding:0 20px}.hero{margin:0;min-height:600px;border-radius:0}.hero div{padding:50px 20px}.hero h1{font-size:59px}.hero span{font-size:15px}.services{padding:82px 20px}.services h2{font-size:51px}.services>div{grid-template-columns:1fr 1fr;gap:8px;margin-top:33px}.services article{min-height:190px;padding:18px}.services h3{margin-top:55px;font-size:22px}.form{margin:0;border-radius:0;display:block;padding:58px 20px}.form h2{font-size:52px}form{margin-top:35px;grid-template-columns:1fr}}</style>
