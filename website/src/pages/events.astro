---
import PageShell from '../layouts/PageShell.astro';
type EventRow = [string, string, string, string, string, string]
let events: EventRow[] = [['jazz-in-park','24','мая','Вечер джаза в парке','19:00 · Центральный парк','Живой звук, десерты и кофе, который особенно хорош на свежем воздухе.'],['latte-art','31','мая','Мастер-класс по латте-арту','13:00 · Красный проспект','Покажем базовые движения и дадим попробовать всё самим.'],['book-club','07','июня','Книжный клуб','18:30 · улица Ленина','Обсуждаем книгу месяца — без строгих правил, но с хорошим кофе.']]
try { const response = await fetch(`${import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'}/api/content?type=EVENT`); if (response.ok) { const data = await response.json(); events = data.entries.map((entry: any): EventRow => { const date = entry.eventStartsAt ? new Date(entry.eventStartsAt) : null; return [entry.slug, date ? String(date.getDate()).padStart(2, '0') : '—', date ? date.toLocaleDateString('ru-RU', { month: 'long' }) : 'скоро', entry.title, [date ? date.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' }) : '', entry.location].filter(Boolean).join(' · '), entry.excerpt ?? 'Подробности скоро появятся на странице события.'] }) } } catch { /* editorial fallback remains available */ }
---
<PageShell title="События" description="События и мероприятия Чашка кофе в Новосибирске." active="events"><section class="hero"><div><p>Афиша чашка кофе</p><h1>Встречаемся<br/>не только<br/>за кофе</h1><span>Музыка, книги, мастер-классы и разговоры, для которых хочется освободить вечер.</span><a href="#events">Ближайшие события ↓</a></div><i>♪</i><em>24<small>мая · 19:00</small></em></section><section id="events" class="events"><div class="heading"><p>Ближайшие события</p><h2>Сохраняйте<br/>дату</h2></div><div class="event-list">{events.map(([slug,day,month,title,place,copy])=><article><div class="date"><b>{day}</b><span>{month}</span></div><div><p>{place}</p><h3>{title}</h3><span>{copy}</span></div><a href={`/events/${slug}`}>Подробнее <b>→</b></a></article>)}</div></section><section class="archive"><div><p>Прошедшие вечера</p><h2>То, что<br/>уже было</h2><span>Архив встреч, к которым приятно возвращаться — и повод не пропустить следующую.</span></div><strong>ЧК<i>together</i></strong></section></PageShell>
<style>.hero{position:relative;min-height:670px;margin:0 2vw;padding:clamp(60px,8vw,130px);overflow:hidden;border-radius:30px;background:#203d2e;color:#fff}.hero>div{position:relative;z-index:1;max-width:690px}.hero p,.heading>p,.archive p{margin:0;color:#b9dc3c;text-transform:uppercase;letter-spacing:.15em;font-size:11px;font-weight:800}.hero h1,.heading h2,.archive h2{margin:20px 0;font-size:clamp(62px,7vw,118px);line-height:.83;letter-spacing:-.1em}.hero span{display:block;max-width:425px;font-size:16px;line-height:1.55}.hero a{display:inline-block;margin-top:31px;padding:18px 21px;border-radius:99px;background:#b7dc3a;color:#203729;text-decoration:none;font-size:13px;font-weight:800}.hero>i{position:absolute;right:8vw;top:-.33em;color:#b7dc3a;font-family:Georgia,serif;font-style:normal;font-size:clamp(300px,43vw,680px);line-height:1}.hero>em{position:absolute;z-index:2;right:7vw;bottom:55px;font-style:normal;text-align:right;font-size:clamp(53px,7vw,110px);font-weight:800;line-height:.73;letter-spacing:-.11em}.hero em small{display:block;font-size:.27em;letter-spacing:-.04em}.events{padding:clamp(100px,12vw,180px) 7vw;display:grid;grid-template-columns:.7fr 1.3fr;gap:70px}.heading h2{font-size:clamp(49px,5vw,86px)}.event-list{display:grid;gap:10px}.event-list article{display:grid;grid-template-columns:94px 1fr auto;gap:20px;padding:25px 0;border-top:1px solid #c9d0c6}.event-list article:last-child{border-bottom:1px solid #c9d0c6}.date b{font-size:58px;line-height:.77;letter-spacing:-.1em;color:#779b25}.date span{display:block;margin-top:12px;text-transform:uppercase;font-size:10px;font-weight:700}.event-list p{margin:0;color:#728c2a;font-size:10px;text-transform:uppercase;letter-spacing:.1em;font-weight:700}.event-list h3{margin:9px 0 12px;font-size:30px;line-height:.98;letter-spacing:-.07em}.event-list span{display:block;max-width:400px;font-size:12px;line-height:1.6}.event-list a{align-self:center;padding:15px 17px;border:1px solid #8e998e;border-radius:99px;color:inherit;text-decoration:none;font-size:11px;font-weight:700;white-space:nowrap}.event-list a b{margin-left:18px}.archive{position:relative;overflow:hidden;margin:0 2vw;padding:clamp(57px,7vw,112px);border-radius:28px;background:#dfebd3}.archive>div{position:relative;z-index:1}.archive h2{font-size:clamp(51px,5vw,86px)}.archive span{display:block;max-width:345px;font-size:13px;line-height:1.65}.archive strong{position:absolute;right:5vw;bottom:35px;color:#1f3c2d;font-size:clamp(110px,18vw,310px);line-height:.71;letter-spacing:-.17em}.archive strong i{display:block;font-family:'21Cent',cursive;font-size:.31em;letter-spacing:0;font-weight:400}@media(max-width:700px){.hero{margin:0;min-height:640px;padding:58px 20px;border-radius:0}.hero h1{font-size:63px}.hero span{font-size:14px}.hero>i{right:-7px;top:70px;font-size:390px}.hero>em{right:20px;bottom:41px;font-size:66px}.events{padding:86px 20px;display:block}.heading h2{font-size:55px}.event-list{margin-top:48px}.event-list article{grid-template-columns:55px 1fr;gap:12px;padding:22px 0}.date b{font-size:43px}.event-list h3{font-size:26px}.event-list span{font-size:11px}.event-list a{grid-column:2;justify-self:start}.archive{margin:0;padding:65px 20px;border-radius:0}.archive h2{font-size:57px}.archive strong{right:20px;bottom:34px;font-size:143px}}</style>
