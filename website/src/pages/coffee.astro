---
import PageShell from '../layouts/PageShell.astro';
const products=[['Эфиопия Гуджи','ягоды · бергамот · карамель','зерно'],['Колумбия Уила','шоколад · вишня · орех','дрипы'],['Бразилия Серрадо','какао · фундук · нуга','капсулы']]
---
<PageShell title="Кофе" active="coffee"><section class="hero"><div><p class="eyebrow">кофе для дома</p><h1>Ваш ритуал<br/>начинается<br/>с зерна</h1><p>Зерно, дрипы и капсулы собственной обжарки — для дома, работы и дороги.</p><a class="button" href="/app">Выбрать кофе <span>→</span></a></div><div class="pack" aria-hidden="true">ЧК<small>coffee<br/>roasters</small></div></section><section class="catalog"><div><p class="eyebrow">выберите свой вкус</p><h2>Кофе, который<br/>хочется повторить</h2></div><div class="products">{products.map(([name,taste,type],i)=><article><span>0{i+1}</span><div class="bean">●</div><p>{type}</p><h3>{name}</h3><small>{taste}</small><a href="/app">Смотреть в приложении ↗</a></article>)}</div></section><section class="story"><img src="/images/home-hero-v1.png" alt="Кофе и свежая выпечка"/><div><p class="eyebrow">собственная обжарка</p><h2>Мы ищем вкус,<br/>который запоминается</h2><p>Выбираем кофе с чистым, понятным характером и обжариваем так, чтобы он был хорош и в чашке дома, и в любимой кофейне.</p></div></section></PageShell>
<style>
@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap');:root{font-family:Montserrat,Arial,sans-serif;color:#1b201b;background:#eaebe5}*{box-sizing:border-box}body{margin:0;padding:14px;background:#eaebe5}a{color:inherit;text-decoration:none}.shell{max-width:1680px;margin:auto;overflow:hidden;border-radius:30px;background:#fdfcf8;box-shadow:0 14px 55px rgba(34,40,29,.08)}header{height:104px;padding:0 clamp(34px,4vw,72px);display:flex;align-items:center;gap:34px}.brand,.footer-brand{display:flex;align-items:center;gap:10px;font-size:22px;font-weight:800;line-height:.86;letter-spacing:-.075em}header nav{display:flex;gap:34px;margin:auto}header nav a{font-size:14px;font-weight:600}header nav .active{padding-bottom:7px;border-bottom:2px solid #9bbe2b}.top,.button{padding:15px 21px;border-radius:999px;background:#202d24;color:#fff;font-size:14px;font-weight:700}.hero{margin:0 14px;padding:clamp(60px,8vw,130px);min-height:630px;border-radius:25px;background:#e8ddca;display:grid;grid-template-columns:1fr 1fr;align-items:center}.eyebrow{margin:0 0 14px;color:#8baa27;text-transform:uppercase;letter-spacing:.14em;font-size:11px;font-weight:700}.hero h1,.catalog h2,.story h2{margin:0;font-size:clamp(58px,6vw,105px);line-height:.84;letter-spacing:-.1em}.hero p:not(.eyebrow),.story p:not(.eyebrow){max-width:410px;margin:26px 0;font-size:17px;line-height:1.55;color:#5d6058}.button{display:inline-flex;gap:27px;align-items:center}.pack{justify-self:center;width:280px;height:390px;border-radius:17px 17px 35px 35px;padding:97px 43px;background:#a8c933;color:#203025;font-size:96px;font-weight:800;letter-spacing:-.18em;box-shadow:22px 24px 0 rgba(81,77,42,.14);transform:rotate(7deg)}.pack small{display:block;margin-top:38px;font-size:19px;line-height:.9;letter-spacing:-.04em}.catalog{padding:clamp(100px,11vw,170px) clamp(34px,6.5vw,108px)}.catalog h2{font-size:clamp(53px,5vw,90px)}.products{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:60px}.products article{min-height:350px;padding:28px;border-radius:23px;background:#edf0e8;position:relative}.products article:nth-child(2){background:#e5ddca}.products article:nth-child(3){background:#dce8c9}.products span{font-size:13px;color:#8baa27;font-weight:700}.bean{position:absolute;right:27px;top:23px;font-size:91px;line-height:1;color:#33412e;transform:rotate(-24deg)}.products h3{margin:65px 0 9px;font-size:31px;line-height:.92;letter-spacing:-.07em}.products p{font-size:12px;color:#6a7268}.products small{font-size:13px;color:#626b61}.products a{display:block;margin-top:37px;font-size:12px;font-weight:700}.story{margin:0 14px 14px;min-height:460px;border-radius:25px;overflow:hidden;display:grid;grid-template-columns:1.1fr .9fr;background:#20372b;color:#fff}.story img{width:100%;height:100%;object-fit:cover}.story>div{padding:clamp(46px,6vw,98px)}.story .eyebrow{color:#b8d93c}.story h2{font-size:clamp(45px,4.5vw,78px)}.story p:not(.eyebrow){color:#d9e1d6;font-size:15px}footer{padding:70px clamp(34px,6.5vw,105px) 22px;background:#202d24;color:#fff;display:grid;grid-template-columns:1fr 1.2fr 1fr;gap:35px}.footer-brand{font-size:25px}.footer-brand+p{margin:0;font-size:clamp(28px,3vw,43px);line-height:.93;font-weight:700;letter-spacing:-.07em}footer a,footer>span{font-size:12px;color:#d1d9d0}footer>span{grid-column:1/-1;padding-top:20px;border-top:1px solid rgba(255,255,255,.16)}@media(max-width:840px){body{padding:0;background:#fdfcf8}.shell{border-radius:0;box-shadow:none}header{height:72px;padding:0 20px}.brand{font-size:18px}.brand img{width:39px;height:39px}header nav,.top{display:none}.hero{margin:0;padding:55px 20px 0;display:block;min-height:700px;border-radius:0}.hero h1{font-size:57px}.hero p:not(.eyebrow){font-size:15px}.pack{width:225px;height:300px;margin:55px auto -45px;padding:75px 32px;font-size:73px}.pack small{margin-top:27px;font-size:14px}.catalog{padding:84px 20px}.catalog h2{font-size:52px}.products{grid-template-columns:1fr;gap:8px;margin-top:34px}.products article{min-height:250px;padding:20px}.products h3{margin-top:43px;font-size:28px}.story{margin:0 12px 12px;display:block;border-radius:22px}.story img{height:270px;display:block}.story>div{padding:45px 25px}.story h2{font-size:49px}footer{padding:46px 20px 20px;display:block}.footer-brand+p{margin:30px 0}footer>span{display:block;margin-top:30px}}
</style>
