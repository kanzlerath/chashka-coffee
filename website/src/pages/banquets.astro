---
import PageShell from '../layouts/PageShell.astro';
const points=['Выберите ресторан','Расскажите о дате и гостях','Мы свяжемся и всё подготовим'];
---
<PageShell title="Банкеты"><section class="hero"><img src="/images/restaurants-hero.png" alt="Интерьер ресторана"/><div><p>Банкеты и встречи</p><h1>Соберём<br/>ваш повод</h1><span>Семейный праздник, важный ужин или встреча команды — выберите место, а мы поможем с деталями.</span><a href="#form">Оставить заявку →</a></div></section><section class="steps"><p>Как организовать</p><h2>Спокойно<br/>и по делу</h2><div>{points.map((point,index)=><article><b>0{index+1}</b><h3>{point}</h3><i>→</i></article>)}</div></section><section id="form" class="form"><div><p>Единая заявка</p><h2>Расскажите<br/>о событии</h2></div><form><input placeholder="Ваше имя"/><input placeholder="Телефон"/><input placeholder="Дата"/><input placeholder="Количество гостей"/><textarea placeholder="Комментарий"></textarea><button type="button">Отправить заявку →</button></form></section></PageShell>
<style>.hero{position:relative;min-height:610px;margin:0 2vw;overflow:hidden;border-radius:27px}.hero img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}.hero:after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,#f8f7f2 0%,rgba(248,247,242,.88) 35%,transparent 70%)}.hero div{position:relative;z-index:1;max-width:670px;padding:clamp(50px,7vw,115px)}.hero p,.steps>p,.form p{font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:700;color:#8dab27}.hero h1,.steps h2,.form h2{margin:18px 0;font-size:clamp(58px,6vw,107px);line-height:.84;letter-spacing:-.1em}.hero span{display:block;max-width:390px;font-size:16px;line-height:1.55}.hero a,.form button{display:inline-block;margin-top:27px;padding:17px 21px;border-radius:999px;background:#20382b;color:#fff;text-decoration:none;border:0;font:700 14px Montserrat}.steps{padding:clamp(90px,11vw,160px) 7vw}.steps h2{font-size:clamp(51px,5vw,88px)}.steps>div{display:grid;grid-template-columns:repeat(3,1fr);gap:13px;margin-top:60px}.steps article{min-height:260px;padding:27px;border-radius:23px;background:#e8ece2;position:relative}.steps b{font-size:13px;color:#8bab25}.steps h3{margin:75px 0 0;font-size:27px;line-height:.92;letter-spacing:-.07em}.steps i{position:absolute;right:25px;bottom:23px;font-size:24px}.form{margin:0 2vw;padding:clamp(48px,7vw,100px);border-radius:27px;background:#20382b;color:#fff;display:grid;grid-template-columns:.8fr 1.2fr;gap:70px}.form p{color:#b7d93d}.form h2{font-size:clamp(47px,5vw,80px)}form{display:grid;grid-template-columns:1fr 1fr;gap:10px}input,textarea{width:100%;border:0;border-radius:10px;padding:15px;font:14px Montserrat}textarea{grid-column:1/-1;min-height:100px}button{grid-column:1/-1;justify-self:start;background:#b7d93d!important;color:#20382b!important}@media(max-width:700px){.hero{margin:0;min-height:600px;border-radius:0}.hero div{padding:50px 20px}.hero h1{font-size:62px}.hero span{font-size:15px}.steps{padding:82px 20px}.steps h2{font-size:52px}.steps>div{grid-template-columns:1fr;gap:8px;margin-top:33px}.steps article{min-height:180px;padding:20px}.steps h3{margin-top:40px;font-size:24px}.form{margin:0;border-radius:0;display:block;padding:58px 20px}.form h2{font-size:52px}form{margin-top:35px;grid-template-columns:1fr}}</style>
